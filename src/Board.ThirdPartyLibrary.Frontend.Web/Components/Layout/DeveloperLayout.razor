@inherits LayoutComponentBase

<div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(243,154,46,0.16),_transparent_24%),radial-gradient(circle_at_top_right,_rgba(77,117,244,0.14),_transparent_22%),linear-gradient(180deg,_#17151a_0%,_#1d1a20_52%,_#151318_100%)] text-slate-100">
    <header class="border-b border-white/10 bg-[#17151a]/82 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
            <div>
                <a class="font-display text-xl font-bold uppercase tracking-[0.04em] text-white" href="/develop">Developer Console</a>
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/80">Organization and title workflows</div>
            </div>
            <nav class="hidden gap-2 md:flex">
                <NavLink class="app-nav-link" href="/games">Browse Gmaes</NavLink>
                <NavLink class="app-nav-link" href="/player/games">My Games</NavLink>
                <NavLink class="app-nav-link" href="/player/wishlist">Wishlist</NavLink>
                <NavLink class="app-nav-link" href="/develop">Develop</NavLink>
                <NavLink class="app-nav-link" href="/account">Account</NavLink>
            </nav>
            <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-300/60 hover:text-cyan-100" href="/auth/signout?returnUrl=%2Flibrary" data-enhance-nav="false">Sign out</a>
        </div>
    </header>

    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-8 sm:px-6 lg:grid-cols-[260px_minmax(0,1fr)] lg:px-8">
        <aside class="app-panel p-5">
            <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">Workspace</div>
            <nav class="mt-4 flex flex-col gap-2 text-sm text-slate-200">
                <NavLink class="app-side-link" href="/develop" Match="NavLinkMatch.All">Overview</NavLink>
                <NavLink class="app-side-link" href="/player/games">My games</NavLink>
                <NavLink class="app-side-link" href="/player/wishlist">Wishlist</NavLink>
                <NavLink class="app-side-link" href="/games">Browse Gmaes</NavLink>
                <NavLink class="app-side-link" href="/account">Account</NavLink>
            </nav>
            <div class="mt-6 rounded-[1.25rem] border border-cyan-200/20 bg-cyan-200/12 p-4 text-sm text-cyan-50/90">
                Organization-specific navigation appears here after developer access is active and the managed workspace list has loaded.
            </div>
        </aside>

        <main>
            @Body
        </main>
    </div>
</div>
