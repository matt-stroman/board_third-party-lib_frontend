@inherits LayoutComponentBase

<div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(86,189,196,0.32),_transparent_32%),linear-gradient(180deg,_#04131d_0%,_#0a1d2c_45%,_#09111d_100%)] text-slate-100">
    <header class="sticky top-0 z-40 border-b border-white/10 bg-slate-950/70 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-4 sm:px-6 lg:px-8">
            <a class="flex items-center gap-3" href="/">
                <div class="grid size-10 place-items-center rounded-2xl bg-[linear-gradient(135deg,_#4cc9f0,_#1d4ed8)] text-sm font-black tracking-[0.3em] text-slate-950">
                    B
                </div>
                <div>
                    <div class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-lg font-semibold leading-none">Board Third Party Library</div>
                    <div class="text-xs uppercase tracking-[0.24em] text-cyan-200/70">Player browse and developer tools</div>
                </div>
            </a>
            <nav class="hidden items-center gap-2 md:flex">
                <NavLink class="app-nav-link" href="/" Match="NavLinkMatch.All">Home</NavLink>
                <NavLink class="app-nav-link" href="/library">Library</NavLink>
                <NavLink class="app-nav-link" href="/develop">Develop</NavLink>
                <AuthorizeView>
                    <Authorized>
                        <NavLink class="app-nav-link" href="/account">Account</NavLink>
                    </Authorized>
                </AuthorizeView>
            </nav>
            <div class="hidden items-center gap-3 md:flex">
                <AuthorizeView>
                    <Authorized>
                        <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-300/60 hover:text-cyan-100" href="/account">Account</a>
                        <a class="rounded-full bg-cyan-300 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200" href="/auth/signout?returnUrl=%2Flibrary">Sign out</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-300/60 hover:text-cyan-100" href="/auth/signin?returnUrl=%2Fdevelop">Sign in</a>
                        <a class="rounded-full bg-cyan-300 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200" href="/library">Browse games</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
            <a class="rounded-full border border-white/15 px-3 py-2 text-sm font-medium text-slate-200 md:hidden" href="/library">Menu</a>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        @Body
    </main>

    <footer class="border-t border-white/10 bg-slate-950/50">
        <div class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-6 text-sm text-slate-300 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
            <div>Public catalog browse and authenticated developer workflows now share the same web surface.</div>
            <div class="flex gap-4 text-slate-400">
                <a class="transition hover:text-cyan-200" href="/library">Library</a>
                <a class="transition hover:text-cyan-200" href="/develop">Develop</a>
                <AuthorizeView>
                    <Authorized>
                        <a class="transition hover:text-cyan-200" href="/account">Account</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </footer>

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">x</span>
    </div>
</div>
