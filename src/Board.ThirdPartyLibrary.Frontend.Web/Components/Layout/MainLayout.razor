@inherits LayoutComponentBase
@implements IDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IBoardLibraryApiClient ApiClient
@inject IUserProfileState UserProfileState
@inject NavigationManager NavigationManager

<div class="flex min-h-screen flex-col bg-[radial-gradient(circle_at_top_left,_rgba(243,154,46,0.18),_transparent_28%),radial-gradient(circle_at_top_right,_rgba(77,117,244,0.18),_transparent_24%),radial-gradient(circle_at_top,_rgba(255,251,240,0.08),_transparent_40%),linear-gradient(180deg,_#17151a_0%,_#1d1a20_52%,_#151318_100%)] text-slate-100">
    @if (IsUserMenuOpen || IsNotificationsOpen)
    {
        <button class="fixed inset-0 z-40 cursor-default bg-transparent" type="button" aria-label="Close navigation menus" @onclick="CloseOverlays"></button>
    }

    <header class="sticky top-0 z-50 border-b border-white/10 bg-[#17151a]/78 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-4 sm:px-6 lg:px-8">
            <a class="flex items-center gap-3" href="/">
                <img class="size-10 rounded-2xl object-contain shadow-[0_12px_25px_rgba(16,14,20,0.3)]"
                     src="/favicon_sm.png"
                     alt="Board Enthusiasts logo" />
                <div>
                    <div class="font-display text-lg font-semibold leading-none text-white">Board Enthusiasts</div>
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/80">Players and Developers who ♡ Board</div>
                </div>
            </a>
            <nav class="hidden items-center gap-2 md:flex">
                <a class="@BrowseLinkClass" href="/browse" data-enhance-nav="false">Browse</a>
                <AuthorizeView>
                    <Authorized>
                        <NavLink class="app-nav-link" href="/player" data-enhance-nav="false">Play</NavLink>
                        <NavLink class="app-nav-link" href="/develop" data-enhance-nav="false">Develop</NavLink>
                        @if (ShowModerateSection)
                        {
                            <NavLink class="app-nav-link" href="/moderate" data-enhance-nav="false">Moderate</NavLink>
                        }
                    </Authorized>
                </AuthorizeView>
                <NavLink class="app-nav-link" href="/install-guide" data-enhance-nav="false">Install</NavLink>
            </nav>
            <div class="flex items-center gap-3">
                <a class="inline-flex size-11 items-center justify-center rounded-full border border-white/15 text-slate-200 transition hover:border-cyan-300/60 hover:text-cyan-100" href="https://discord.gg/cz2zReWqcA" target="_blank" rel="noreferrer" aria-label="Join the Board Enthusiasts Discord">
                    <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M20.317 4.369A19.79 19.79 0 0 0 15.438 3c-.211.375-.458.88-.628 1.274a18.27 18.27 0 0 0-5.62 0A13.74 13.74 0 0 0 8.56 3 19.736 19.736 0 0 0 3.68 4.37C.59 9.04-.246 13.595.172 18.084A19.9 19.9 0 0 0 6.16 21c.484-.665.915-1.37 1.287-2.11a12.85 12.85 0 0 1-2.024-.977c.17-.126.336-.257.497-.392 3.905 1.836 8.14 1.836 11.998 0 .166.135.332.266.497.392a12.9 12.9 0 0 1-2.03.98c.372.739.803 1.444 1.287 2.109a19.86 19.86 0 0 0 5.99-2.916c.49-5.2-.837-9.714-3.346-13.715ZM8.02 15.332c-1.18 0-2.15-1.085-2.15-2.42 0-1.335.951-2.42 2.15-2.42 1.208 0 2.17 1.094 2.15 2.42 0 1.335-.951 2.42-2.15 2.42Zm7.96 0c-1.18 0-2.15-1.085-2.15-2.42 0-1.335.951-2.42 2.15-2.42 1.208 0 2.17 1.094 2.15 2.42 0 1.335-.942 2.42-2.15 2.42Z" />
                    </svg>
                </a>
                <AuthorizeView>
                    <Authorized>
                        <div class="relative">
                            <button class="relative inline-flex size-11 items-center justify-center rounded-full border border-white/15 text-slate-200 transition hover:border-cyan-300/60 hover:text-cyan-100"
                                    type="button"
                                    aria-label="Open notifications"
                                    @onclick="ToggleNotificationsAsync">
                                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.5 17a2.5 2.5 0 0 0 5 0"></path>
                                </svg>
                                @if (UnreadNotificationCount > 0)
                                {
                                    <span class="absolute -right-1 -top-1 inline-flex min-h-5 min-w-5 items-center justify-center rounded-full bg-amber-300 px-1.5 text-[0.62rem] font-black leading-none text-slate-950">
                                        @GetUnreadNotificationBadgeText()
                                    </span>
                                }
                            </button>

                            @if (IsNotificationsOpen)
                            {
                                <section class="absolute right-0 z-50 mt-3 w-[min(92vw,24rem)] overflow-hidden rounded-[1.5rem] border border-white/15 bg-[#111017] shadow-[0_28px_70px_rgba(0,0,0,0.48)]">
                                    <div class="flex items-center justify-between gap-3 p-4">
                                        <div>
                                            <div class="text-sm font-semibold text-white">Notifications</div>
                                            <div class="text-xs text-slate-400">@GetNotificationHeaderText()</div>
                                        </div>
                                        @if (UnreadNotificationCount > 0)
                                        {
                                            <div class="rounded-full border border-amber-200/30 bg-amber-300/15 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-amber-100">@UnreadNotificationCount unread</div>
                                        }
                                    </div>
                                    <div class="border-t border-white/10"></div>

                                    @if (IsLoadingNotifications)
                                    {
                                        <div class="space-y-3 p-4">
                                            <div class="h-14 animate-pulse rounded-[1rem] bg-white/10"></div>
                                            <div class="h-14 animate-pulse rounded-[1rem] bg-white/10"></div>
                                            <div class="h-14 animate-pulse rounded-[1rem] bg-white/10"></div>
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(NotificationErrorMessage))
                                    {
                                        <div class="p-4 text-sm leading-7 text-rose-100">@NotificationErrorMessage</div>
                                    }
                                    else if (Notifications.Count == 0)
                                    {
                                        <div class="p-4 text-sm leading-7 text-slate-300">No notifications yet.</div>
                                    }
                                    else
                                    {
                                        <div class="max-h-[28rem] overflow-y-auto p-2">
                                            @foreach (var notification in Notifications)
                                            {
                                                <button class="block w-full rounded-[1rem] border px-3 py-3 text-left transition @(notification.IsRead ? "border-transparent text-slate-300 hover:bg-white/5" : "border-cyan-300/20 bg-cyan-300/8 text-slate-100 hover:border-cyan-300/35 hover:bg-cyan-300/12")"
                                                        type="button"
                                                        @onclick="() => OpenNotificationAsync(notification)">
                                                    <div class="flex items-start justify-between gap-3">
                                                        <div class="min-w-0">
                                                            <div class="truncate text-sm font-semibold text-white">@notification.Title</div>
                                                            <div class="mt-1 text-xs uppercase tracking-[0.16em] text-cyan-100/70">@FormatNotificationCategory(notification.Category)</div>
                                                        </div>
                                                        @if (!notification.IsRead)
                                                        {
                                                            <span class="mt-1 inline-flex size-2.5 shrink-0 rounded-full bg-amber-300"></span>
                                                        }
                                                    </div>
                                                    <div class="mt-2 text-sm text-slate-300" style="display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;overflow:hidden;">
                                                        @notification.Body
                                                    </div>
                                                    <div class="mt-2 text-xs text-slate-500">@FormatNotificationTimestamp(notification.CreatedAt)</div>
                                                </button>
                                            }
                                        </div>
                                    }
                                </section>
                            }
                        </div>
                        <div class="relative">
                            <button class="inline-flex size-11 items-center justify-center overflow-hidden rounded-full border border-white/15 bg-slate-900/60 text-sm font-bold text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" type="button" aria-label="Open account menu" @onclick="ToggleUserMenu">
                                @if (!string.IsNullOrWhiteSpace(AvatarImageSource))
                                {
                                    <img class="size-full object-cover" src="@AvatarImageSource" alt="User avatar" />
                                }
                                else
                                {
                                    <span>@AvatarInitials</span>
                                }
                            </button>

                            @if (IsUserMenuOpen)
                            {
                                <section class="absolute right-0 z-50 mt-3 w-[min(92vw,21rem)] overflow-hidden rounded-[1.5rem] border border-white/15 bg-[#111017] shadow-[0_28px_70px_rgba(0,0,0,0.48)]">
                                    <div class="flex items-center gap-3 p-4">
                                        <div class="grid size-12 place-items-center overflow-hidden rounded-full bg-slate-800 text-sm font-bold text-slate-100">
                                            @if (!string.IsNullOrWhiteSpace(AvatarImageSource))
                                            {
                                                <img class="size-full object-cover" src="@AvatarImageSource" alt="User avatar" />
                                            }
                                            else
                                            {
                                                <span>@AvatarInitials</span>
                                            }
                                        </div>
                                        <div class="min-w-0">
                                            <div class="truncate text-sm font-semibold text-white">@MenuUserNameLine</div>
                                            <div class="truncate text-xs text-slate-300">@MenuDisplayNameLine</div>
                                        </div>
                                    </div>

                                    <div class="border-t border-white/10"></div>
                                    <nav class="p-2 text-sm text-slate-200">
                                        <button class="block w-full rounded-xl px-3 py-2 text-left transition hover:bg-white/10" type="button" @onclick='() => NavigateToAndCloseUserMenu("/player?workflow=account-profile")'>Profile</button>
                                        <button class="block w-full rounded-xl px-3 py-2 text-left transition hover:bg-white/10" type="button" @onclick='() => NavigateToAndCloseUserMenu("/player")'>My Games</button>
                                        <button class="block w-full rounded-xl px-3 py-2 text-left transition hover:bg-white/10" type="button" @onclick='() => NavigateToAndCloseUserMenu("/player/wishlist")'>Wishlist</button>
                                        <button class="block w-full rounded-xl px-3 py-2 text-left transition hover:bg-white/10" type="button" @onclick='() => NavigateToAndCloseUserMenu("/player?workflow=reported-titles")'>Reported Titles</button>
                                    </nav>

                                    @if (ShowDeveloperSection)
                                    {
                                        <div class="border-t border-white/10"></div>
                                        <nav class="p-2 text-sm text-slate-200">
                                            <button class="block w-full rounded-xl px-3 py-2 text-left transition hover:bg-white/10" type="button" @onclick='() => NavigateToAndCloseUserMenu("/develop")'>Developer Console</button>
                                        </nav>
                                    }

                                    @if (ShowModerateSection)
                                    {
                                        <div class="border-t border-white/10"></div>
                                        <nav class="p-2 text-sm text-slate-200">
                                            <button class="block w-full rounded-xl px-3 py-2 text-left transition hover:bg-white/10" type="button" @onclick='() => NavigateToAndCloseUserMenu("/moderate")'>Moderate</button>
                                        </nav>
                                    }

                                    <div class="border-t border-white/10"></div>
                                    <nav class="p-2 text-sm text-slate-200">
                                        <button class="block w-full rounded-xl px-3 py-2 text-left transition hover:bg-white/10" type="button" @onclick='() => NavigateToAndCloseUserMenu("/player?workflow=account-settings")'>Account Settings</button>
                                    </nav>

                                    <div class="border-t border-white/10"></div>
                                    <nav class="p-2 text-sm text-slate-200">
                                        <a class="block rounded-xl px-3 py-2 text-rose-100 transition hover:bg-rose-400/20" href="/auth/signout?returnUrl=%2Fbrowse" data-enhance-nav="false" @onclick="CloseUserMenu">Sign Out</a>
                                    </nav>
                                </section>
                            }
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-300/60 hover:text-cyan-100" href="/auth/signin?returnUrl=%2Fplayer" data-enhance-nav="false">Sign In</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
        <div class="mx-auto flex max-w-7xl gap-2 overflow-x-auto px-4 pb-4 sm:px-6 md:hidden lg:px-8">
            <a class="@($"{BrowseLinkClass} whitespace-nowrap")" href="/browse" data-enhance-nav="false">Browse</a>
            <AuthorizeView>
                <Authorized>
                    <NavLink class="app-nav-link whitespace-nowrap" href="/player" data-enhance-nav="false">Play</NavLink>
                    <NavLink class="app-nav-link whitespace-nowrap" href="/develop" data-enhance-nav="false">Develop</NavLink>
                    @if (ShowModerateSection)
                    {
                        <NavLink class="app-nav-link whitespace-nowrap" href="/moderate" data-enhance-nav="false">Moderate</NavLink>
                    }
                </Authorized>
            </AuthorizeView>
            <NavLink class="app-nav-link whitespace-nowrap" href="/install-guide" data-enhance-nav="false">Install</NavLink>
        </div>
    </header>

    <main class="mx-auto flex-1 w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        @Body
    </main>

    <footer class="border-t border-white/10 bg-[#17151a]/72">
        <div class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-6 text-sm text-slate-300 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
            <div>Browse games, manage your account, and build in the developer console.</div>
            <div class="flex gap-4 text-slate-400">
                <a class="transition hover:text-cyan-200" href="/browse">Browse</a>
                <AuthorizeView>
                    <Authorized>
                        <a class="transition hover:text-cyan-200" href="/player">Play</a>
                        <a class="transition hover:text-cyan-200" href="/player/wishlist">Wishlist</a>
                        <a class="transition hover:text-cyan-200" href="/player?workflow=reported-titles">Reported Titles</a>
                        <a class="transition hover:text-cyan-200" href="/develop">Develop</a>
                        @if (ShowModerateSection)
                        {
                            <a class="transition hover:text-cyan-200" href="/moderate">Moderate</a>
                        }
                        <a class="transition hover:text-cyan-200" href="/account">Account</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="transition hover:text-cyan-200" href="/install-guide">Install</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </footer>

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">x</span>
    </div>
</div>

@code {
    private CurrentUserResponse? CurrentUser { get; set; }

    private UserProfile? CurrentProfile { get; set; }

    private DeveloperEnrollment? EnrollmentState { get; set; }

    private bool IsUserMenuOpen { get; set; }
    private bool IsNotificationsOpen { get; set; }
    private bool IsLoadingNotifications { get; set; }
    private string? NotificationErrorMessage { get; set; }
    private IReadOnlyList<UserNotification> Notifications { get; set; } = [];

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        UserProfileState.Changed += HandleUserProfileStateChanged;
        CurrentProfile = UserProfileState.Profile;

        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authenticationState.User.Identity?.IsAuthenticated == true)
        {
            try
            {
                CurrentUser = await ApiClient.GetCurrentUserAsync();
                CurrentProfile = await ApiClient.GetCurrentUserProfileAsync();
                UserProfileState.SetProfile(CurrentProfile);
                EnrollmentState = (await ApiClient.GetDeveloperEnrollmentAsync()).DeveloperEnrollment;
                await LoadNotificationsAsync();
            }
            catch
            {
                // Keep shell rendering resilient even if profile APIs are unavailable.
            }
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        UserProfileState.Changed -= HandleUserProfileStateChanged;
    }

    private string BrowseLinkClass => IsBrowseRoute
        ? "app-nav-link active"
        : "app-nav-link";

    private bool IsBrowseRoute
    {
        get
        {
            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            if (string.IsNullOrWhiteSpace(relativePath))
            {
                return true;
            }

            return relativePath.StartsWith("browse", StringComparison.OrdinalIgnoreCase)
                || relativePath.StartsWith("studios", StringComparison.OrdinalIgnoreCase)
                || relativePath.StartsWith("library", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool IsDeveloperRole => EnrollmentState.HasDeveloperAccess() || CurrentUser.IsDeveloper();

    private bool ShowDeveloperSection => IsDeveloperRole;

    private bool ShowModerateSection => CurrentUser.HasRole("moderator");
    private int UnreadNotificationCount => Notifications.Count(candidate => !candidate.IsRead);

    private string AvatarInitials => string.IsNullOrWhiteSpace(CurrentProfile?.Initials)
        ? "U"
        : CurrentProfile.Initials;

    private string? AvatarImageSource => CurrentProfile?.AvatarDataUrl ?? CurrentProfile?.AvatarUrl;

    private string MenuUserNameLine =>
        FirstNonEmpty(CurrentProfile?.UserName, CurrentProfile?.DisplayName, CurrentUser?.DisplayName, "board-user");

    private string MenuDisplayNameLine
    {
        get
        {
            var displayName = FirstNonEmpty(CurrentProfile?.DisplayName, CurrentUser?.DisplayName);
            if (!string.IsNullOrWhiteSpace(displayName))
            {
                return displayName;
            }

            var firstName = CurrentProfile?.FirstName?.Trim();
            var lastName = CurrentProfile?.LastName?.Trim();
            if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            {
                return string.Join(' ', new[] { firstName, lastName }.Where(value => !string.IsNullOrWhiteSpace(value)));
            }

            return FirstNonEmpty(CurrentUser?.Email, "Board user");
        }
    }

    private void HandleUserProfileStateChanged()
    {
        CurrentProfile = UserProfileState.Profile;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ToggleNotificationsAsync()
    {
        IsUserMenuOpen = false;
        IsNotificationsOpen = !IsNotificationsOpen;
        if (IsNotificationsOpen)
        {
            await LoadNotificationsAsync();
        }
    }

    private void ToggleUserMenu()
    {
        IsNotificationsOpen = false;
        IsUserMenuOpen = !IsUserMenuOpen;
    }

    private void CloseUserMenu() => IsUserMenuOpen = false;

    private void CloseOverlays()
    {
        IsUserMenuOpen = false;
        IsNotificationsOpen = false;
    }

    private void NavigateToAndCloseUserMenu(string href)
    {
        CloseUserMenu();
        NavigationManager.NavigateTo(href);
    }

    private async Task LoadNotificationsAsync()
    {
        if (CurrentUser is null)
        {
            Notifications = [];
            return;
        }

        IsLoadingNotifications = true;
        NotificationErrorMessage = null;

        try
        {
            Notifications = (await ApiClient.GetCurrentUserNotificationsAsync()).Notifications
                .OrderByDescending(candidate => candidate.CreatedAt)
                .ToArray();
        }
        catch (Exception exception)
        {
            NotificationErrorMessage = exception.Message;
        }
        finally
        {
            IsLoadingNotifications = false;
        }
    }

    private async Task OpenNotificationAsync(UserNotification notification)
    {
        if (!notification.IsRead)
        {
            try
            {
                var response = await ApiClient.MarkCurrentUserNotificationReadAsync(notification.Id);
                Notifications = Notifications
                    .Select(candidate => candidate.Id == response.Notification.Id ? response.Notification : candidate)
                    .OrderByDescending(candidate => candidate.CreatedAt)
                    .ToArray();
            }
            catch
            {
                // Keep navigation resilient even if the read mutation fails.
            }
        }

        IsNotificationsOpen = false;
        if (!string.IsNullOrWhiteSpace(notification.ActionUrl))
        {
            NavigationManager.NavigateTo(notification.ActionUrl);
        }
    }

    private string GetUnreadNotificationBadgeText() => UnreadNotificationCount > 9 ? "9+" : UnreadNotificationCount.ToString();

    private string GetNotificationHeaderText() =>
        Notifications.Count == 0
            ? "No recent activity"
            : $"{Notifications.Count} recent item{(Notifications.Count == 1 ? string.Empty : "s")}";

    private static string FormatNotificationCategory(string category) =>
        string.Equals(category, "title_report", StringComparison.OrdinalIgnoreCase)
            ? "Title Report"
            : string.IsNullOrWhiteSpace(category)
                ? "Notification"
                : category.Replace('_', ' ').Trim();

    private static string FormatNotificationTimestamp(DateTime timestamp)
    {
        var elapsed = DateTime.UtcNow - timestamp.ToUniversalTime();
        if (elapsed.TotalMinutes < 1)
        {
            return "Just now";
        }

        if (elapsed.TotalHours < 1)
        {
            return $"{Math.Max(1, (int)elapsed.TotalMinutes)}m ago";
        }

        if (elapsed.TotalDays < 1)
        {
            return $"{Math.Max(1, (int)elapsed.TotalHours)}h ago";
        }

        if (elapsed.TotalDays < 7)
        {
            return $"{Math.Max(1, (int)elapsed.TotalDays)}d ago";
        }

        return timestamp.ToLocalTime().ToString("MMM d, yyyy h:mm tt");
    }

    private static string FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value))?.Trim() ?? string.Empty;
}
