@page "/account"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Account</PageTitle>

<section class="space-y-6">
    <div class="app-chip w-fit">Current user</div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Account unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CurrentUser is null || EnrollmentState is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-44 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-36 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Account</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                Account shows player-facing access state and profile details without exposing raw backend control codes.
            </p>

            <dl class="mt-6 grid gap-4 text-sm text-slate-300 sm:grid-cols-2">
                <div class="rounded-[1.25rem] bg-black/15 p-4"><dt class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Display name</dt><dd class="mt-2 text-base text-white">@CurrentUser.DisplayName</dd></div>
                <div class="rounded-[1.25rem] bg-black/15 p-4"><dt class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Email</dt><dd class="mt-2 text-base text-white">@CurrentUser.Email</dd></div>
                <div class="rounded-[1.25rem] bg-black/15 p-4"><dt class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Player library access</dt><dd class="mt-2 text-base text-white">Active</dd></div>
                <div class="rounded-[1.25rem] bg-black/15 p-4"><dt class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Developer access</dt><dd class="mt-2 text-base text-white">@EnrollmentState.ToStatusLabel()</dd></div>
                <div class="rounded-[1.25rem] bg-black/15 p-4"><dt class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Email verification</dt><dd class="mt-2 text-base text-white">@(CurrentUser.EmailVerified ? "Verified" : "Pending")</dd></div>
                <div class="rounded-[1.25rem] bg-black/15 p-4"><dt class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Board profile</dt><dd class="mt-2 text-base text-white">@(BoardProfile is null ? "Not linked" : "Linked")</dd></div>
            </dl>

            <div class="mt-6 grid gap-4 lg:grid-cols-2">
                <section class="rounded-[1.5rem] border border-white/10 bg-black/10 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Player area</div>
                    <h2 class="mt-3 text-xl font-semibold text-white">Player-first default</h2>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                        New accounts start in the player library. Wishlist, collections, favorites, and owned-title management will build from that authenticated player surface.
                    </p>
                    <a class="mt-4 inline-flex rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/player/games">Open my games</a>
                </section>
                <section class="rounded-[1.5rem] border border-white/10 bg-black/10 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Developer area</div>
                    <h2 class="mt-3 text-xl font-semibold text-white">Separate developer enrollment</h2>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                        @EnrollmentState.ToStatusDescription()
                    </p>
                    <a class="mt-4 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/account/developer-access">Manage developer access</a>
                </section>
            </div>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/account/profile">Edit profile</a>
                <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/account/settings">Account settings</a>
                <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/account/board-profile">Manage Board profile</a>
                @if (CurrentUser.IsModerator())
                {
                    <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/moderation/developer-enrollment-requests">Review developer requests</a>
                }
                <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/auth/signout?returnUrl=%2Flibrary" data-enhance-nav="false">Sign out</a>
            </div>
        </section>
    }
</section>

@code {
    private CurrentUserResponse? CurrentUser { get; set; }

    private DeveloperEnrollment? EnrollmentState { get; set; }

    private BoardProfile? BoardProfile { get; set; }

    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ErrorMessage = null;

        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            BoardProfile = await ApiClient.GetBoardProfileAsync();
            EnrollmentState = (await ApiClient.GetDeveloperEnrollmentAsync()).DeveloperEnrollment;

            if (CurrentUser is null)
            {
                ErrorMessage = "The authenticated user profile could not be loaded from the backend.";
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }
}
