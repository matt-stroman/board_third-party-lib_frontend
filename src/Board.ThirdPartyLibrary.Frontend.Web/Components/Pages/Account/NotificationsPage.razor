@page "/account/notifications"
@attribute [Authorize]
@inject INotificationCenter NotificationCenter

<PageTitle>Notifications</PageTitle>

<section class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Notifications unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (!NotificationCenter.IsLoaded)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-44 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (Notifications.Count == 0)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">No notifications yet</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">Developer-enrollment updates and other in-app notifications will appear here.</p>
        </section>
    }
    else
    {
        <section class="grid gap-4 lg:grid-cols-3">
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Unread</div>
                <div class="mt-3 text-4xl font-black text-white">@UnreadCount</div>
            </section>
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Read</div>
                <div class="mt-3 text-4xl font-black text-white">@ReadCount</div>
            </section>
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Latest activity</div>
                <div class="mt-3 text-base font-semibold text-white">@LatestActivityLabel</div>
            </section>
        </section>

        <section class="space-y-4">
            @foreach (var notification in Notifications)
            {
                <section class="app-panel p-6">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div>
                            <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">@notification.Category.Replace('_', ' ')</div>
                            <h1 class="mt-3 text-2xl font-semibold text-white">@notification.Title</h1>
                            <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-300">@notification.Body</p>
                            <div class="mt-4 text-xs uppercase tracking-[0.18em] text-cyan-100/70">@notification.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy 'at' h:mm tt")</div>
                        </div>
                        <div class="flex flex-col gap-3 sm:flex-row">
                            @if (!string.IsNullOrWhiteSpace(notification.ActionUrl))
                            {
                                <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@notification.ActionUrl">Open</a>
                            }
                            @if (!notification.IsRead)
                            {
                                <button class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" type="button" @onclick="() => MarkReadAsync(notification.NotificationId)">Mark read</button>
                            }
                        </div>
                    </div>
                </section>
            }
        </section>
    }
</section>

@code {
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<UserNotification> Notifications => NotificationCenter.Notifications;
    private int UnreadCount => Notifications.Count(static notification => !notification.IsRead);
    private int ReadCount => Notifications.Count(static notification => notification.IsRead);
    private string LatestActivityLabel =>
        Notifications.Count == 0
            ? "No activity yet"
            : Notifications[0].CreatedAt.ToLocalTime().ToString("MMMM d, yyyy 'at' h:mm tt");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await NotificationCenter.EnsureLoadedAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }

    private async Task MarkReadAsync(Guid notificationId)
    {
        try
        {
            await NotificationCenter.MarkReadAsync(notificationId);
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }
}
