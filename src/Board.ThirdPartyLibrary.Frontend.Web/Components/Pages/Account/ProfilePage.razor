@page "/account/profile"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@inject IBoardLibraryApiClient ApiClient
@inject IUserProfileState UserProfileState

<PageTitle>Profile</PageTitle>

<section class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Profile unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Profile is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-40 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-44 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else
    {
        <section class="grid gap-4 lg:grid-cols-[1fr_1fr]">
            <section class="app-panel p-6">
                <h1 class="app-page-title">Profile</h1>
                <p class="mt-4 text-sm leading-7 text-slate-300">
                    Public profile details appear across player and developer spaces. Avatar supports hosted URLs or direct upload.
                </p>

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
                }

                <div class="mt-6 grid gap-4">
                    <label class="text-sm text-slate-300">Display Name
                        <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="DisplayName" />
                    </label>
                </div>

                <div class="mt-6 flex flex-wrap gap-3">
                    <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="SaveProfileAsync" disabled="@IsSavingProfile">
                        @(IsSavingProfile ? "Saving..." : "Save profile")
                    </button>
                    <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/account/settings">Account Settings</a>
                </div>
            </section>

            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Avatar</div>
                <div class="mt-4 flex items-center gap-4">
                    <div class="grid size-20 place-items-center overflow-hidden rounded-full bg-slate-800 text-lg font-bold text-slate-100">
                        @if (!string.IsNullOrWhiteSpace(AvatarSource))
                        {
                            <img class="size-full object-cover" src="@AvatarSource" alt="Profile avatar" />
                        }
                        else
                        {
                            <span>@AvatarInitials</span>
                        }
                    </div>
                    <div class="text-sm leading-7 text-slate-300">Recommended formats: JPEG, PNG, WEBP, GIF up to 2 MB.</div>
                </div>

                <div class="mt-6 grid gap-4">
                    <label class="text-sm text-slate-300">Avatar URL
                        <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="AvatarUrlInput" placeholder="https://..." />
                    </label>
                    <div class="flex flex-wrap gap-3">
                        <button class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="SaveAvatarUrlAsync" disabled="@IsSavingAvatarUrl">
                            @(IsSavingAvatarUrl ? "Saving..." : "Use URL")
                        </button>
                        <button class="rounded-full border border-rose-300/30 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="RemoveAvatarAsync" disabled="@IsRemovingAvatar">
                            @(IsRemovingAvatar ? "Removing..." : "Remove avatar")
                        </button>
                    </div>
                </div>

                <div class="mt-6">
                    <div class="text-sm text-slate-300">Upload avatar</div>
                    <div class="mt-3 flex flex-wrap items-center gap-3">
                        <label class="app-file-button" for="@AvatarUploadInputId">Choose File...</label>
                        <InputFile id="@AvatarUploadInputId" class="sr-only" OnChange="UploadAvatarAsync" accept="image/jpeg,image/png,image/webp,image/gif" />
                        <span class="text-sm text-slate-300">@AvatarUploadSummary</span>
                    </div>
                </div>
            </section>
        </section>
    }
</section>

@code {
    private UserProfile? Profile { get; set; }

    private const string AvatarUploadInputId = "profile-avatar-upload";

    private string? DisplayName { get; set; }

    private string? AvatarUrlInput { get; set; }

    private string AvatarUploadSummary { get; set; } = "No file chosen";

    private string? StatusMessage { get; set; }

    private string? ErrorMessage { get; set; }

    private bool IsSavingProfile { get; set; }

    private bool IsSavingAvatarUrl { get; set; }

    private bool IsRemovingAvatar { get; set; }

    private string AvatarInitials => string.IsNullOrWhiteSpace(Profile?.Initials) ? "U" : Profile.Initials;

    private string? AvatarSource => Profile?.AvatarDataUrl ?? Profile?.AvatarUrl;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task SaveProfileAsync()
    {
        if (IsSavingProfile)
        {
            return;
        }

        IsSavingProfile = true;
        await ExecuteAsync(async () =>
        {
            var response = await ApiClient.UpdateCurrentUserProfileAsync(
                new UpdateUserProfileRequest(DisplayName));
            SetProfile(response.Profile);
            StatusMessage = "Profile details updated.";
        });
        IsSavingProfile = false;
    }

    private async Task SaveAvatarUrlAsync()
    {
        if (IsSavingAvatarUrl)
        {
            return;
        }

        IsSavingAvatarUrl = true;
        await ExecuteAsync(async () =>
        {
            if (string.IsNullOrWhiteSpace(AvatarUrlInput))
            {
                throw new InvalidOperationException("Avatar URL is required.");
            }

            var response = await ApiClient.SetCurrentUserAvatarUrlAsync(AvatarUrlInput);
            SetProfile(response.Profile);
            StatusMessage = "Avatar URL saved.";
        });
        IsSavingAvatarUrl = false;
    }

    private async Task RemoveAvatarAsync()
    {
        if (IsRemovingAvatar)
        {
            return;
        }

        IsRemovingAvatar = true;
        await ExecuteAsync(async () =>
        {
            var response = await ApiClient.RemoveCurrentUserAvatarAsync();
            SetProfile(response.Profile);
            AvatarUrlInput = null;
            StatusMessage = "Avatar removed.";
        });
        IsRemovingAvatar = false;
    }

    private async Task UploadAvatarAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        AvatarUploadSummary = file.Name;
        await ExecuteAsync(async () =>
        {
            await using var stream = file.OpenReadStream(2L * 1024L * 1024L);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var response = await ApiClient.UploadCurrentUserAvatarAsync(new ApiUploadFile(file.Name, file.ContentType, memoryStream.ToArray()));
            SetProfile(response.Profile);
            AvatarUrlInput = null;
            StatusMessage = "Avatar uploaded.";
        });
    }

    private async Task LoadAsync()
    {
        await ExecuteAsync(async () =>
        {
            var profile = await ApiClient.GetCurrentUserProfileAsync();
            if (profile is null)
            {
                throw new InvalidOperationException("The current user profile could not be loaded.");
            }

            SetProfile(profile);
        });
    }

    private void SetProfile(UserProfile profile)
    {
        Profile = profile;
        DisplayName = profile.DisplayName;
        AvatarUrlInput = profile.AvatarUrl;
        UserProfileState.SetProfile(profile);
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        ErrorMessage = null;
        StatusMessage = null;
        try
        {
            await action();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }
}
