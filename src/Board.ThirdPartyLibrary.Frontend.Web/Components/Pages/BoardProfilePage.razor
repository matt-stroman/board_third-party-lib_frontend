@page "/account/board-profile"
@layout DeveloperLayout

<PageTitle>Board Profile</PageTitle>

<section class="app-panel max-w-3xl p-6">
    <div class="app-chip w-fit">Board profile</div>
    <h1 class="mt-4 app-page-title">Linked Board Profile</h1>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <label class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">Board user ID<div class="mt-2 text-white">board_user_12345</div></label>
        <label class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">Display name<div class="mt-2 text-white">BoardKiddo</div></label>
        <label class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300 sm:col-span-2">Avatar URL<div class="mt-2 text-white">https://cdn.board.fun/users/board_user_12345/avatar.png</div></label>
    </div>
    <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/account">Save changes</a>
        <a class="rounded-full border border-rose-300/30 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-rose-100" href="/account">Remove link</a>
    </div>
</section>
