@page "/develop"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Developer Console</PageTitle>

<section class="app-workspace-shell space-y-6">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Developer console unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CurrentUser is null || EnrollmentState is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-40 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!HasDeveloperAccess)
    {
        <section class="app-panel p-6">
            <h1 class="mt-4 app-page-title">Become a Developer</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                Want to create games and apps for Board? Great!
            </p>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                Click below to gain access to the developer console, where you can manage your studios, titles, releases, and more.
            </p>
            <div class="mt-6">
                <button class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="SubmitEnrollmentAsync" disabled="@(IsSubmitting || !CanSubmitEnrollment)">
                    @(IsSubmitting ? "Enabling..." : "Become a Developer")
                </button>
            </div>
        </section>
    }
    else
    {
        <section class="app-workspace-content">
            <div>
                <h1 class="app-page-title">Developer Console</h1>
                <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                    Manage studios, titles, releases, and publishing settings.
                </p>
            </div>

            <section class="app-panel w-full p-4">
                <div class="flex flex-wrap gap-2">
                    @foreach (var domain in DevelopDomains)
                    {
                        <button class="@GetDomainButtonClass(domain)"
                                type="button"
                                @onclick="() => SelectDomainAsync(domain)">
                            @GetDomainLabel(domain)
                        </button>
                    }
                </div>
            </section>

            <section class="app-workspace-grid">
                <aside class="app-panel p-4">

                    <div class="mt-3 text-xs uppercase tracking-[0.2em] text-cyan-100/70">Studio</div>
                    <div class="mt-2 flex items-center gap-2">
                        @if (Studios.Count == 0)
                        {
                            <select class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-400"
                                    disabled>
                                <option>No studios yet</option>
                            </select>
                        }
                        else
                        {
                            <select class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100"
                                    @onchange="OnActiveStudioChanged">
                                @foreach (var studio in Studios)
                                {
                                    <option value="@studio.Id" selected="@(studio.Id == ActiveStudioId)">@studio.DisplayName</option>
                                }
                            </select>
                        }
                        <button class="inline-flex size-10 shrink-0 items-center justify-center rounded-full border border-white/15 text-lg font-semibold leading-none text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 disabled:cursor-not-allowed disabled:opacity-60"
                                type="button"
                                title="Create studio"
                                aria-label="Create studio"
                                @onclick="OpenCreateStudioWorkflowAsync"
                                disabled="@IsBusy">
                            +
                        </button>
                    </div>

                    @if (ActiveDomain is DevelopDomain.Titles or DevelopDomain.Releases or DevelopDomain.Publishing)
                    {
                        <div class="mt-3 text-xs uppercase tracking-[0.2em] text-cyan-100/70">Title</div>

                        @if (ActiveStudio is null)
                        {
                            <div class="mt-2 flex items-center gap-2">
                                <select class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-400"
                                        disabled>
                                    <option>Select a studio first</option>
                                </select>
                                <button class="inline-flex size-10 shrink-0 items-center justify-center rounded-full border border-white/15 text-lg font-semibold leading-none text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 disabled:cursor-not-allowed disabled:opacity-60"
                                        type="button"
                                        title="Create title"
                                        aria-label="Create title"
                                        @onclick="OpenCreateTitleWorkflowAsync"
                                        disabled>
                                    +
                                </button>
                            </div>
                        }
                        else if (ActiveStudioTitles.Count == 0)
                        {
                            <div class="mt-2 flex items-center gap-2">
                                <select class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-400"
                                        disabled>
                                    <option>No titles yet</option>
                                </select>
                                <button class="inline-flex size-10 shrink-0 items-center justify-center rounded-full border border-white/15 text-lg font-semibold leading-none text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 disabled:cursor-not-allowed disabled:opacity-60"
                                        type="button"
                                        title="Create title"
                                        aria-label="Create title"
                                        @onclick="OpenCreateTitleWorkflowAsync"
                                        disabled="@IsBusy">
                                    +
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="mt-2 flex items-center gap-2">
                                <select class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100"
                                        @onchange="OnActiveTitleChanged">
                                    @foreach (var title in ActiveStudioTitles)
                                    {
                                        <option value="@title.Id" selected="@(title.Id == ActiveTitleId)">@title.DisplayName</option>
                                    }
                                </select>
                                <button class="inline-flex size-10 shrink-0 items-center justify-center rounded-full border border-white/15 text-lg font-semibold leading-none text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 disabled:cursor-not-allowed disabled:opacity-60"
                                        type="button"
                                        title="Create title"
                                        aria-label="Create title"
                                        @onclick="OpenCreateTitleWorkflowAsync"
                                        disabled="@IsBusy">
                                    +
                                </button>
                            </div>
                        }
                    }

                    <div class="mt-3 text-xs uppercase tracking-[0.2em] text-cyan-100/70">Workflow</div>
                    <nav class="mt-3 space-y-2">
                        @foreach (var workflow in GetWorkflows(ActiveDomain))
                        {
                            <button class="@GetWorkflowButtonClass(workflow.Key)"
                                    type="button"
                                    @onclick="() => SelectWorkflow(workflow.Key)">
                                @workflow.Label
                            </button>
                        }
                    </nav>
                </aside>

                <section class="app-panel app-workspace-main p-6">
                    @if (IsBusy && !HasActiveDomainData())
                    {
                        <div class="h-7 w-52 animate-pulse rounded-full bg-white/10"></div>
                        <div class="mt-4 h-44 animate-pulse rounded-[1.25rem] bg-white/10"></div>
                    }
                    else if (ActiveDomain == DevelopDomain.Studios)
                    {
                        @if (ActiveWorkflow == "studios-overview")
                        {
                            <h2 class="text-2xl font-semibold text-white">Studios</h2>

                            @if (Studios.Count == 0)
                            {
                                <p class="mt-6 text-sm text-slate-300">No managed studios yet.</p>
                            }
                            else
                            {
                                <div class="mt-6 grid gap-3 lg:grid-cols-2">
                                    @foreach (var studio in Studios)
                                    {
                                        <section class="rounded-[1.1rem] border border-white/10 bg-black/15 p-4">
                                            <div class="flex items-start justify-between gap-4">
                                                <div>
                                                    <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">@FormatMembershipRole(studio.Role)</div>
                                                    <div class="mt-2 text-lg font-semibold text-white">@studio.DisplayName</div>
                                                    <div class="mt-2 text-sm text-cyan-100/70">@studio.Slug</div>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(studio.LogoUrl))
                                                {
                                                    <img class="h-16 w-16 rounded-[1rem] border border-white/10 object-cover" src="@studio.LogoUrl" alt="@($"{studio.DisplayName} logo")" />
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(studio.Description))
                                            {
                                                <p class="mt-2 text-sm text-slate-300">@studio.Description</p>
                                            }
                                            <div class="mt-4 flex flex-wrap gap-3 text-sm">
                                                <button class="text-cyan-200 transition hover:text-cyan-100"
                                                        type="button"
                                                        @onclick="() => SelectStudioForSettings(studio.Id)">
                                                    Edit in console
                                                </button>
                                            </div>
                                        </section>
                                    }
                                </div>
                            }
                        }
                        else if (ActiveWorkflow == "studios-create")
                        {
                            <h2 class="text-2xl font-semibold text-white">Create Studio</h2>
                            <p class="mt-3 text-sm leading-7 text-slate-300">
                                Create a managed studio in-place. The new studio becomes active immediately.
                            </p>

                            @if (!string.IsNullOrWhiteSpace(StudioStatusMessage))
                            {
                                <div class="@GetStudioStatusClass() mt-5 rounded-[1rem] border px-4 py-3 text-sm">
                                    @StudioStatusMessage
                                </div>
                            }

                            <div class="mt-6 grid gap-4 lg:grid-cols-2">
                                <label class="block">
                                    <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Display Name</span>
                                    <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                           value="@NewStudioDisplayName"
                                           @oninput="OnNewStudioDisplayNameInput"
                                           placeholder="Stellar Forge" />
                                </label>
                                <label class="block">
                                    <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Slug</span>
                                    <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/55 px-4 py-3 text-slate-300"
                                           value="@NewStudioSlug"
                                           readonly />
                                </label>
                            </div>
                            <label class="mt-4 block">
                                <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Description</span>
                                <textarea class="mt-2 min-h-28 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                          value="@NewStudioDescription"
                                          @oninput="OnNewStudioDescriptionInput"
                                          placeholder="Family co-op studio focused on couch multiplayer."></textarea>
                            </label>
                            <div class="mt-6 grid gap-5 xl:grid-cols-2">
                                <section class="rounded-[1.1rem] border border-white/10 bg-black/10 p-4">
                                    <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Studio Logo</div>
                                    @if (GetPreferredStudioMediaPreview(PendingNewStudioLogoPreviewUrl, NewStudioLogoUrl) is { } newStudioLogoPreview)
                                    {
                                        <img class="mt-3 h-24 w-24 rounded-[1rem] border border-white/10 object-cover" src="@newStudioLogoPreview" alt="Studio logo preview" />
                                    }
                                    <label class="mt-4 block">
                                        <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Logo URL</span>
                                        <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                               value="@NewStudioLogoUrl"
                                               @oninput="OnNewStudioLogoUrlInput"
                                               placeholder="https://cdn.example.com/studios/stellar-forge.png" />
                                    </label>
                                    <div class="mt-3 flex flex-wrap items-center gap-3">
                                        <label class="cursor-pointer rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" for="new-studio-logo-upload">Upload image</label>
                                        <InputFile id="new-studio-logo-upload" class="sr-only" OnChange="HandleNewStudioLogoUploadAsync" accept="image/svg+xml,image/jpeg,image/png,image/webp,image/gif" />
                                        @if (PendingNewStudioLogoFile is not null)
                                        {
                                            <span class="text-xs text-slate-400">@PendingNewStudioLogoFile.FileName</span>
                                        }
                                    </div>
                                </section>
                                <section class="rounded-[1.1rem] border border-white/10 bg-black/10 p-4">
                                    <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Studio Banner</div>
                                    @if (GetPreferredStudioMediaPreview(PendingNewStudioBannerPreviewUrl, NewStudioBannerUrl) is { } newStudioBannerPreview)
                                    {
                                        <img class="mt-3 h-28 w-full rounded-[1rem] border border-white/10 object-cover" src="@newStudioBannerPreview" alt="Studio banner preview" />
                                    }
                                    <label class="mt-4 block">
                                        <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Banner URL</span>
                                        <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                               value="@NewStudioBannerUrl"
                                               @oninput="OnNewStudioBannerUrlInput"
                                               placeholder="https://cdn.example.com/studios/stellar-forge-banner.png" />
                                    </label>
                                    <div class="mt-3 flex flex-wrap items-center gap-3">
                                        <label class="cursor-pointer rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" for="new-studio-banner-upload">Upload image</label>
                                        <InputFile id="new-studio-banner-upload" class="sr-only" OnChange="HandleNewStudioBannerUploadAsync" accept="image/svg+xml,image/jpeg,image/png,image/webp,image/gif" />
                                        @if (PendingNewStudioBannerFile is not null)
                                        {
                                            <span class="text-xs text-slate-400">@PendingNewStudioBannerFile.FileName</span>
                                        }
                                    </div>
                                </section>
                            </div>
                            <div class="mt-6">
                                <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60"
                                        type="button"
                                        @onclick="CreateStudioAsync"
                                        disabled="@IsCreateStudioDisabled">
                                    @(IsStudioMutationInFlight ? "Creating..." : "Create Studio")
                                </button>
                            </div>
                        }
                        else
                        {
                            <h2 class="text-2xl font-semibold text-white">Studio Settings</h2>
                            @if (ActiveStudio is null)
                            {
                                <p class="mt-3 text-sm text-slate-300">Select a studio context first, or create a new studio.</p>
                            }
                            else
                            {
                                <p class="mt-3 text-sm leading-7 text-slate-300">
                                    Active studio:
                                    <strong class="text-white">@ActiveStudio.DisplayName</strong>
                                </p>

                                @if (!string.IsNullOrWhiteSpace(StudioStatusMessage))
                                {
                                    <div class="@GetStudioStatusClass() mt-5 rounded-[1rem] border px-4 py-3 text-sm">
                                        @StudioStatusMessage
                                    </div>
                                }

                                <div class="mt-6 grid gap-4 lg:grid-cols-2">
                                    <label class="block">
                                        <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Display Name</span>
                                        <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                               value="@StudioSettingsDisplayName"
                                               @oninput="OnStudioSettingsDisplayNameInput" />
                                    </label>
                                    <label class="block">
                                        <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Slug</span>
                                        <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/55 px-4 py-3 text-slate-300"
                                               value="@StudioSettingsSlug"
                                               readonly />
                                    </label>
                                </div>
                                <label class="mt-4 block">
                                    <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Description</span>
                                    <textarea class="mt-2 min-h-28 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                              value="@StudioSettingsDescription"
                                              @oninput="OnStudioSettingsDescriptionInput"></textarea>
                                </label>
                                <div class="mt-6 grid gap-5 xl:grid-cols-2">
                                    <section class="rounded-[1.1rem] border border-white/10 bg-black/10 p-4">
                                        <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Studio Logo</div>
                                        @if (GetPreferredStudioMediaPreview(PendingStudioSettingsLogoPreviewUrl, StudioSettingsLogoUrl) is { } studioSettingsLogoPreview)
                                        {
                                            <img class="mt-3 h-24 w-24 rounded-[1rem] border border-white/10 object-cover" src="@studioSettingsLogoPreview" alt="Studio logo preview" />
                                        }
                                        <label class="mt-4 block">
                                            <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Logo URL</span>
                                            <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                                   value="@StudioSettingsLogoUrl"
                                                   @oninput="OnStudioSettingsLogoUrlInput"
                                                   placeholder="https://cdn.example.com/studios/stellar-forge.png" />
                                        </label>
                                        <div class="mt-3 flex flex-wrap items-center gap-3">
                                            <label class="cursor-pointer rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" for="studio-settings-logo-upload">Upload image</label>
                                            <InputFile id="studio-settings-logo-upload" class="sr-only" OnChange="HandleStudioSettingsLogoUploadAsync" accept="image/svg+xml,image/jpeg,image/png,image/webp,image/gif" />
                                            @if (PendingStudioSettingsLogoFile is not null)
                                            {
                                                <span class="text-xs text-slate-400">@PendingStudioSettingsLogoFile.FileName</span>
                                            }
                                        </div>
                                    </section>
                                    <section class="rounded-[1.1rem] border border-white/10 bg-black/10 p-4">
                                        <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Studio Banner</div>
                                        @if (GetPreferredStudioMediaPreview(PendingStudioSettingsBannerPreviewUrl, StudioSettingsBannerUrl) is { } studioSettingsBannerPreview)
                                        {
                                            <img class="mt-3 h-28 w-full rounded-[1rem] border border-white/10 object-cover" src="@studioSettingsBannerPreview" alt="Studio banner preview" />
                                        }
                                        <label class="mt-4 block">
                                            <span class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Banner URL</span>
                                            <input class="mt-2 w-full rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                                   value="@StudioSettingsBannerUrl"
                                                   @oninput="OnStudioSettingsBannerUrlInput"
                                                   placeholder="https://cdn.example.com/studios/stellar-forge-banner.png" />
                                        </label>
                                        <div class="mt-3 flex flex-wrap items-center gap-3">
                                            <label class="cursor-pointer rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" for="studio-settings-banner-upload">Upload image</label>
                                            <InputFile id="studio-settings-banner-upload" class="sr-only" OnChange="HandleStudioSettingsBannerUploadAsync" accept="image/svg+xml,image/jpeg,image/png,image/webp,image/gif" />
                                            @if (PendingStudioSettingsBannerFile is not null)
                                            {
                                                <span class="text-xs text-slate-400">@PendingStudioSettingsBannerFile.FileName</span>
                                            }
                                        </div>
                                    </section>
                                </div>

                                <section class="mt-6 rounded-[1.1rem] border border-white/10 bg-black/10 p-4">
                                    <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Studio Links</div>
                                    <div class="mt-4 space-y-3">
                                        @if (StudioSettingsLinks.Count == 0)
                                        {
                                            <p class="text-sm text-slate-400">No studio links configured yet.</p>
                                        }
                                        else
                                        {
                                            @foreach (var link in StudioSettingsLinks)
                                            {
                                                <div class="grid gap-3 rounded-[1rem] border border-white/10 bg-slate-950/45 p-4 xl:grid-cols-[0.8fr_1.4fr_auto_auto]">
                                                    <input class="rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-100"
                                                           @bind="link.Label"
                                                           placeholder="Discord" />
                                                    <input class="rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-100"
                                                           @bind="link.Url"
                                                           placeholder="https://discord.gg/example" />
                                                    <button class="rounded-full border border-white/15 px-4 py-3 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60"
                                                            type="button"
                                                            @onclick="() => SaveStudioLinkAsync(link)"
                                                            disabled="@(BusyStudioLinkId == link.Id || IsStudioMutationInFlight)">
                                                        Save
                                                    </button>
                                                    <button class="rounded-full border border-rose-300/20 px-4 py-3 text-xs font-semibold uppercase tracking-[0.16em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60"
                                                            type="button"
                                                            @onclick="() => DeleteStudioLinkAsync(link)"
                                                            disabled="@(BusyStudioLinkId == link.Id || IsStudioMutationInFlight)">
                                                        Remove
                                                    </button>
                                                </div>
                                            }
                                        }
                                    </div>

                                    <div class="mt-4 grid gap-3 rounded-[1rem] border border-dashed border-white/10 bg-black/10 p-4 xl:grid-cols-[0.8fr_1.4fr_auto]">
                                        <input class="rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-100"
                                               value="@NewStudioLinkLabel"
                                               @oninput="args => NewStudioLinkLabel = args.Value?.ToString() ?? string.Empty"
                                               placeholder="LinkedIn" />
                                        <input class="rounded-[0.95rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-100"
                                               value="@NewStudioLinkUrl"
                                               @oninput="args => NewStudioLinkUrl = args.Value?.ToString() ?? string.Empty"
                                               placeholder="https://www.linkedin.com/company/example" />
                                        <button class="rounded-full bg-cyan-300 px-4 py-3 text-xs font-bold uppercase tracking-[0.16em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60"
                                                type="button"
                                                @onclick="AddStudioLinkAsync"
                                                disabled="@(IsAddingStudioLink || IsStudioMutationInFlight)">
                                            Add link
                                        </button>
                                    </div>
                                </section>

                                <div class="mt-6 flex flex-wrap gap-3">
                                    <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60"
                                            type="button"
                                            @onclick="SaveStudioSettingsAsync"
                                            disabled="@IsSaveStudioDisabled">
                                        @(IsStudioMutationInFlight ? "Saving..." : "Save Settings")
                                    </button>
                                </div>
                            }
                        }
                    }
                    else if (ActiveDomain == DevelopDomain.Titles)
                    {
                        @if (ActiveStudio is null)
                        {
                            <h2 class="text-2xl font-semibold text-white">Titles</h2>
                            <p class="mt-3 text-sm text-slate-300">Select or create a studio first.</p>
                        }
                        else if (ActiveWorkflow == "titles-overview")
                        {
                            <h2 class="text-2xl font-semibold text-white">Titles</h2>
                            <p class="mt-3 text-sm leading-7 text-slate-300">
                                Active studio: <strong class="text-white">@ActiveStudio.DisplayName</strong>
                            </p>

                            @if (ActiveStudioTitles.Count == 0)
                            {
                                <p class="mt-6 text-sm text-slate-300">No titles found for this studio.</p>
                            }
                            else
                            {
                                <div class="mt-6 space-y-3">
                                    @foreach (var title in ActiveStudioTitles)
                                    {
                                        <section class="rounded-[1.1rem] border border-white/10 bg-black/15 p-4">
                                            <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">@title.ContentKind</div>
                                            <div class="mt-2 text-lg font-semibold text-white">@title.DisplayName</div>
                                            <p class="mt-2 text-sm text-slate-300">@title.ShortDescription</p>
                                            <div class="mt-4 flex flex-wrap gap-3 text-sm">
                                                <a class="text-cyan-200 transition hover:text-cyan-100" href="/develop/titles/@title.Id" data-enhance-nav="false">Overview</a>
                                                <a class="text-cyan-200 transition hover:text-cyan-100" href="/develop/titles/@title.Id/metadata" data-enhance-nav="false">Metadata</a>
                                                <a class="text-cyan-200 transition hover:text-cyan-100" href="/develop/titles/@title.Id/releases" data-enhance-nav="false">Releases</a>
                                                <a class="text-cyan-200 transition hover:text-cyan-100" href="/develop/titles/@title.Id/acquisition" data-enhance-nav="false">Acquisition</a>
                                            </div>
                                        </section>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <h2 class="text-2xl font-semibold text-white">Create Title</h2>
                            <p class="mt-3 text-sm leading-7 text-slate-300">
                                Create a new title under <strong class="text-white">@ActiveStudio.DisplayName</strong>.
                            </p>
                            <a class="mt-6 inline-flex rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-950"
                               href="/develop/studios/@ActiveStudio.Id/titles/new"
                               data-enhance-nav="false">
                                Open title creation form
                            </a>
                        }
                    }
                    else if (ActiveDomain == DevelopDomain.Releases)
                    {
                        @if (ActiveTitle is null)
                        {
                            <h2 class="text-2xl font-semibold text-white">Releases</h2>
                            <p class="mt-3 text-sm text-slate-300">Choose a title to inspect releases.</p>
                        }
                        else
                        {
                            <h2 class="text-2xl font-semibold text-white">Releases</h2>
                            <p class="mt-3 text-sm leading-7 text-slate-300">
                                Title: <strong class="text-white">@ActiveTitle.DisplayName</strong>
                            </p>

                            @if (ActiveTitleReleases.Count == 0)
                            {
                                <p class="mt-6 text-sm text-slate-300">No releases for this title yet.</p>
                            }
                            else
                            {
                                <div class="mt-6 space-y-3">
                                    @foreach (var release in ActiveTitleReleases)
                                    {
                                        <section class="rounded-[1.1rem] border border-white/10 bg-black/15 p-4">
                                            <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">@release.Status</div>
                                            <div class="mt-2 text-lg font-semibold text-white">Version @release.Version</div>
                                            <div class="mt-2 text-sm text-slate-300">Metadata revision @release.MetadataRevisionNumber</div>
                                        </section>
                                    }
                                </div>
                            }

                            <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-slate-100"
                               href="/develop/titles/@ActiveTitle.Id/releases"
                               data-enhance-nav="false">
                                Open release manager
                            </a>
                        }
                    }
                    else if (ActiveDomain == DevelopDomain.Publishing)
                    {
                        @if (ActiveWorkflow == "publishing-connections")
                        {
                            <h2 class="text-2xl font-semibold text-white">Publishing Connections</h2>

                            @if (ActiveStudio is null)
                            {
                                <p class="mt-3 text-sm text-slate-300">Choose a studio to view publisher connections.</p>
                            }
                            else
                            {
                                <p class="mt-3 text-sm leading-7 text-slate-300">
                                    Studio: <strong class="text-white">@ActiveStudio.DisplayName</strong>
                                </p>

                                @if (ActiveStudioConnections.Count == 0)
                                {
                                    <p class="mt-6 text-sm text-slate-300">No integration connections configured yet.</p>
                                }
                                else
                                {
                                    <div class="mt-6 space-y-3">
                                        @foreach (var connection in ActiveStudioConnections)
                                        {
                                            var connectionName = connection.SupportedPublisher?.DisplayName
                                                ?? connection.CustomPublisherDisplayName
                                                ?? connection.Id.ToString("D");
                                            <section class="rounded-[1.1rem] border border-white/10 bg-black/15 p-4">
                                                <div class="text-lg font-semibold text-white">@connectionName</div>
                                                <div class="mt-2 text-sm text-slate-300">Enabled: @(connection.IsEnabled ? "Yes" : "No")</div>
                                            </section>
                                        }
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <h2 class="text-2xl font-semibold text-white">Acquisition Bindings</h2>

                            @if (ActiveTitle is null)
                            {
                                <p class="mt-3 text-sm text-slate-300">Choose a title to view acquisition bindings.</p>
                            }
                            else
                            {
                                <p class="mt-3 text-sm leading-7 text-slate-300">
                                    Title: <strong class="text-white">@ActiveTitle.DisplayName</strong>
                                </p>

                                @if (ActiveTitleBindings.Count == 0)
                                {
                                    <p class="mt-6 text-sm text-slate-300">No acquisition bindings configured yet.</p>
                                }
                                else
                                {
                                    <div class="mt-6 space-y-3">
                                        @foreach (var binding in ActiveTitleBindings)
                                        {
                                            var connectionName = binding.IntegrationConnection.SupportedPublisher?.DisplayName
                                                ?? binding.IntegrationConnection.CustomPublisherDisplayName
                                                ?? binding.IntegrationConnectionId.ToString("D");
                                            <section class="rounded-[1.1rem] border border-white/10 bg-black/15 p-4">
                                                <div class="text-lg font-semibold text-white">@connectionName</div>
                                                <a class="mt-2 block text-sm text-cyan-200 transition hover:text-cyan-100"
                                                   href="@binding.AcquisitionUrl"
                                                   target="_blank"
                                                   rel="noreferrer"
                                                   data-enhance-nav="false">
                                                    @binding.AcquisitionUrl
                                                </a>
                                                <div class="mt-2 text-sm text-slate-300">Primary: @(binding.IsPrimary ? "Yes" : "No")</div>
                                            </section>
                                        }
                                    </div>
                                }

                                <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-slate-100"
                                   href="/develop/titles/@ActiveTitle.Id/acquisition"
                                   data-enhance-nav="false">
                                    Open acquisition manager
                                </a>
                            }
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-300">Select an option.</p>
                    }
                </section>
            </section>
        </section>
    }
</section>

@code {
    private static readonly DevelopDomain[] DevelopDomains =
    [
        DevelopDomain.Studios,
        DevelopDomain.Titles,
        DevelopDomain.Releases,
        DevelopDomain.Publishing
    ];

    private CurrentUserResponse? CurrentUser { get; set; }

    private DeveloperEnrollment? EnrollmentState { get; set; }

    private List<DeveloperStudioSummary> Studios { get; } = [];

    private readonly Dictionary<Guid, IReadOnlyList<CatalogTitleSummary>> studioTitles = [];

    private readonly Dictionary<Guid, IReadOnlyList<TitleRelease>> titleReleases = [];

    private readonly Dictionary<Guid, IReadOnlyList<IntegrationConnection>> studioConnections = [];

    private readonly Dictionary<Guid, IReadOnlyList<TitleIntegrationBinding>> titleBindings = [];

    private Guid? ActiveStudioId { get; set; }

    private Guid? ActiveTitleId { get; set; }

    private DevelopDomain ActiveDomain { get; set; } = DevelopDomain.Studios;

    private string ActiveWorkflow { get; set; } = "studios-overview";

    private bool IsBusy { get; set; }

    private bool IsSubmitting { get; set; }

    private string? ErrorMessage { get; set; }

    private string? StudioStatusMessage { get; set; }

    private bool StudioStatusIsError { get; set; }

    private bool IsStudioMutationInFlight { get; set; }

    private string NewStudioDisplayName { get; set; } = string.Empty;

    private string NewStudioSlug { get; set; } = "studio";

    private string NewStudioDescription { get; set; } = string.Empty;

    private string NewStudioLogoUrl { get; set; } = string.Empty;
    private string NewStudioBannerUrl { get; set; } = string.Empty;
    private ApiUploadFile? PendingNewStudioLogoFile { get; set; }
    private string? PendingNewStudioLogoPreviewUrl { get; set; }
    private ApiUploadFile? PendingNewStudioBannerFile { get; set; }
    private string? PendingNewStudioBannerPreviewUrl { get; set; }

    private Guid? StudioSettingsStudioId { get; set; }

    private string StudioSettingsDisplayName { get; set; } = string.Empty;

    private string StudioSettingsSlug { get; set; } = string.Empty;

    private string StudioSettingsDescription { get; set; } = string.Empty;

    private string StudioSettingsLogoUrl { get; set; } = string.Empty;
    private string StudioSettingsBannerUrl { get; set; } = string.Empty;
    private ApiUploadFile? PendingStudioSettingsLogoFile { get; set; }
    private string? PendingStudioSettingsLogoPreviewUrl { get; set; }
    private ApiUploadFile? PendingStudioSettingsBannerFile { get; set; }
    private string? PendingStudioSettingsBannerPreviewUrl { get; set; }
    private List<StudioLinkDraft> StudioSettingsLinks { get; } = [];
    private string NewStudioLinkLabel { get; set; } = string.Empty;
    private string NewStudioLinkUrl { get; set; } = string.Empty;
    private Guid? BusyStudioLinkId { get; set; }
    private bool IsAddingStudioLink { get; set; }

    private bool HasDeveloperAccess => EnrollmentState.HasDeveloperAccess();

    private bool CanSubmitEnrollment => EnrollmentState?.CanSubmitRequest == true;

    private bool IsCreateStudioDisabled =>
        IsStudioMutationInFlight
        || string.IsNullOrWhiteSpace(NewStudioDisplayName)
        || string.IsNullOrWhiteSpace(NewStudioSlug);

    private bool IsSaveStudioDisabled =>
        IsStudioMutationInFlight
        || ActiveStudio is null
        || string.IsNullOrWhiteSpace(StudioSettingsDisplayName)
        || string.IsNullOrWhiteSpace(StudioSettingsSlug);

    private DeveloperStudioSummary? ActiveStudio =>
        ActiveStudioId is null
            ? Studios.FirstOrDefault()
            : Studios.FirstOrDefault(candidate => candidate.Id == ActiveStudioId);

    private IReadOnlyList<CatalogTitleSummary> ActiveStudioTitles =>
        ActiveStudioId is null
            ? []
            : studioTitles.TryGetValue(ActiveStudioId.Value, out var titles)
                ? titles
                : [];

    private CatalogTitleSummary? ActiveTitle =>
        ActiveTitleId is null
            ? ActiveStudioTitles.FirstOrDefault()
            : ActiveStudioTitles.FirstOrDefault(candidate => candidate.Id == ActiveTitleId);

    private IReadOnlyList<TitleRelease> ActiveTitleReleases =>
        ActiveTitleId is null
            ? []
            : titleReleases.TryGetValue(ActiveTitleId.Value, out var releases)
                ? releases
                : [];

    private IReadOnlyList<IntegrationConnection> ActiveStudioConnections =>
        ActiveStudioId is null
            ? []
            : studioConnections.TryGetValue(ActiveStudioId.Value, out var connections)
                ? connections
                : [];

    private IReadOnlyList<TitleIntegrationBinding> ActiveTitleBindings =>
        ActiveTitleId is null
            ? []
            : titleBindings.TryGetValue(ActiveTitleId.Value, out var bindings)
                ? bindings
                : [];

    protected override async Task OnInitializedAsync()
    {
        await LoadBaselineAsync();
    }

    private async Task LoadBaselineAsync()
    {
        ErrorMessage = null;

        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            EnrollmentState = (await ApiClient.GetDeveloperEnrollmentAsync()).DeveloperEnrollment;

            if (HasDeveloperAccess)
            {
                await EnsureDomainDataAsync(ActiveDomain, forceRefresh: true);
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }

    private async Task SubmitEnrollmentAsync()
    {
        if (CurrentUser is null || IsSubmitting || !CanSubmitEnrollment)
        {
            return;
        }

        ErrorMessage = null;
        IsSubmitting = true;

        try
        {
            EnrollmentState = (await ApiClient.SubmitDeveloperEnrollmentAsync()).DeveloperEnrollment;
            if (HasDeveloperAccess)
            {
                await EnsureDomainDataAsync(DevelopDomain.Studios, forceRefresh: true);
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task SelectDomainAsync(DevelopDomain domain)
    {
        ActiveDomain = domain;
        ActiveWorkflow = GetWorkflows(domain).First().Key;
        StudioStatusMessage = null;
        await EnsureDomainDataAsync(domain);
    }

    private void SelectWorkflow(string workflowKey)
    {
        ActiveWorkflow = workflowKey;
        StudioStatusMessage = null;

        if (workflowKey == "studios-settings")
        {
            EnsureStudioSettingsDraftInitialized();
        }
    }

    private async Task OpenCreateStudioWorkflowAsync()
    {
        ActiveDomain = DevelopDomain.Studios;
        ActiveWorkflow = "studios-create";
        StudioStatusMessage = null;
        await EnsureDomainDataAsync(DevelopDomain.Studios);
    }

    private async Task OpenCreateTitleWorkflowAsync()
    {
        if (ActiveStudio is null)
        {
            return;
        }

        ActiveDomain = DevelopDomain.Titles;
        ActiveWorkflow = "titles-create";
        StudioStatusMessage = null;
        await EnsureDomainDataAsync(DevelopDomain.Titles);
    }

    private async Task EnsureDomainDataAsync(DevelopDomain domain, bool forceRefresh = false)
    {
        if (!HasDeveloperAccess)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = null;

        try
        {
            await EnsureStudiosAsync(forceRefresh);

            if (domain is DevelopDomain.Titles or DevelopDomain.Releases or DevelopDomain.Publishing)
            {
                await EnsureTitlesAsync(forceRefresh);
            }

            if (domain is DevelopDomain.Releases)
            {
                await EnsureReleasesAsync(forceRefresh);
            }

            if (domain is DevelopDomain.Publishing)
            {
                await EnsureConnectionsAsync(forceRefresh);
                await EnsureBindingsAsync(forceRefresh);
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task EnsureStudiosAsync(bool forceRefresh)
    {
        if (!forceRefresh && Studios.Count > 0)
        {
            return;
        }

        var response = await ApiClient.GetManagedStudiosAsync();
        Studios.Clear();
        Studios.AddRange(response.Studios.OrderBy(candidate => candidate.DisplayName, StringComparer.OrdinalIgnoreCase));

        ActiveStudioId = ActiveStudioId is not null && Studios.Any(candidate => candidate.Id == ActiveStudioId)
            ? ActiveStudioId
            : Studios.FirstOrDefault()?.Id;

        StudioSettingsStudioId = null;

        if (ActiveStudioId is null)
        {
            ActiveTitleId = null;
        }
    }

    private async Task EnsureTitlesAsync(bool forceRefresh)
    {
        if (ActiveStudioId is null)
        {
            return;
        }

        if (!forceRefresh && studioTitles.ContainsKey(ActiveStudioId.Value))
        {
            return;
        }

        var response = await ApiClient.GetStudioTitlesAsync(ActiveStudioId.Value);
        studioTitles[ActiveStudioId.Value] = response.Titles;

        ActiveTitleId = ActiveTitleId is not null && response.Titles.Any(candidate => candidate.Id == ActiveTitleId)
            ? ActiveTitleId
            : response.Titles.FirstOrDefault()?.Id;
    }

    private async Task EnsureReleasesAsync(bool forceRefresh)
    {
        if (ActiveTitleId is null)
        {
            return;
        }

        if (!forceRefresh && titleReleases.ContainsKey(ActiveTitleId.Value))
        {
            return;
        }

        var response = await ApiClient.GetTitleReleasesAsync(ActiveTitleId.Value);
        titleReleases[ActiveTitleId.Value] = response.Releases;
    }

    private async Task EnsureConnectionsAsync(bool forceRefresh)
    {
        if (ActiveStudioId is null)
        {
            return;
        }

        if (!forceRefresh && studioConnections.ContainsKey(ActiveStudioId.Value))
        {
            return;
        }

        var response = await ApiClient.GetStudioIntegrationConnectionsAsync(ActiveStudioId.Value);
        studioConnections[ActiveStudioId.Value] = response.IntegrationConnections;
    }

    private async Task EnsureBindingsAsync(bool forceRefresh)
    {
        if (ActiveTitleId is null)
        {
            return;
        }

        if (!forceRefresh && titleBindings.ContainsKey(ActiveTitleId.Value))
        {
            return;
        }

        var response = await ApiClient.GetTitleIntegrationBindingsAsync(ActiveTitleId.Value);
        titleBindings[ActiveTitleId.Value] = response.IntegrationBindings;
    }

    private async Task OnActiveStudioChanged(ChangeEventArgs args)
    {
        if (!Guid.TryParse(args.Value?.ToString(), out var studioId))
        {
            return;
        }

        ActiveStudioId = studioId;
        ActiveTitleId = null;
        StudioSettingsStudioId = null;
        await EnsureDomainDataAsync(ActiveDomain);

        if (ActiveWorkflow == "studios-settings")
        {
            EnsureStudioSettingsDraftInitialized();
        }
    }

    private async Task OnActiveTitleChanged(ChangeEventArgs args)
    {
        if (!Guid.TryParse(args.Value?.ToString(), out var titleId))
        {
            return;
        }

        ActiveTitleId = titleId;
        await EnsureDomainDataAsync(ActiveDomain);
    }

    private void SelectStudioForSettings(Guid studioId)
    {
        ActiveStudioId = studioId;
        ActiveWorkflow = "studios-settings";
        StudioSettingsStudioId = null;
        StudioStatusMessage = null;
        EnsureStudioSettingsDraftInitialized();
    }

    private void OnNewStudioDisplayNameInput(ChangeEventArgs args)
    {
        NewStudioDisplayName = args.Value?.ToString() ?? string.Empty;
        NewStudioSlug = SlugGenerator.ToKebabCase(NewStudioDisplayName, "studio");
    }

    private void OnNewStudioDescriptionInput(ChangeEventArgs args) => NewStudioDescription = args.Value?.ToString() ?? string.Empty;

    private void OnNewStudioLogoUrlInput(ChangeEventArgs args) => NewStudioLogoUrl = args.Value?.ToString() ?? string.Empty;

    private void OnNewStudioBannerUrlInput(ChangeEventArgs args) => NewStudioBannerUrl = args.Value?.ToString() ?? string.Empty;

    private async Task CreateStudioAsync()
    {
        if (IsCreateStudioDisabled)
        {
            return;
        }

        IsStudioMutationInFlight = true;
        StudioStatusMessage = null;

        try
        {
            var response = await ApiClient.CreateStudioAsync(
                new CreateStudioRequest(
                    SlugGenerator.ToKebabCase(NewStudioSlug, "studio"),
                    NewStudioDisplayName.Trim(),
                    NormalizeOptionalText(NewStudioDescription),
                    NormalizeOptionalText(NewStudioLogoUrl),
                    NormalizeOptionalText(NewStudioBannerUrl)));

            if (PendingNewStudioLogoFile is not null)
            {
                response = await ApiClient.UploadStudioLogoAsync(response.Studio.Id, PendingNewStudioLogoFile);
            }

            if (PendingNewStudioBannerFile is not null)
            {
                response = await ApiClient.UploadStudioBannerAsync(response.Studio.Id, PendingNewStudioBannerFile);
            }

            var createdStudio = new DeveloperStudioSummary(
                response.Studio.Id,
                response.Studio.Slug,
                response.Studio.DisplayName,
                response.Studio.Description,
                response.Studio.LogoUrl,
                response.Studio.BannerUrl,
                response.Studio.Links,
                "owner");

            UpsertManagedStudio(createdStudio);
            ActiveStudioId = createdStudio.Id;
            ActiveTitleId = null;
            studioTitles.Remove(createdStudio.Id);
            studioConnections.Remove(createdStudio.Id);
            StudioSettingsStudioId = null;
            ActiveWorkflow = "studios-settings";
            SetStudioStatus("Studio created. Continue in Studio Settings.", isError: false);
            ResetNewStudioDraft();
            EnsureStudioSettingsDraftInitialized();
        }
        catch (Exception exception)
        {
            SetStudioStatus($"Create studio failed: {exception.Message}", isError: true);
        }
        finally
        {
            IsStudioMutationInFlight = false;
        }
    }

    private void EnsureStudioSettingsDraftInitialized()
    {
        if (ActiveStudio is null || StudioSettingsStudioId == ActiveStudio.Id)
        {
            return;
        }

        StudioSettingsStudioId = ActiveStudio.Id;
        StudioSettingsDisplayName = ActiveStudio.DisplayName;
        StudioSettingsSlug = ActiveStudio.Slug;
        StudioSettingsDescription = ActiveStudio.Description ?? string.Empty;
        StudioSettingsLogoUrl = ActiveStudio.LogoUrl ?? string.Empty;
        StudioSettingsBannerUrl = ActiveStudio.BannerUrl ?? string.Empty;
        PendingStudioSettingsLogoFile = null;
        PendingStudioSettingsLogoPreviewUrl = null;
        PendingStudioSettingsBannerFile = null;
        PendingStudioSettingsBannerPreviewUrl = null;
        StudioSettingsLinks.Clear();
        StudioSettingsLinks.AddRange(
            ActiveStudio.Links
                .OrderBy(candidate => candidate.Label, StringComparer.OrdinalIgnoreCase)
                .Select(candidate => new StudioLinkDraft
                {
                    Id = candidate.Id,
                    Label = candidate.Label,
                    Url = candidate.Url
                }));
        NewStudioLinkLabel = string.Empty;
        NewStudioLinkUrl = string.Empty;
    }

    private void OnStudioSettingsDisplayNameInput(ChangeEventArgs args)
    {
        StudioSettingsDisplayName = args.Value?.ToString() ?? string.Empty;
    }

    private void OnStudioSettingsDescriptionInput(ChangeEventArgs args) => StudioSettingsDescription = args.Value?.ToString() ?? string.Empty;

    private void OnStudioSettingsLogoUrlInput(ChangeEventArgs args) => StudioSettingsLogoUrl = args.Value?.ToString() ?? string.Empty;

    private void OnStudioSettingsBannerUrlInput(ChangeEventArgs args) => StudioSettingsBannerUrl = args.Value?.ToString() ?? string.Empty;

    private async Task SaveStudioSettingsAsync()
    {
        var activeStudio = ActiveStudio;
        if (IsSaveStudioDisabled || activeStudio is null)
        {
            return;
        }

        IsStudioMutationInFlight = true;
        StudioStatusMessage = null;

        try
        {
            var response = await ApiClient.UpdateStudioAsync(
                activeStudio.Id,
                new UpdateStudioRequest(
                    activeStudio.Slug,
                    StudioSettingsDisplayName.Trim(),
                    NormalizeOptionalText(StudioSettingsDescription),
                    NormalizeOptionalText(StudioSettingsLogoUrl),
                    NormalizeOptionalText(StudioSettingsBannerUrl)));

            if (PendingStudioSettingsLogoFile is not null)
            {
                response = await ApiClient.UploadStudioLogoAsync(activeStudio.Id, PendingStudioSettingsLogoFile);
            }

            if (PendingStudioSettingsBannerFile is not null)
            {
                response = await ApiClient.UploadStudioBannerAsync(activeStudio.Id, PendingStudioSettingsBannerFile);
            }

            var updatedStudio = new DeveloperStudioSummary(
                response.Studio.Id,
                response.Studio.Slug,
                response.Studio.DisplayName,
                response.Studio.Description,
                response.Studio.LogoUrl,
                response.Studio.BannerUrl,
                response.Studio.Links,
                activeStudio.Role);

            UpsertManagedStudio(updatedStudio);
            ActiveStudioId = updatedStudio.Id;
            StudioSettingsStudioId = null;
            EnsureStudioSettingsDraftInitialized();
            SetStudioStatus("Studio settings saved.", isError: false);
        }
        catch (Exception exception)
        {
            SetStudioStatus($"Save studio settings failed: {exception.Message}", isError: true);
        }
        finally
        {
            IsStudioMutationInFlight = false;
        }
    }

    private void UpsertManagedStudio(DeveloperStudioSummary studio)
    {
        var existingIndex = Studios.FindIndex(candidate => candidate.Id == studio.Id);
        if (existingIndex >= 0)
        {
            Studios[existingIndex] = studio;
        }
        else
        {
            Studios.Add(studio);
        }

        Studios.Sort((left, right) => string.Compare(left.DisplayName, right.DisplayName, StringComparison.OrdinalIgnoreCase));
    }

    private void ResetNewStudioDraft()
    {
        NewStudioDisplayName = string.Empty;
        NewStudioSlug = "studio";
        NewStudioDescription = string.Empty;
        NewStudioLogoUrl = string.Empty;
        NewStudioBannerUrl = string.Empty;
        PendingNewStudioLogoFile = null;
        PendingNewStudioLogoPreviewUrl = null;
        PendingNewStudioBannerFile = null;
        PendingNewStudioBannerPreviewUrl = null;
    }

    private async Task HandleNewStudioLogoUploadAsync(InputFileChangeEventArgs args)
    {
        var upload = await CreateUploadFileAsync(args);
        PendingNewStudioLogoFile = upload;
        PendingNewStudioLogoPreviewUrl = upload is null ? null : CreateDataUrl(upload);
    }

    private async Task HandleNewStudioBannerUploadAsync(InputFileChangeEventArgs args)
    {
        var upload = await CreateUploadFileAsync(args);
        PendingNewStudioBannerFile = upload;
        PendingNewStudioBannerPreviewUrl = upload is null ? null : CreateDataUrl(upload);
    }

    private async Task HandleStudioSettingsLogoUploadAsync(InputFileChangeEventArgs args)
    {
        var upload = await CreateUploadFileAsync(args);
        PendingStudioSettingsLogoFile = upload;
        PendingStudioSettingsLogoPreviewUrl = upload is null ? null : CreateDataUrl(upload);
    }

    private async Task HandleStudioSettingsBannerUploadAsync(InputFileChangeEventArgs args)
    {
        var upload = await CreateUploadFileAsync(args);
        PendingStudioSettingsBannerFile = upload;
        PendingStudioSettingsBannerPreviewUrl = upload is null ? null : CreateDataUrl(upload);
    }

    private async Task AddStudioLinkAsync()
    {
        if (ActiveStudio is null || IsAddingStudioLink)
        {
            return;
        }

        var validationMessage = ValidateStudioLinkDraft(NewStudioLinkLabel, NewStudioLinkUrl);
        if (validationMessage is not null)
        {
            SetStudioStatus(validationMessage, isError: true);
            return;
        }

        IsAddingStudioLink = true;
        StudioStatusMessage = null;

        try
        {
            var response = await ApiClient.CreateStudioLinkAsync(
                ActiveStudio.Id,
                new UpsertStudioLinkRequest(NewStudioLinkLabel.Trim(), NewStudioLinkUrl.Trim()));

            StudioSettingsLinks.Add(new StudioLinkDraft
            {
                Id = response.Link.Id,
                Label = response.Link.Label,
                Url = response.Link.Url
            });
            SyncActiveStudioLinks();
            NewStudioLinkLabel = string.Empty;
            NewStudioLinkUrl = string.Empty;
            SetStudioStatus("Studio link added.", isError: false);
        }
        catch (Exception exception)
        {
            SetStudioStatus($"Add studio link failed: {exception.Message}", isError: true);
        }
        finally
        {
            IsAddingStudioLink = false;
        }
    }

    private async Task SaveStudioLinkAsync(StudioLinkDraft draft)
    {
        if (ActiveStudio is null || draft.Id is null || BusyStudioLinkId == draft.Id)
        {
            return;
        }

        var validationMessage = ValidateStudioLinkDraft(draft.Label, draft.Url);
        if (validationMessage is not null)
        {
            SetStudioStatus(validationMessage, isError: true);
            return;
        }

        BusyStudioLinkId = draft.Id;
        StudioStatusMessage = null;

        try
        {
            var response = await ApiClient.UpdateStudioLinkAsync(
                ActiveStudio.Id,
                draft.Id.Value,
                new UpsertStudioLinkRequest(draft.Label.Trim(), draft.Url.Trim()));

            draft.Label = response.Link.Label;
            draft.Url = response.Link.Url;
            SyncActiveStudioLinks();
            SetStudioStatus("Studio link saved.", isError: false);
        }
        catch (Exception exception)
        {
            SetStudioStatus($"Save studio link failed: {exception.Message}", isError: true);
        }
        finally
        {
            BusyStudioLinkId = null;
        }
    }

    private async Task DeleteStudioLinkAsync(StudioLinkDraft draft)
    {
        if (ActiveStudio is null || draft.Id is null || BusyStudioLinkId == draft.Id)
        {
            return;
        }

        BusyStudioLinkId = draft.Id;
        StudioStatusMessage = null;

        try
        {
            await ApiClient.DeleteStudioLinkAsync(ActiveStudio.Id, draft.Id.Value);
            StudioSettingsLinks.Remove(draft);
            SyncActiveStudioLinks();
            SetStudioStatus("Studio link removed.", isError: false);
        }
        catch (Exception exception)
        {
            SetStudioStatus($"Delete studio link failed: {exception.Message}", isError: true);
        }
        finally
        {
            BusyStudioLinkId = null;
        }
    }

    private void SyncActiveStudioLinks()
    {
        var activeStudio = ActiveStudio;
        if (activeStudio is null)
        {
            return;
        }

        var updatedStudio = activeStudio with
        {
            Links = StudioSettingsLinks
                .Where(candidate => candidate.Id is not null)
                .Select(candidate => new StudioLink(
                    candidate.Id!.Value,
                    candidate.Label.Trim(),
                    candidate.Url.Trim(),
                    DateTime.UtcNow,
                    DateTime.UtcNow))
                .ToList()
        };

        UpsertManagedStudio(updatedStudio);
    }

    private static string? ValidateStudioLinkDraft(string? label, string? url)
    {
        if (string.IsNullOrWhiteSpace(label))
        {
            return "Studio link label is required.";
        }

        if (string.IsNullOrWhiteSpace(url) || !Uri.TryCreate(url.Trim(), UriKind.Absolute, out _))
        {
            return "Studio link URL must be an absolute URI.";
        }

        return null;
    }

    private static async Task<ApiUploadFile?> CreateUploadFileAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return null;
        }

        await using var stream = file.OpenReadStream(10 * 1024 * 1024);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        return new ApiUploadFile(file.Name, file.ContentType, memoryStream.ToArray());
    }

    private static string CreateDataUrl(ApiUploadFile file) => $"data:{file.ContentType};base64,{Convert.ToBase64String(file.Content)}";

    private static string? GetPreferredStudioMediaPreview(string? uploadedPreviewUrl, string? configuredUrl) =>
        !string.IsNullOrWhiteSpace(uploadedPreviewUrl)
            ? uploadedPreviewUrl
            : NormalizeOptionalText(configuredUrl);

    private void SetStudioStatus(string message, bool isError)
    {
        StudioStatusMessage = message;
        StudioStatusIsError = isError;
    }

    private string GetStudioStatusClass() =>
        StudioStatusIsError
            ? "border-rose-300/40 bg-rose-400/10 text-rose-100"
            : "border-emerald-300/40 bg-emerald-400/10 text-emerald-100";

    private static string? NormalizeOptionalText(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();

    private static string FormatMembershipRole(string role)
    {
        if (string.IsNullOrWhiteSpace(role))
        {
            return "Member";
        }

        var tokens = role.Replace("-", " ", StringComparison.Ordinal).Replace("_", " ", StringComparison.Ordinal).Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (var index = 0; index < tokens.Length; index++)
        {
            var token = tokens[index];
            tokens[index] = token.Length == 1
                ? token.ToUpperInvariant()
                : char.ToUpperInvariant(token[0]) + token[1..].ToLowerInvariant();
        }

        return string.Join(" ", tokens);
    }

    private bool HasActiveDomainData() =>
        ActiveDomain switch
        {
            DevelopDomain.Studios => Studios.Count > 0,
            DevelopDomain.Titles => ActiveStudioTitles.Count > 0,
            DevelopDomain.Releases => ActiveTitleReleases.Count > 0,
            DevelopDomain.Publishing => ActiveStudioConnections.Count > 0 || ActiveTitleBindings.Count > 0,
            _ => false
        };

