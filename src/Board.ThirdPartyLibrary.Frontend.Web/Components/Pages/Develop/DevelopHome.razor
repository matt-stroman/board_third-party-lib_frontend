@page "/develop"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient
@layout DeveloperLayout

<PageTitle>Developer Console</PageTitle>

<section class="space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <div class="app-chip w-fit">Developer home</div>
            <h1 class="mt-4 app-page-title">Developer Console</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                Live workspace data is now loaded from the backend: your profile, the organizations you can manage, and a title preview for the active organization.
            </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
            <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/develop/organizations/new">New organization</a>
            @if (PrimaryOrganization is not null)
            {
                <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@($"/develop/organizations/{PrimaryOrganization.Id}/titles/new")">New title</a>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Developer workspace unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (ManagedOrganizations is null || CurrentUser is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-40 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else
    {
        <section class="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Signed in as</div>
                <h2 class="mt-3 text-2xl font-semibold text-white">@CurrentUser.DisplayName</h2>
                <div class="mt-3 text-sm text-slate-300">@CurrentUser.Email</div>
                <div class="mt-6 flex flex-wrap gap-2">
                    @foreach (var role in CurrentUser.Roles)
                    {
                        <span class="app-chip">@role</span>
                    }
                </div>
            </section>

            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Managed organizations</div>
                <div class="mt-3 text-4xl font-black text-white">@ManagedOrganizations.Organizations.Count</div>
                <p class="mt-3 text-sm leading-7 text-slate-300">
                    Organizations come from the authenticated developer endpoint, so this list reflects the current membership state instead of a placeholder workspace.
                </p>
            </section>
        </section>

        @if (ManagedOrganizations.Organizations.Count == 0)
        {
            <section class="app-panel p-6">
                <h2 class="text-xl font-semibold text-white">No managed organizations yet</h2>
                <p class="mt-3 text-sm leading-7 text-slate-300">
                    Create your first organization to unlock title CRUD, release workflows, and acquisition setup.
                </p>
            </section>
        }
        else
        {
            <section class="space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold uppercase tracking-[0.08em] text-white">Your organizations</h2>
                    <div class="text-sm text-slate-400">Roles and links come from the live management API.</div>
                </div>
                <section class="grid gap-4 lg:grid-cols-3">
                    @foreach (var organization in ManagedOrganizations.Organizations)
                    {
                        <a class="app-panel p-5 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="@($"/develop/organizations/{organization.Id}")">
                            <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">@organization.Role</div>
                            <div class="mt-3 text-xl font-semibold text-white">@organization.DisplayName</div>
                            <div class="mt-2 text-sm text-slate-300">@organization.Description</div>
                        </a>
                    }
                </section>
            </section>

            @if (PrimaryOrganization is not null)
            {
                <section class="space-y-4">
                    <div class="flex items-center justify-between">
                        <h2 class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold uppercase tracking-[0.08em] text-white">Active organization preview</h2>
                        <a class="text-sm text-cyan-200 transition hover:text-cyan-100" href="@($"/develop/organizations/{PrimaryOrganization.Id}/titles")">Open titles</a>
                    </div>
                    <section class="app-panel p-6">
                        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                            <div>
                                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Active organization</div>
                                <h3 class="mt-3 text-3xl font-semibold text-white">@PrimaryOrganization.DisplayName</h3>
                                <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300">@PrimaryOrganization.Description</p>
                            </div>
                            <div class="app-chip">@PrimaryOrganization.Role</div>
                        </div>

                        <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                            @foreach (var title in PrimaryOrganizationTitles)
                            {
                                <a class="rounded-[1.25rem] border border-white/10 bg-black/15 p-4 transition hover:border-cyan-300/35" href="@($"/library/{title.OrganizationSlug}/{title.Slug}")">
                                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">@title.GenreDisplay</div>
                                    <div class="mt-3 text-lg font-semibold text-white">@title.DisplayName</div>
                                    <div class="mt-2 text-sm text-slate-300">@title.ShortDescription</div>
                                </a>
                            }
                        </div>
                    </section>
                </section>
            }
        }
    }
</section>

@code {
    private CurrentUserResponse? CurrentUser { get; set; }

    private DeveloperOrganizationListResponse? ManagedOrganizations { get; set; }

    private IReadOnlyList<CatalogTitleSummary> PrimaryOrganizationTitles { get; set; } = [];

    private DeveloperOrganizationSummary? PrimaryOrganization => ManagedOrganizations?.Organizations.FirstOrDefault();

    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ErrorMessage = null;

        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            ManagedOrganizations = await ApiClient.GetManagedOrganizationsAsync();

            if (CurrentUser is null)
            {
                ErrorMessage = "The authenticated user profile could not be loaded from the backend.";
                return;
            }

            if (PrimaryOrganization is not null)
            {
                var titleResponse = await ApiClient.GetOrganizationTitlesAsync(PrimaryOrganization.Id);
                PrimaryOrganizationTitles = titleResponse.Titles.Take(3).ToArray();
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }
}
