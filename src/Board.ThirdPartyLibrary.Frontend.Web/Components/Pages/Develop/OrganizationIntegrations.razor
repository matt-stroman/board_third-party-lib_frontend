@page "/develop/organizations/{OrganizationId:guid}/integrations"
@layout DeveloperLayout

<PageTitle>Organization Integrations</PageTitle>

<section class="app-panel p-6">
    <div class="app-chip w-fit">Integration connections</div>
    <h1 class="mt-4 app-page-title">Publisher Connections</h1>
    <div class="mt-6 space-y-3 text-sm text-slate-300">
        <div class="rounded-[1.25rem] bg-black/15 p-4">itch.io • enabled • reusable for title bindings</div>
        <div class="rounded-[1.25rem] bg-black/15 p-4">Stellar Forge Direct • enabled • custom publisher fallback</div>
    </div>
</section>

@code {
    [Parameter] public Guid OrganizationId { get; set; }
}
