@page "/develop/organizations/{OrganizationId:guid}/memberships"
@layout DeveloperLayout

<PageTitle>Memberships</PageTitle>

<section class="app-panel p-6">
    <div class="app-chip w-fit">Membership management</div>
    <h1 class="mt-4 app-page-title">Memberships</h1>
    <div class="mt-6 space-y-3 text-sm text-slate-300">
        <div class="rounded-[1.25rem] bg-black/15 p-4">Local Admin <span class="text-cyan-100">Owner</span></div>
        <div class="rounded-[1.25rem] bg-black/15 p-4">Studio Editor <span class="text-cyan-100">Developer</span></div>
    </div>
</section>

@code {
    [Parameter] public Guid OrganizationId { get; set; }
}
