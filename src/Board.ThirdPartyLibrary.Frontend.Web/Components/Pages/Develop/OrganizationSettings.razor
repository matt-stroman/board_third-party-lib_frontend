@page "/develop/studios/{OrganizationId:guid}/settings"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Organization Settings</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-52 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(LoadErrorMessage))
    {
        <section class="app-panel max-w-4xl p-6">
            <h1 class="app-page-title">Organization settings unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@LoadErrorMessage</p>
            <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop/studios/@OrganizationId">Back to organization</a>
        </section>
    }
    else if (Organization is null)
    {
        <section class="app-panel max-w-4xl p-6">
            <h1 class="app-page-title">Organization not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">
                This account cannot access the requested organization.
            </p>
            <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop">Back to develop</a>
        </section>
    }
    else
    {
        <section class="app-panel max-w-4xl p-6">
            <h1 class="mt-4 app-page-title">@Organization.DisplayName</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">
                Update your studio details.
            </p>

            @if (!string.IsNullOrWhiteSpace(FormErrorMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-rose-300/25 bg-rose-300/10 px-4 py-3 text-sm text-rose-100">@FormErrorMessage</div>
            }
            else if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
            }

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
                <label class="text-sm text-slate-300">Display name
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="DisplayName" placeholder="Stellar Forge" />
                </label>
                <label class="text-sm text-slate-300">Slug (auto-generated)
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/55 px-4 py-3 text-slate-300" value="@GeneratedSlug" readonly />
                </label>
                <label class="text-sm text-slate-300 sm:col-span-2">Description
                    <textarea class="mt-2 min-h-28 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="Description" placeholder="Family co-op studio."></textarea>
                </label>
                <label class="text-sm text-slate-300 sm:col-span-2">Logo URL (optional)
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="LogoUrl" placeholder="https://cdn.example.com/studios/stellar-forge.png" />
                </label>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
                <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="SaveAsync" disabled="@IsSubmitting">
                    @(IsSubmitting ? "Saving..." : "Save changes")
                </button>
                <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop/studios/@OrganizationId">Back to organization</a>
            </div>
        </section>
    }
</section>

@code {
    [Parameter] public Guid OrganizationId { get; set; }

    private DeveloperOrganizationSummary? Organization { get; set; }

    private string? DisplayName { get; set; }

    private string? Description { get; set; }

    private string? LogoUrl { get; set; }

    private string? LoadErrorMessage { get; set; }

    private string? FormErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    private bool IsLoading { get; set; } = true;

    private bool IsSubmitting { get; set; }

    private string GeneratedSlug => SlugGenerator.ToKebabCase(DisplayName, "organization");

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task SaveAsync()
    {
        if (Organization is null || IsSubmitting)
        {
            return;
        }

        FormErrorMessage = Validate();
        StatusMessage = null;
        if (!string.IsNullOrWhiteSpace(FormErrorMessage))
        {
            return;
        }

        IsSubmitting = true;
        try
        {
            var response = await ApiClient.UpdateOrganizationAsync(
                OrganizationId,
                new UpdateOrganizationRequest(
                    GeneratedSlug,
                    DisplayName!.Trim(),
                    NormalizeOptionalField(Description),
                    NormalizeOptionalField(LogoUrl)));

            var updated = response.Organization;
            Organization = Organization with
            {
                DisplayName = updated.DisplayName,
                Description = updated.Description,
                LogoUrl = updated.LogoUrl
            };

            DisplayName = updated.DisplayName;
            Description = updated.Description;
            LogoUrl = updated.LogoUrl;
            StatusMessage = "Organization updated.";
        }
        catch (Exception exception)
        {
            FormErrorMessage = exception.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        LoadErrorMessage = null;
        FormErrorMessage = null;
        StatusMessage = null;
        Organization = null;

        try
        {
            var organizations = await ApiClient.GetManagedOrganizationsAsync();
            Organization = organizations.Organizations.FirstOrDefault(candidate => candidate.Id == OrganizationId);

            if (Organization is null)
            {
                return;
            }

            DisplayName = Organization.DisplayName;
            Description = Organization.Description;
            LogoUrl = Organization.LogoUrl;
        }
        catch (Exception exception)
        {
            LoadErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(DisplayName))
        {
            return "Display name is required.";
        }

        if (!string.IsNullOrWhiteSpace(LogoUrl) && !Uri.TryCreate(LogoUrl.Trim(), UriKind.Absolute, out _))
        {
            return "Logo URL must be an absolute URI.";
        }

        return null;
    }

    private static string? NormalizeOptionalField(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();
}

