@page "/develop/organizations/{OrganizationId:guid}"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>@PageTitle</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-40 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Organization workspace unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
            <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop">Back to develop</a>
        </section>
    }
    else if (Organization is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Organization not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">
                This account cannot access the requested organization workspace.
            </p>
            <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop">Back to develop</a>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                    <h1 class="mt-4 app-page-title">@Organization.DisplayName</h1>
                    <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                        @(string.IsNullOrWhiteSpace(Organization.Description)
                            ? "No organization description has been provided yet."
                            : Organization.Description)
                    </p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/develop/organizations/@OrganizationId/settings">Edit organization</a>
                    <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop/organizations/@OrganizationId/titles/new">New title</a>
                </div>
            </div>

            <div class="mt-6 grid gap-4 sm:grid-cols-3">
                <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Slug</div>
                    <div class="mt-3 text-white">@Organization.Slug</div>
                </div>
                <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Role</div>
                    <div class="mt-3 text-white">@Organization.Role</div>
                </div>
                <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Titles</div>
                    <div class="mt-3 text-white">@OrganizationTitles.Count</div>
                </div>
            </div>

            <div class="mt-6 grid gap-4 sm:grid-cols-3">
                <a class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300 transition hover:border hover:border-cyan-300/35" href="/develop/organizations/@OrganizationId/settings">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Settings</div>
                    <div class="mt-3 text-white">Update slug, display name, description, and logo URL</div>
                </a>
                <a class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300 transition hover:border hover:border-cyan-300/35" href="/develop/organizations/@OrganizationId/memberships">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Memberships</div>
                    <div class="mt-3 text-white">Manage owners, admins, and editors</div>
                </a>
                <a class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300 transition hover:border hover:border-cyan-300/35" href="/develop/organizations/@OrganizationId/titles">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Titles</div>
                    <div class="mt-3 text-white">Open the title management workspace</div>
                </a>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold uppercase tracking-[0.08em] text-white">Recent titles</h2>
                <a class="text-sm text-cyan-200 transition hover:text-cyan-100" href="/develop/organizations/@OrganizationId/titles">View all</a>
            </div>

            @if (OrganizationTitles.Count == 0)
            {
                <section class="app-panel p-6">
                    <p class="text-sm leading-7 text-slate-300">
                        No titles exist for this organization yet.
                    </p>
                </section>
            }
            else
            {
                <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                    @foreach (var title in OrganizationTitles.Take(3))
                    {
                        <a class="app-panel p-5 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/games/@title.OrganizationSlug/@title.Slug">
                            <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">@title.GenreDisplay</div>
                            <div class="mt-2 text-xl font-semibold text-white">@title.DisplayName</div>
                            <div class="mt-2 text-sm text-slate-300">@title.ShortDescription</div>
                        </a>
                    }
                </section>
            }
        </section>
    }
</section>

@code {
    [Parameter] public Guid OrganizationId { get; set; }

    private DeveloperOrganizationSummary? Organization { get; set; }

    private IReadOnlyList<CatalogTitleSummary> OrganizationTitles { get; set; } = [];

    private bool IsLoading { get; set; } = true;

    private string? ErrorMessage { get; set; }

    private string PageTitle =>
        Organization is null
            ? "Organization Workspace"
            : $"{Organization.DisplayName} Workspace";

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        Organization = null;
        OrganizationTitles = [];

        try
        {
            var organizations = await ApiClient.GetManagedOrganizationsAsync();
            Organization = organizations.Organizations.FirstOrDefault(candidate => candidate.Id == OrganizationId);

            if (Organization is null)
            {
                return;
            }

            var titleResponse = await ApiClient.GetOrganizationTitlesAsync(OrganizationId);
            OrganizationTitles = titleResponse.Titles;
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
