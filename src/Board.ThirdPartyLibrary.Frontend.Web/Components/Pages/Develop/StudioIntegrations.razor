@page "/develop/studios/{StudioId:guid}/integrations"
@attribute [Authorize]
@inject NavigationManager NavigationManager

<PageTitle>Studio Integrations</PageTitle>

<section class="app-panel p-6">
    <h1 class="app-page-title">Publisher Connections</h1>
    <p class="mt-4 text-sm leading-7 text-slate-300">
        Connection management now lives in the Developer Console.
    </p>
    <a class="mt-6 inline-flex rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/develop" data-enhance-nav="false">
        Open Developer Console
    </a>
</section>

@code {
    [Parameter] public Guid StudioId { get; set; }

    protected override void OnInitialized()
    {
        NavigationManager.NavigateTo("/develop", forceLoad: true);
    }
}

