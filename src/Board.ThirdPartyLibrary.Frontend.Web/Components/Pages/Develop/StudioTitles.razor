@page "/develop/studios/{StudioId:guid}/titles"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Studio Titles</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-44 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Titles unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Studio is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Studio not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">This account cannot access the requested studio.</p>
            <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop">Back to develop</a>
        </section>
    }
    else
    {
        <div class="flex items-center justify-between gap-4">
            <div>
                <h1 class="mt-4 app-page-title">@Studio.DisplayName</h1>
                <p class="mt-4 text-base leading-8 text-slate-300">Manage title metadata, media, releases, and acquisition bindings.</p>
            </div>
            <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/develop/studios/@StudioId/titles/new">Create title</a>
        </div>

        @if (Titles.Count == 0)
        {
            <section class="app-panel p-6">
                <p class="text-sm leading-7 text-slate-300">No titles exist yet for this studio.</p>
            </section>
        }
        else
        {
            <section class="grid gap-4 lg:grid-cols-2">
                @foreach (var title in Titles)
                {
                    <a class="app-panel p-5 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/develop/titles/@title.Id">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">@title.LifecycleStatus • @title.Visibility</div>
                        <div class="mt-2 text-xl font-semibold text-white">@title.DisplayName</div>
                        <div class="mt-2 text-sm text-slate-300">@title.ShortDescription</div>
                        <div class="mt-3 text-xs uppercase tracking-[0.2em] text-slate-400">Revision @title.CurrentMetadataRevision • @title.ContentKind</div>
                    </a>
                }
            </section>
        }
    }
</section>

@code {
    [Parameter] public Guid StudioId { get; set; }

    private DeveloperStudioSummary? Studio { get; set; }

    private IReadOnlyList<CatalogTitleSummary> Titles { get; set; } = [];

    private bool IsLoading { get; set; } = true;

    private string? ErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        Studio = null;
        Titles = [];

        try
        {
            var studios = await ApiClient.GetManagedStudiosAsync();
            Studio = studios.Studios.FirstOrDefault(candidate => candidate.Id == StudioId);
            if (Studio is null)
            {
                return;
            }

            Titles = (await ApiClient.GetStudioTitlesAsync(StudioId)).Titles;
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}

