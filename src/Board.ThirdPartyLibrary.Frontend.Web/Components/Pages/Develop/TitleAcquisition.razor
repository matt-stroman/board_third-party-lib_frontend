@page "/develop/titles/{TitleId:guid}/acquisition"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Title Acquisition</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-52 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Acquisition unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Title is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">This account cannot access the requested title.</p>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <h1 class="mt-4 app-page-title">@Title.DisplayName</h1>
            <p class="mt-4 text-sm leading-7 text-slate-300">
                Manage external acquisition bindings used for player-facing "Get" links.
            </p>

            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
            }

            @if (Connections.Count == 0)
            {
                <div class="mt-6 rounded-[1rem] border border-amber-300/30 bg-amber-300/10 px-4 py-3 text-sm text-amber-100">
                    No integration connections exist for this studio. Create one from studio integrations first.
                </div>

                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                    <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" @bind="NewConnectionDisplayName" placeholder="Publisher display name (e.g. itch.io)" />
                    <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" @bind="NewConnectionHomepageUrl" placeholder="Publisher homepage URL (optional)" />
                </div>
                <div class="mt-3">
                    <button class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="CreateConnectionAsync" disabled="@IsMutatingBindings">
                        @(IsMutatingBindings ? "Saving..." : "Create connection")
                    </button>
                </div>
            }
            else
            {
                <div class="mt-6 grid gap-4 sm:grid-cols-2">
                    <label class="text-sm text-slate-300">Integration connection
                        <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="NewBindingConnectionId">
                            @foreach (var connection in Connections)
                            {
                                <option value="@connection.Id.ToString("D")">@GetConnectionDisplayName(connection)</option>
                            }
                        </select>
                    </label>
                    <label class="text-sm text-slate-300">Acquisition URL
                        <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="NewBindingUrl" placeholder="https://..." />
                    </label>
                    <label class="text-sm text-slate-300 sm:col-span-2">Acquisition label (optional)
                        <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="NewBindingLabel" placeholder="View on itch.io" />
                    </label>
                    <label class="inline-flex items-center gap-2 text-sm text-slate-300">
                        <input type="checkbox" @bind="NewBindingIsPrimary" />
                        Primary binding
                    </label>
                    <label class="inline-flex items-center gap-2 text-sm text-slate-300">
                        <input type="checkbox" @bind="NewBindingIsEnabled" />
                        Enabled
                    </label>
                </div>

                <div class="mt-6">
                    <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="CreateBindingAsync" disabled="@IsMutatingBindings">
                        @(IsMutatingBindings ? "Saving..." : "Create binding")
                    </button>
                </div>
            }
        </section>

        <section class="app-panel p-6">
            <h2 class="text-2xl font-semibold text-white">Current bindings</h2>
            @if (Bindings.Count == 0)
            {
                <p class="mt-3 text-sm text-slate-300">No acquisition bindings configured yet.</p>
            }
            else
            {
                <div class="mt-4 space-y-3">
                    @foreach (var binding in Bindings)
                    {
                        var editor = GetBindingEditor(binding);
                        <section class="rounded-[1rem] border border-white/10 bg-black/15 p-4">
                            <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">@GetConnectionDisplayName(binding.IntegrationConnection)</div>
                            <div class="mt-3 grid gap-3 sm:grid-cols-2">
                                <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" @bind="editor.AcquisitionUrl" />
                                <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" @bind="editor.AcquisitionLabel" placeholder="Label (optional)" />
                                <label class="inline-flex items-center gap-2 text-sm text-slate-300">
                                    <input type="checkbox" @bind="editor.IsPrimary" />
                                    Primary
                                </label>
                                <label class="inline-flex items-center gap-2 text-sm text-slate-300">
                                    <input type="checkbox" @bind="editor.IsEnabled" />
                                    Enabled
                                </label>
                            </div>
                            <div class="mt-4 flex flex-wrap gap-2">
                                <button class="rounded-full border border-white/15 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => UpdateBindingAsync(binding.Id)" disabled="@IsMutatingBindings">
                                    @(IsMutatingBindings ? "Saving..." : "Save")
                                </button>
                                <button class="rounded-full border border-rose-300/30 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => DeleteBindingAsync(binding.Id)" disabled="@IsMutatingBindings">
                                    @(IsMutatingBindings ? "Removing..." : "Delete")
                                </button>
                            </div>
                        </section>
                    }
                </div>
            }
        </section>
    }
</section>

@code {
    [Parameter] public Guid TitleId { get; set; }

    private DeveloperTitle? Title { get; set; }

    private IReadOnlyList<IntegrationConnection> Connections { get; set; } = [];

    private IReadOnlyList<TitleIntegrationBinding> Bindings { get; set; } = [];

    private Dictionary<Guid, BindingEditorState> BindingEditors { get; } = new();

    private string? NewBindingConnectionId { get; set; }

    private string? NewBindingUrl { get; set; }

    private string? NewBindingLabel { get; set; }

    private string? NewConnectionDisplayName { get; set; }

    private string? NewConnectionHomepageUrl { get; set; }

    private bool NewBindingIsPrimary { get; set; } = true;

    private bool NewBindingIsEnabled { get; set; } = true;

    private bool IsLoading { get; set; } = true;

    private bool IsMutatingBindings { get; set; }

    private string? ErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task CreateBindingAsync()
    {
        if (IsMutatingBindings)
        {
            return;
        }

        if (!Guid.TryParse(NewBindingConnectionId, out var connectionId))
        {
            ErrorMessage = "Select an integration connection.";
            return;
        }

        if (string.IsNullOrWhiteSpace(NewBindingUrl))
        {
            ErrorMessage = "Acquisition URL is required.";
            return;
        }

        await MutateBindingsAsync(async () =>
        {
            await ApiClient.CreateTitleIntegrationBindingAsync(
                TitleId,
                new UpsertTitleIntegrationBindingRequest(
                    connectionId,
                    NewBindingUrl.Trim(),
                    NormalizeOptional(NewBindingLabel),
                    null,
                    NewBindingIsPrimary,
                    NewBindingIsEnabled));

            NewBindingUrl = null;
            NewBindingLabel = null;
            NewBindingIsPrimary = true;
            NewBindingIsEnabled = true;
            StatusMessage = "Binding created.";
        });
    }

    private async Task CreateConnectionAsync()
    {
        if (Title is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(NewConnectionDisplayName))
        {
            ErrorMessage = "Publisher display name is required.";
            return;
        }

        await MutateBindingsAsync(async () =>
        {
            await ApiClient.CreateStudioIntegrationConnectionAsync(
                Title.StudioId,
                new UpsertIntegrationConnectionRequest(
                    null,
                    NewConnectionDisplayName.Trim(),
                    NormalizeOptional(NewConnectionHomepageUrl),
                    null,
                    true));

            Connections = (await ApiClient.GetStudioIntegrationConnectionsAsync(Title.StudioId)).IntegrationConnections;
            NewBindingConnectionId = Connections.FirstOrDefault()?.Id.ToString("D");
            NewConnectionDisplayName = null;
            NewConnectionHomepageUrl = null;
            StatusMessage = "Integration connection created.";
        });
    }

    private async Task UpdateBindingAsync(Guid bindingId)
    {
        if (!BindingEditors.TryGetValue(bindingId, out var editor))
        {
            return;
        }

        await MutateBindingsAsync(async () =>
        {
            await ApiClient.UpdateTitleIntegrationBindingAsync(
                TitleId,
                bindingId,
                new UpsertTitleIntegrationBindingRequest(
                    editor.ConnectionId,
                    editor.AcquisitionUrl,
                    NormalizeOptional(editor.AcquisitionLabel),
                    null,
                    editor.IsPrimary,
                    editor.IsEnabled));

            StatusMessage = "Binding updated.";
        });
    }

    private async Task DeleteBindingAsync(Guid bindingId)
    {
        await MutateBindingsAsync(async () =>
        {
            await ApiClient.DeleteTitleIntegrationBindingAsync(TitleId, bindingId);
            StatusMessage = "Binding removed.";
        });
    }

    private async Task MutateBindingsAsync(Func<Task> operation)
    {
        if (IsMutatingBindings)
        {
            return;
        }

        IsMutatingBindings = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            await operation();
            await RefreshBindingsAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsMutatingBindings = false;
        }
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StatusMessage = null;
        Title = null;
        Connections = [];
        Bindings = [];
        BindingEditors.Clear();

        try
        {
            Title = await ApiClient.GetDeveloperTitleAsync(TitleId);
            if (Title is null)
            {
                return;
            }

            Connections = (await ApiClient.GetStudioIntegrationConnectionsAsync(Title.StudioId)).IntegrationConnections;
            NewBindingConnectionId = Connections.FirstOrDefault()?.Id.ToString("D");
            await RefreshBindingsAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RefreshBindingsAsync()
    {
        Bindings = (await ApiClient.GetTitleIntegrationBindingsAsync(TitleId)).IntegrationBindings;
        BindingEditors.Clear();
        foreach (var binding in Bindings)
        {
            BindingEditors[binding.Id] = new BindingEditorState
            {
                ConnectionId = binding.IntegrationConnectionId,
                AcquisitionUrl = binding.AcquisitionUrl,
                AcquisitionLabel = binding.AcquisitionLabel,
                IsPrimary = binding.IsPrimary,
                IsEnabled = binding.IsEnabled
            };
        }
    }

    private BindingEditorState GetBindingEditor(TitleIntegrationBinding binding)
    {
        if (BindingEditors.TryGetValue(binding.Id, out var editor))
        {
            return editor;
        }

        editor = new BindingEditorState
        {
            ConnectionId = binding.IntegrationConnectionId,
            AcquisitionUrl = binding.AcquisitionUrl,
            AcquisitionLabel = binding.AcquisitionLabel,
            IsPrimary = binding.IsPrimary,
            IsEnabled = binding.IsEnabled
        };
        BindingEditors[binding.Id] = editor;
        return editor;
    }

    private static string GetConnectionDisplayName(IntegrationConnection connection) =>
        connection.SupportedPublisher?.DisplayName
        ?? connection.CustomPublisherDisplayName
        ?? connection.Id.ToString("D");

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();

    private sealed class BindingEditorState
    {
        public Guid ConnectionId { get; set; }

        public string AcquisitionUrl { get; set; } = string.Empty;

        public string? AcquisitionLabel { get; set; }

        public bool IsPrimary { get; set; }

        public bool IsEnabled { get; set; }
    }
}
