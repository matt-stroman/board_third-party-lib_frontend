@page "/develop/titles/{TitleId:guid}/media"
@layout DeveloperLayout

<PageTitle>Title Media</PageTitle>

<section class="app-panel p-6">
    <div class="app-chip w-fit">Media</div>
    <h1 class="mt-4 app-page-title">Media Slots</h1>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
        <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">Card asset<br />Required alt text</div>
        <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">Hero asset<br />Required alt text</div>
        <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">Logo asset<br />Required alt text</div>
    </div>
</section>

@code {
    [Parameter] public Guid TitleId { get; set; }
}
