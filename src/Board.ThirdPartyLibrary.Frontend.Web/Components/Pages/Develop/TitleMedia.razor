@page "/develop/titles/{TitleId:guid}/media"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Title Media</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-52 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Media unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Title is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">This account cannot access the requested title.</p>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <h1 class="mt-4 app-page-title">@Title.DisplayName</h1>
            <p class="mt-4 text-sm leading-7 text-slate-300">
                Configure card, hero, and logo media using either hosted URLs or direct upload (up to 25 MB).
            </p>

            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
            }

            <div class="mt-6 grid gap-4 lg:grid-cols-3">
                @foreach (var role in MediaRoles)
                {
                    var roleState = GetRoleState(role);
                    var currentAsset = GetMediaAsset(role);
                    var fileInputId = $"title-media-{role}";
                    <section class="rounded-[1.25rem] border border-white/10 bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">@role</div>
                        <div class="mt-3 overflow-hidden rounded-[0.9rem] border border-white/10 bg-slate-950/40">
                            @if (currentAsset is not null && !string.IsNullOrWhiteSpace(currentAsset.SourceUrl))
                            {
                                <img class="h-28 w-full object-cover" src="@currentAsset.SourceUrl" alt="@(currentAsset.AltText ?? $"{role} media asset")" />
                            }
                            else
                            {
                                <div class="grid h-28 place-items-center text-xs uppercase tracking-[0.2em] text-slate-400">No media</div>
                            }
                        </div>

                        <label class="mt-4 block text-sm text-slate-300">URL
                            <input class="mt-2 w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-slate-100" @bind="roleState.UrlInput" placeholder="https://..." />
                        </label>
                        <label class="mt-3 block text-sm text-slate-300">Alt text (optional)
                            <input class="mt-2 w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-slate-100" @bind="roleState.AltText" />
                        </label>

                        <div class="mt-3 flex flex-wrap gap-2">
                            <button class="rounded-full border border-white/15 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => SaveUrlAsync(role)" disabled="@roleState.IsSavingUrl">
                                @(roleState.IsSavingUrl ? "Saving..." : "Use URL")
                            </button>
                            <button class="rounded-full border border-rose-300/30 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => RemoveAsync(role)" disabled="@roleState.IsDeleting">
                                @(roleState.IsDeleting ? "Removing..." : "Remove")
                            </button>
                        </div>

                        <div class="mt-4">
                            <div class="flex flex-wrap items-center gap-2">
                                <label class="app-file-button" for="@fileInputId">Choose File...</label>
                                <InputFile id="@fileInputId" class="sr-only" OnChange="@(args => UploadAsync(role, args))" accept="image/jpeg,image/png,image/webp,image/gif" />
                                <span class="text-xs text-slate-300">@roleState.UploadSummary</span>
                            </div>
                        </div>
                    </section>
                }
            </div>
        </section>
    }
</section>

@code {
    [Parameter] public Guid TitleId { get; set; }

    private static readonly string[] MediaRoles = ["card", "hero", "logo"];

    private DeveloperTitle? Title { get; set; }

    private IReadOnlyList<TitleMediaAsset> MediaAssets { get; set; } = [];

    private Dictionary<string, MediaRoleState> RoleStates { get; } = new(StringComparer.Ordinal);

    private bool IsLoading { get; set; } = true;

    private string? ErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task SaveUrlAsync(string mediaRole)
    {
        var roleState = GetRoleState(mediaRole);
        if (roleState.IsSavingUrl)
        {
            return;
        }

        roleState.IsSavingUrl = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            if (string.IsNullOrWhiteSpace(roleState.UrlInput))
            {
                throw new InvalidOperationException("Media URL is required.");
            }

            await ApiClient.UpsertTitleMediaAssetAsync(
                TitleId,
                mediaRole,
                new UpsertTitleMediaAssetRequest(
                    roleState.UrlInput.Trim(),
                    NormalizeOptional(roleState.AltText),
                    null,
                    null,
                    null));

            await RefreshMediaAssetsAsync();
            StatusMessage = $"{mediaRole} media saved.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            roleState.IsSavingUrl = false;
        }
    }

    private async Task UploadAsync(string mediaRole, InputFileChangeEventArgs args)
    {
        var roleState = GetRoleState(mediaRole);
        if (roleState.IsUploading)
        {
            return;
        }

        var file = args.File;
        roleState.UploadSummary = file.Name;
        roleState.IsUploading = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            await using var stream = file.OpenReadStream(25L * 1024L * 1024L);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            await ApiClient.UploadTitleMediaAssetAsync(
                TitleId,
                mediaRole,
                new ApiUploadFile(file.Name, file.ContentType, memoryStream.ToArray()),
                NormalizeOptional(roleState.AltText));

            roleState.UrlInput = null;
            await RefreshMediaAssetsAsync();
            StatusMessage = $"{mediaRole} media uploaded.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            roleState.IsUploading = false;
        }
    }

    private async Task RemoveAsync(string mediaRole)
    {
        var roleState = GetRoleState(mediaRole);
        if (roleState.IsDeleting)
        {
            return;
        }

        roleState.IsDeleting = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            await ApiClient.DeleteTitleMediaAssetAsync(TitleId, mediaRole);
            roleState.UrlInput = null;
            roleState.UploadSummary = "No file chosen";
            await RefreshMediaAssetsAsync();
            StatusMessage = $"{mediaRole} media removed.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            roleState.IsDeleting = false;
        }
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StatusMessage = null;
        Title = null;
        MediaAssets = [];
        RoleStates.Clear();

        try
        {
            Title = await ApiClient.GetDeveloperTitleAsync(TitleId);
            if (Title is null)
            {
                return;
            }

            await RefreshMediaAssetsAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RefreshMediaAssetsAsync()
    {
        MediaAssets = (await ApiClient.GetTitleMediaAssetsAsync(TitleId)).MediaAssets;

        foreach (var role in MediaRoles)
        {
            var roleState = GetRoleState(role);
            var asset = GetMediaAsset(role);
            roleState.UrlInput = asset?.SourceUrl;
            roleState.AltText = asset?.AltText;
        }
    }

    private TitleMediaAsset? GetMediaAsset(string mediaRole) =>
        MediaAssets.FirstOrDefault(candidate => string.Equals(candidate.MediaRole, mediaRole, StringComparison.OrdinalIgnoreCase));

    private MediaRoleState GetRoleState(string mediaRole)
    {
        if (RoleStates.TryGetValue(mediaRole, out var state))
        {
            return state;
        }

        state = new MediaRoleState();
        RoleStates[mediaRole] = state;
        return state;
    }

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();

    private sealed class MediaRoleState
    {
        public string? UrlInput { get; set; }

        public string? AltText { get; set; }

        public string UploadSummary { get; set; } = "No file chosen";

        public bool IsSavingUrl { get; set; }

        public bool IsUploading { get; set; }

        public bool IsDeleting { get; set; }
    }
}
