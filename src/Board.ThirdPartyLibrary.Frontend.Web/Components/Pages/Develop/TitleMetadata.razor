@page "/develop/titles/{TitleId:guid}/metadata"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Title Metadata</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-52 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Metadata unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Title is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">This account cannot access the requested title.</p>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <h1 class="mt-4 app-page-title">@Title.DisplayName</h1>
            <p class="mt-4 text-sm leading-7 text-slate-300">
                Update the active metadata revision. When the current revision is frozen, a new revision is created automatically.
            </p>

            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
            }

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
                <label class="text-sm text-slate-300">Display name
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="DisplayName" />
                </label>
                <label class="text-sm text-slate-300">Genre
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="GenreDisplay" />
                </label>
                <label class="text-sm text-slate-300 sm:col-span-2">Short description
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="ShortDescription" />
                </label>
                <label class="text-sm text-slate-300 sm:col-span-2">Description
                    <textarea class="mt-2 min-h-32 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="Description"></textarea>
                </label>
                <label class="text-sm text-slate-300">Min players
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" type="number" min="1" @bind="MinPlayers" />
                </label>
                <label class="text-sm text-slate-300">Max players
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" type="number" min="@MinPlayers" @bind="MaxPlayers" />
                </label>
                <label class="text-sm text-slate-300">Age rating authority
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="AgeRatingAuthority" />
                </label>
                <label class="text-sm text-slate-300">Age rating value
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="AgeRatingValue" />
                </label>
                <label class="text-sm text-slate-300">Minimum age (years)
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" type="number" min="0" @bind="MinAgeYears" />
                </label>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
                <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="SaveMetadataAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Save metadata")
                </button>
            </div>
        </section>

        <section class="app-panel p-6">
            <h2 class="text-2xl font-semibold text-white">Revision history</h2>
            @if (MetadataVersions.Count == 0)
            {
                <p class="mt-3 text-sm text-slate-300">No metadata revisions found.</p>
            }
            else
            {
                <div class="mt-4 space-y-3">
                    @foreach (var version in MetadataVersions.OrderByDescending(candidate => candidate.RevisionNumber))
                    {
                        <div class="rounded-[1rem] border border-white/10 bg-black/15 px-4 py-3">
                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <div>
                                    <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">Revision @version.RevisionNumber</div>
                                    <div class="mt-1 text-sm text-white">@version.DisplayName</div>
                                    <div class="mt-1 text-xs text-slate-400">@(version.IsFrozen ? "Frozen" : "Editable") • @(version.IsCurrent ? "Current" : "Inactive")</div>
                                </div>
                                @if (!version.IsCurrent)
                                {
                                    <button class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => ActivateMetadataVersionAsync(version.RevisionNumber)" disabled="@IsActivatingRevision">
                                        @(IsActivatingRevision ? "Activating..." : "Activate")
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }
</section>

@code {
    [Parameter] public Guid TitleId { get; set; }

    private DeveloperTitle? Title { get; set; }

    private IReadOnlyList<TitleMetadataVersion> MetadataVersions { get; set; } = [];

    private string? DisplayName { get; set; }

    private string? ShortDescription { get; set; }

    private string? Description { get; set; }

    private string? GenreDisplay { get; set; }

    private int MinPlayers { get; set; } = 1;

    private int MaxPlayers { get; set; } = 1;

    private string? AgeRatingAuthority { get; set; }

    private string? AgeRatingValue { get; set; }

    private int MinAgeYears { get; set; }

    private bool IsLoading { get; set; } = true;

    private bool IsSaving { get; set; }

    private bool IsActivatingRevision { get; set; }

    private string? ErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task SaveMetadataAsync()
    {
        if (Title is null || IsSaving)
        {
            return;
        }

        var validationError = Validate();
        if (!string.IsNullOrWhiteSpace(validationError))
        {
            ErrorMessage = validationError;
            StatusMessage = null;
            return;
        }

        IsSaving = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            var response = await ApiClient.UpsertTitleMetadataAsync(
                TitleId,
                new UpsertTitleMetadataRequest(
                    DisplayName!.Trim(),
                    ShortDescription!.Trim(),
                    Description!.Trim(),
                    GenreDisplay!.Trim(),
                    MinPlayers,
                    MaxPlayers,
                    AgeRatingAuthority!.Trim(),
                    AgeRatingValue!.Trim(),
                    MinAgeYears));

            SetTitle(response.Title);
            MetadataVersions = (await ApiClient.GetTitleMetadataVersionsAsync(TitleId)).MetadataVersions;
            StatusMessage = "Metadata updated.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task ActivateMetadataVersionAsync(int revisionNumber)
    {
        if (IsActivatingRevision)
        {
            return;
        }

        IsActivatingRevision = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            var response = await ApiClient.ActivateTitleMetadataVersionAsync(TitleId, revisionNumber);
            SetTitle(response.Title);
            MetadataVersions = (await ApiClient.GetTitleMetadataVersionsAsync(TitleId)).MetadataVersions;
            StatusMessage = $"Revision {revisionNumber} activated.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsActivatingRevision = false;
        }
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StatusMessage = null;
        Title = null;
        MetadataVersions = [];

        try
        {
            var title = await ApiClient.GetDeveloperTitleAsync(TitleId);
            if (title is null)
            {
                return;
            }

            SetTitle(title);
            MetadataVersions = (await ApiClient.GetTitleMetadataVersionsAsync(TitleId)).MetadataVersions;
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SetTitle(DeveloperTitle title)
    {
        Title = title;
        DisplayName = title.DisplayName;
        ShortDescription = title.ShortDescription;
        Description = title.Description ?? string.Empty;
        GenreDisplay = title.GenreDisplay;
        MinPlayers = title.MinPlayers;
        MaxPlayers = title.MaxPlayers;
        AgeRatingAuthority = title.AgeRatingAuthority;
        AgeRatingValue = title.AgeRatingValue;
        MinAgeYears = title.MinAgeYears;
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(DisplayName))
        {
            return "Display name is required.";
        }

        if (string.IsNullOrWhiteSpace(ShortDescription))
        {
            return "Short description is required.";
        }

        if (string.IsNullOrWhiteSpace(Description))
        {
            return "Description is required.";
        }

        if (string.IsNullOrWhiteSpace(GenreDisplay))
        {
            return "Genre is required.";
        }

        if (MinPlayers < 1)
        {
            return "Minimum players must be at least 1.";
        }

        if (MaxPlayers < MinPlayers)
        {
            return "Maximum players must be greater than or equal to minimum players.";
        }

        if (string.IsNullOrWhiteSpace(AgeRatingAuthority))
        {
            return "Age rating authority is required.";
        }

        if (string.IsNullOrWhiteSpace(AgeRatingValue))
        {
            return "Age rating value is required.";
        }

        if (MinAgeYears < 0)
        {
            return "Minimum age must be zero or greater.";
        }

        return null;
    }
}
