@page "/develop/titles/{TitleId:guid}/metadata"
@layout DeveloperLayout

<PageTitle>Title Metadata</PageTitle>

<section class="app-panel p-6">
    <div class="app-chip w-fit">Metadata</div>
    <h1 class="mt-4 app-page-title">Metadata Revisions</h1>
    <div class="mt-6 grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">Current metadata editor placeholder</div>
        <div class="rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">Revision history placeholder</div>
    </div>
</section>

@code {
    [Parameter] public Guid TitleId { get; set; }
}
