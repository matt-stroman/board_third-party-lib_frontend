@page "/develop/titles/{TitleId:guid}"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Title Workspace</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-52 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title workspace unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Title is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">This account cannot access the requested title.</p>
            <a class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop">Back to develop</a>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <h1 class="app-page-title">@Title.DisplayName</h1>
                    <p class="mt-4 text-base leading-8 text-slate-300">@Title.ShortDescription</p>
                    <div class="mt-3 text-xs uppercase tracking-[0.2em] text-slate-400">Auto slug: @GeneratedSlug</div>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a class="app-chip" href="/develop/titles/@TitleId/metadata">Metadata</a>
                    <a class="app-chip" href="/develop/titles/@TitleId/media">Media</a>
                    <a class="app-chip" href="/develop/titles/@TitleId/releases">Releases</a>
                    <a class="app-chip" href="/develop/titles/@TitleId/acquisition">Acquisition</a>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
            }

            <div class="mt-6 grid gap-4 sm:grid-cols-3">
                <label class="text-sm text-slate-300">Content kind
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="ContentKind">
                        <option value="game">Game</option>
                        <option value="app">App</option>
                    </select>
                </label>
                <label class="text-sm text-slate-300">Lifecycle status
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="LifecycleStatus">
                        <option value="draft">Draft</option>
                        <option value="testing">Testing</option>
                        <option value="published">Published</option>
                        <option value="archived">Archived</option>
                    </select>
                </label>
                <label class="text-sm text-slate-300">Visibility
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="Visibility" disabled="@IsPrivateOnlyLifecycle">
                        <option value="private">Private</option>
                        <option value="unlisted">Unlisted</option>
                        <option value="listed">Listed</option>
                    </select>
                </label>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
                <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="SaveStableFieldsAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Save title settings")
                </button>
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-3">
                <div class="rounded-[1.25rem] bg-black/15 p-4">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Metadata revision</div>
                    <div class="mt-2 text-lg font-semibold text-white">@Title.CurrentMetadataRevision</div>
                </div>
                <div class="rounded-[1.25rem] bg-black/15 p-4">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Current release</div>
                    <div class="mt-2 text-lg font-semibold text-white">@(Title.CurrentRelease?.Version ?? "None")</div>
                </div>
                <div class="rounded-[1.25rem] bg-black/15 p-4">
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Acquisition URL</div>
                    <div class="mt-2 text-sm text-white">@(Title.AcquisitionUrl ?? "Not configured")</div>
                </div>
            </div>
        </section>
    }
</section>

@code {
    [Parameter] public Guid TitleId { get; set; }

    private DeveloperTitle? Title { get; set; }

    private string ContentKind { get; set; } = "game";

    private string LifecycleStatus { get; set; } = "draft";

    private string Visibility { get; set; } = "private";

    private bool IsLoading { get; set; } = true;

    private bool IsSaving { get; set; }

    private string? ErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    private bool IsPrivateOnlyLifecycle =>
        string.Equals(LifecycleStatus, "draft", StringComparison.Ordinal) ||
        string.Equals(LifecycleStatus, "archived", StringComparison.Ordinal);

    private string GeneratedSlug => SlugGenerator.ToKebabCase(Title?.DisplayName, "title");

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task SaveStableFieldsAsync()
    {
        if (Title is null || IsSaving)
        {
            return;
        }

        ErrorMessage = null;
        StatusMessage = null;
        if (IsPrivateOnlyLifecycle)
        {
            Visibility = "private";
        }

        IsSaving = true;
        try
        {
            var response = await ApiClient.UpdateTitleAsync(
                TitleId,
                new UpdateDeveloperTitleRequest(
                    GeneratedSlug,
                    ContentKind,
                    LifecycleStatus,
                    Visibility));
            SetTitle(response.Title);
            StatusMessage = "Title settings updated.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StatusMessage = null;
        Title = null;

        try
        {
            var title = await ApiClient.GetDeveloperTitleAsync(TitleId);
            if (title is null)
            {
                return;
            }

            SetTitle(title);
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SetTitle(DeveloperTitle title)
    {
        Title = title;
        ContentKind = title.ContentKind;
        LifecycleStatus = title.LifecycleStatus;
        Visibility = title.Visibility;
    }
}
