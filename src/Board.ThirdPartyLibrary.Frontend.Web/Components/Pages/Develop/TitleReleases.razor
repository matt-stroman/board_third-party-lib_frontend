@page "/develop/titles/{TitleId:guid}/releases"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Title Releases</PageTitle>

<section class="space-y-6">
    @if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-52 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Releases unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Title is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">This account cannot access the requested title.</p>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <h1 class="mt-4 app-page-title">@Title.DisplayName</h1>

            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
            }

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
                <label class="text-sm text-slate-300">New release version
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="NewReleaseVersion" placeholder="1.0.0" />
                </label>
                <label class="text-sm text-slate-300">Metadata revision
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="NewReleaseMetadataRevision">
                        @foreach (var revision in MetadataVersions.OrderByDescending(candidate => candidate.RevisionNumber))
                        {
                            <option value="@revision.RevisionNumber">Revision @revision.RevisionNumber (@revision.DisplayName)</option>
                        }
                    </select>
                </label>
            </div>

            <div class="mt-6">
                <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="CreateReleaseAsync" disabled="@IsCreatingRelease">
                    @(IsCreatingRelease ? "Creating..." : "Create release")
                </button>
            </div>
        </section>

        <section class="app-panel p-6">
            <h2 class="text-2xl font-semibold text-white">Release history</h2>
            @if (Releases.Count == 0)
            {
                <p class="mt-3 text-sm text-slate-300">No releases have been created yet.</p>
            }
            else
            {
                <div class="mt-4 space-y-3">
                    @foreach (var release in Releases)
                    {
                        <div class="@($"rounded-[1rem] border px-4 py-3 {(release.Id == SelectedReleaseId ? "border-cyan-300/35 bg-cyan-300/10" : "border-white/10 bg-black/15")}")">
                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <button class="text-left" type="button" @onclick="() => SelectRelease(release.Id)">
                                    <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">@release.Status</div>
                                    <div class="mt-1 text-lg font-semibold text-white">@release.Version</div>
                                    <div class="mt-1 text-xs text-slate-400">Metadata revision @release.MetadataRevisionNumber • @(release.IsCurrent ? "Current" : "Not current")</div>
                                </button>
                                <div class="flex flex-wrap gap-2">
                                    @if (release.Status == "draft")
                                    {
                                        <button class="rounded-full border border-white/15 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => PublishReleaseAsync(release.Id)" disabled="@IsMutatingRelease">Publish</button>
                                    }
                                    @if (release.Status == "published")
                                    {
                                        <button class="rounded-full border border-white/15 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => ActivateReleaseAsync(release.Id)" disabled="@(IsMutatingRelease || release.IsCurrent)">Activate</button>
                                        <button class="rounded-full border border-rose-300/30 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => WithdrawReleaseAsync(release.Id)" disabled="@IsMutatingRelease">Withdraw</button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

        @if (SelectedRelease is not null)
        {
            <section class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
                <section class="app-panel p-6">
                    <h2 class="text-2xl font-semibold text-white">Selected release</h2>
                    <p class="mt-2 text-sm text-slate-300">Update version and metadata revision while the release is draft.</p>

                    <div class="mt-4 grid gap-4 sm:grid-cols-2">
                        <label class="text-sm text-slate-300">Version
                            <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="SelectedReleaseVersion" />
                        </label>
                        <label class="text-sm text-slate-300">Metadata revision
                            <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="SelectedReleaseMetadataRevision">
                                @foreach (var revision in MetadataVersions.OrderByDescending(candidate => candidate.RevisionNumber))
                                {
                                    <option value="@revision.RevisionNumber">Revision @revision.RevisionNumber</option>
                                }
                            </select>
                        </label>
                    </div>

                    <div class="mt-4">
                        <button class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="UpdateSelectedReleaseAsync" disabled="@(IsMutatingRelease || SelectedRelease.Status != "draft")">
                            @(IsMutatingRelease ? "Saving..." : "Update release")
                        </button>
                    </div>
                </section>

                <section class="app-panel p-6">
                    <h2 class="text-2xl font-semibold text-white">Artifacts</h2>
                    <p class="mt-2 text-sm text-slate-300">Artifacts can only be created or removed while release is draft.</p>

                    <div class="mt-4 grid gap-3">
                        <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" @bind="ArtifactPackageName" placeholder="Package name (fun.board.example)" />
                        <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" type="number" min="1" @bind="ArtifactVersionCode" placeholder="Version code" />
                        <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" @bind="ArtifactSha256" placeholder="SHA-256 (optional)" />
                        <input class="w-full rounded-[0.9rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-sm text-slate-100" type="number" min="1" @bind="ArtifactFileSizeBytes" placeholder="File size bytes (optional)" />
                    </div>

                    <div class="mt-4">
                        <button class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="CreateArtifactAsync" disabled="@(IsMutatingRelease || SelectedRelease.Status != "draft")">
                            @(IsMutatingRelease ? "Saving..." : "Add artifact")
                        </button>
                    </div>

                    <div class="mt-4 space-y-2">
                        @foreach (var artifact in SelectedReleaseArtifacts)
                        {
                            <div class="flex items-center justify-between gap-2 rounded-[0.9rem] border border-white/10 bg-black/15 px-3 py-2">
                                <div class="text-xs text-slate-300">@artifact.PackageName • vc @artifact.VersionCode</div>
                                <button class="rounded-full border border-rose-300/30 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => DeleteArtifactAsync(artifact.Id)" disabled="@(IsMutatingRelease || SelectedRelease.Status != "draft")">Delete</button>
                            </div>
                        }
                    </div>
                </section>
            </section>
        }
    }
</section>

@code {
    [Parameter] public Guid TitleId { get; set; }

    private DeveloperTitle? Title { get; set; }

    private IReadOnlyList<TitleMetadataVersion> MetadataVersions { get; set; } = [];

    private IReadOnlyList<TitleRelease> Releases { get; set; } = [];

    private Guid? SelectedReleaseId { get; set; }

    private IReadOnlyList<ReleaseArtifact> SelectedReleaseArtifacts { get; set; } = [];

    private string NewReleaseVersion { get; set; } = "1.0.0";

    private int NewReleaseMetadataRevision { get; set; } = 1;

    private string SelectedReleaseVersion { get; set; } = string.Empty;

    private int SelectedReleaseMetadataRevision { get; set; } = 1;

    private string ArtifactPackageName { get; set; } = string.Empty;

    private long ArtifactVersionCode { get; set; } = 1;

    private string? ArtifactSha256 { get; set; }

    private long? ArtifactFileSizeBytes { get; set; }

    private bool IsLoading { get; set; } = true;

    private bool IsCreatingRelease { get; set; }

    private bool IsMutatingRelease { get; set; }

    private string? ErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    private TitleRelease? SelectedRelease => Releases.FirstOrDefault(candidate => candidate.Id == SelectedReleaseId);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task CreateReleaseAsync()
    {
        if (IsCreatingRelease)
        {
            return;
        }

        IsCreatingRelease = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            await ApiClient.CreateTitleReleaseAsync(
                TitleId,
                new UpsertTitleReleaseRequest(NewReleaseVersion.Trim(), NewReleaseMetadataRevision));
            await RefreshReleasesAsync();
            StatusMessage = "Release created.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsCreatingRelease = false;
        }
    }

    private async Task UpdateSelectedReleaseAsync()
    {
        if (SelectedRelease is null || IsMutatingRelease)
        {
            return;
        }

        await MutateSelectedReleaseAsync(async () =>
        {
            await ApiClient.UpdateTitleReleaseAsync(
                TitleId,
                SelectedRelease.Id,
                new UpsertTitleReleaseRequest(SelectedReleaseVersion.Trim(), SelectedReleaseMetadataRevision));
            StatusMessage = "Release updated.";
        });
    }

    private async Task PublishReleaseAsync(Guid releaseId)
    {
        await MutateSelectedReleaseAsync(async () =>
        {
            await ApiClient.PublishTitleReleaseAsync(TitleId, releaseId);
            StatusMessage = "Release published.";
        });
    }

    private async Task ActivateReleaseAsync(Guid releaseId)
    {
        await MutateSelectedReleaseAsync(async () =>
        {
            var response = await ApiClient.ActivateTitleReleaseAsync(TitleId, releaseId);
            Title = response.Title;
            StatusMessage = "Release activated.";
        });
    }

    private async Task WithdrawReleaseAsync(Guid releaseId)
    {
        await MutateSelectedReleaseAsync(async () =>
        {
            await ApiClient.WithdrawTitleReleaseAsync(TitleId, releaseId);
            StatusMessage = "Release withdrawn.";
        });
    }

    private async Task CreateArtifactAsync()
    {
        if (SelectedRelease is null || IsMutatingRelease)
        {
            return;
        }

        await MutateSelectedReleaseAsync(async () =>
        {
            await ApiClient.CreateReleaseArtifactAsync(
                TitleId,
                SelectedRelease.Id,
                new UpsertReleaseArtifactRequest(
                    "apk",
                    ArtifactPackageName.Trim(),
                    ArtifactVersionCode,
                    NormalizeOptional(ArtifactSha256),
                    ArtifactFileSizeBytes));
            ArtifactPackageName = string.Empty;
            ArtifactVersionCode = 1;
            ArtifactSha256 = null;
            ArtifactFileSizeBytes = null;
            StatusMessage = "Artifact added.";
        });
    }

    private async Task DeleteArtifactAsync(Guid artifactId)
    {
        if (SelectedRelease is null || IsMutatingRelease)
        {
            return;
        }

        await MutateSelectedReleaseAsync(async () =>
        {
            await ApiClient.DeleteReleaseArtifactAsync(TitleId, SelectedRelease.Id, artifactId);
            StatusMessage = "Artifact removed.";
        });
    }

    private void SelectRelease(Guid releaseId)
    {
        SelectedReleaseId = releaseId;
        var release = SelectedRelease;
        if (release is null)
        {
            return;
        }

        SelectedReleaseVersion = release.Version;
        SelectedReleaseMetadataRevision = release.MetadataRevisionNumber;
        _ = LoadSelectedReleaseArtifactsAsync();
    }

    private async Task MutateSelectedReleaseAsync(Func<Task> operation)
    {
        if (IsMutatingRelease)
        {
            return;
        }

        IsMutatingRelease = true;
        ErrorMessage = null;
        StatusMessage = null;

        try
        {
            await operation();
            await RefreshReleasesAsync();
            await LoadSelectedReleaseArtifactsAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsMutatingRelease = false;
        }
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StatusMessage = null;
        Title = null;
        MetadataVersions = [];
        Releases = [];
        SelectedReleaseId = null;
        SelectedReleaseArtifacts = [];

        try
        {
            Title = await ApiClient.GetDeveloperTitleAsync(TitleId);
            if (Title is null)
            {
                return;
            }

            MetadataVersions = (await ApiClient.GetTitleMetadataVersionsAsync(TitleId)).MetadataVersions;
            if (MetadataVersions.Count > 0)
            {
                NewReleaseMetadataRevision = MetadataVersions.Max(candidate => candidate.RevisionNumber);
            }

            await RefreshReleasesAsync();
            if (SelectedReleaseId is not null)
            {
                await LoadSelectedReleaseArtifactsAsync();
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RefreshReleasesAsync()
    {
        Releases = (await ApiClient.GetTitleReleasesAsync(TitleId)).Releases
            .OrderByDescending(candidate => candidate.PublishedAt ?? candidate.CreatedAt)
            .ThenByDescending(candidate => candidate.CreatedAt)
            .ToArray();

        if (SelectedReleaseId is null || Releases.All(candidate => candidate.Id != SelectedReleaseId))
        {
            SelectedReleaseId = Releases.FirstOrDefault()?.Id;
        }

        if (SelectedRelease is not null)
        {
            SelectedReleaseVersion = SelectedRelease.Version;
            SelectedReleaseMetadataRevision = SelectedRelease.MetadataRevisionNumber;
        }
    }

    private async Task LoadSelectedReleaseArtifactsAsync()
    {
        if (SelectedRelease is null)
        {
            SelectedReleaseArtifacts = [];
            return;
        }

        SelectedReleaseArtifacts = (await ApiClient.GetReleaseArtifactsAsync(TitleId, SelectedRelease.Id)).Artifacts;
    }

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();
}
