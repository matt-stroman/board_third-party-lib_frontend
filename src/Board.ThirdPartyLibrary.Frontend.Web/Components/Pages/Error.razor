@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="mx-auto max-w-3xl app-panel p-8">
    <h1 class="app-page-title">Unexpected Error</h1>
    <p class="mt-4 text-base leading-8 text-slate-300">
        Something went wrong while loading this page.
    </p>

    @if (ShowRequestId)
    {
        <p class="mt-6 rounded-[1.25rem] bg-black/15 p-4 text-sm text-slate-300">
            <strong class="text-white">Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <div class="mt-6 rounded-[1.25rem] bg-black/15 p-4 text-sm leading-7 text-slate-300">
        If this keeps happening, reload the page and try again.
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
