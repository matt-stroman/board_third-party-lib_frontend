
@page "/browse"
@using Microsoft.AspNetCore.WebUtilities
@inject IBoardLibraryApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Browse</PageTitle>

<section class="space-y-8">
    <div class="space-y-3">
        <h1 class="app-page-title">Browse</h1>
        <p class="max-w-3xl text-base leading-8 text-slate-300">
            Browse games and apps from the community.
        </p>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Catalog unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-48 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-56 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else
    {
        <section class="app-panel p-5">
            <div class="grid gap-3 xl:grid-cols-[2fr_0.85fr_0.85fr_auto]">
                <label class="text-sm text-slate-300">
                    Search
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" value="@SearchInput" @oninput="HandleSearchInput" placeholder="Title, studio, description" />
                </label>
                <label class="text-sm text-slate-300">
                    Content kind
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" value="@ContentKindInput" @onchange="HandleContentKindChanged">
                        <option value="all">Games and apps</option>
                        <option value="game">Games only</option>
                        <option value="app">Apps only</option>
                    </select>
                </label>
                <label class="text-sm text-slate-300">
                    Sort
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" value="@SortInput" @onchange="HandleSortChanged">
                        <option value="title-asc">Title (A-Z)</option>
                        <option value="title-desc">Title (Z-A)</option>
                        <option value="studio-asc">Studio (A-Z)</option>
                        <option value="studio-desc">Studio (Z-A)</option>
                        <option value="genre-asc">Genre</option>
                        <option value="players-asc">Players (low-high)</option>
                        <option value="players-desc">Players (high-low)</option>
                        <option value="age-asc">Age rating (low-high)</option>
                        <option value="age-desc">Age rating (high-low)</option>
                    </select>
                </label>
                <div class="flex items-end">
                    <button class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" type="button" @onclick="ResetFilters">
                        Reset filters
                    </button>
                </div>
            </div>

            <div class="mt-5 space-y-3">
                <details class="rounded-[1.5rem] border border-white/10 bg-black/10 px-4 py-3 text-slate-200" open="@(SelectedStudios.Count > 0)">
                    <summary class="flex cursor-pointer list-none items-center gap-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-100/85">
                        <span>Studios</span>
                        <span class="h-px flex-1 bg-white/10"></span>
                        <span class="text-[0.65rem] tracking-[0.16em] text-slate-400">@VisibleStudioEntries.Count available</span>
                    </summary>
                    <div class="mt-4 flex flex-wrap gap-2">
                        @foreach (var studio in VisibleStudioEntries)
                        {
                            var selected = SelectedStudios.Contains(studio.Slug);
                            <button class="rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] transition @(selected ? "border-cyan-300/45 bg-cyan-300/15 text-cyan-50" : "border-white/15 text-slate-100 hover:border-cyan-300/45 hover:text-cyan-100")" type="button" aria-pressed="@selected" @onclick="() => ToggleStudioFilter(studio.Slug)">
                                @studio.DisplayName (@studio.TitleCount)
                            </button>
                        }
                    </div>
                </details>

                <details class="rounded-[1.5rem] border border-white/10 bg-black/10 px-4 py-3 text-slate-200" open="@(SelectedGenres.Count > 0)">
                    <summary class="flex cursor-pointer list-none items-center gap-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-100/85">
                        <span>Genres</span>
                        <span class="h-px flex-1 bg-white/10"></span>
                        <span class="text-[0.65rem] tracking-[0.16em] text-slate-400">@AvailableGenreTags.Count available</span>
                    </summary>
                    <div class="mt-4 flex flex-wrap gap-2">
                        @foreach (var genreTag in AvailableGenreTags)
                        {
                            var selected = SelectedGenres.Contains(genreTag);
                            <button class="rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] transition @(selected ? "border-cyan-300/45 bg-cyan-300/15 text-cyan-50" : "border-white/15 text-slate-100 hover:border-cyan-300/45 hover:text-cyan-100")" type="button" aria-pressed="@selected" @onclick="() => ToggleGenreFilter(genreTag)">
                                @genreTag
                            </button>
                        }
                    </div>
                </details>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
                <div>
                    <h2 class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold uppercase tracking-[0.08em] text-white">Search results</h2>
                    <div class="mt-1 text-sm text-slate-400">
                        Explore titles without leaving the catalog.
                    </div>
                </div>
                <div class="flex flex-wrap items-center gap-3 xl:justify-end">
                    <label class="text-sm text-slate-300">
                        Results per page
                        <select class="ml-3 rounded-full border border-white/15 bg-slate-950/70 px-4 py-2 text-sm text-slate-100" value="@ResultsPerPageInput" @onchange="HandleResultsPerPageChanged">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="all">All</option>
                        </select>
                    </label>
                    @if (FilteredTitles.Count > 0)
                    {
                        <div class="app-panel flex flex-wrap gap-3 p-4 text-sm">
                            <span>@FilteredTitles.Count titles</span>
                            <span class="text-slate-500">•</span>
                            <span>@VisibleStudioEntries.Count studios</span>
                            <span class="text-slate-500">•</span>
                            <span>Page @CurrentPageNumber of @TotalPages</span>
                        </div>
                    }
                </div>
            </div>

            @if (FilteredTitles.Count == 0)
            {
                <section class="app-panel p-6">
                    <h3 class="text-xl font-semibold text-white">No titles match the current filters</h3>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                        Try clearing one or more filters to broaden the results.
                    </p>
                </section>
            }
            else
            {
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
                    @foreach (var title in PagedTitles)
                    {
                        <button class="app-panel group min-h-[26rem] overflow-hidden p-0 text-left transition hover:-translate-y-1 hover:border-cyan-300/35" type="button" @onclick="() => OpenTitleModalAsync(title)">
                            <div class="flex h-full flex-col justify-end bg-cover bg-center" style="@GetCardStyle(title)">
                                <div class="bg-[linear-gradient(180deg,rgba(7,9,14,0.12),rgba(7,9,14,0.95))] p-4">
                                    <div class="rounded-[1.25rem] border border-white/10 bg-slate-950/65 p-4 shadow-[0_10px_32px_rgba(8,8,12,0.34)] backdrop-blur-sm">
                                        <div class="flex flex-wrap gap-2 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-cyan-100/85">
                                            <span class="rounded-full border border-white/15 px-3 py-1">@FormatContentKind(title.ContentKind)</span>
                                            <span class="rounded-full border border-white/15 px-3 py-1">@title.PlayerCountDisplay</span>
                                            <span class="rounded-full border border-white/15 px-3 py-1">@title.AgeDisplay</span>
                                        </div>
                                        <div class="mt-4 text-2xl font-bold text-white">@title.DisplayName</div>
                                        <div class="mt-2 text-xs uppercase tracking-[0.22em] text-cyan-100/75">@GetStudioDisplayName(title.StudioSlug)</div>
                                        <div class="mt-3 flex flex-wrap gap-2">
                                            @foreach (var tag in BrowseCatalogProjectionService.ParseGenreTags(title.GenreDisplay).Take(3))
                                            {
                                                <span class="rounded-full border border-white/10 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-slate-100">@tag</span>
                                            }
                                        </div>
                                        <p class="mt-4 text-sm leading-6 text-slate-200">
                                            @title.ShortDescription
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </button>
                    }
                </div>

                <div class="flex flex-wrap items-center justify-between gap-3">
                    <button class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 @(HasPreviousPage ? string.Empty : "pointer-events-none opacity-40")" type="button" @onclick="ShowPreviousPage" disabled="@(!HasPreviousPage)">
                        Previous
                    </button>
                    <div class="text-sm text-slate-400">Showing @PagedTitles.Count of @FilteredTitles.Count results</div>
                    <button class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 @(HasNextPage ? string.Empty : "pointer-events-none opacity-40")" type="button" @onclick="ShowNextPage" disabled="@(!HasNextPage)">
                        Next
                    </button>
                </div>
            }
        </section>
    }
</section>

@if (IsTitleModalOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/75 p-4 backdrop-blur-sm" @onclick="CloseTitleModal">
        <div class="app-panel max-h-[90vh] w-full max-w-5xl overflow-y-auto p-6 md:p-8" @onclick:stopPropagation="true">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Quick view</div>
                    <h2 class="mt-2 text-3xl font-black text-white">@(ModalTitleDetail?.DisplayName ?? ModalTitleSummary?.DisplayName)</h2>
                </div>
                <button class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" type="button" @onclick="CloseTitleModal">
                    Close
                </button>
            </div>

            @if (IsTitleModalLoading)
            {
                <div class="mt-6 h-72 animate-pulse rounded-[1.75rem] bg-white/10"></div>
            }
            else if (!string.IsNullOrWhiteSpace(TitleModalError))
            {
                <div class="mt-6 rounded-[1.5rem] border border-rose-400/25 bg-rose-500/10 p-5 text-sm leading-7 text-rose-100">
                    @TitleModalError
                </div>
            }
            else if (ModalTitleDetail is not null)
            {
                <div class="mt-6 space-y-6">
                    <div class="min-h-[20rem] rounded-[1.75rem] bg-cover bg-center" style="@GetModalHeroStyle(ModalTitleDetail)"></div>
                    <div class="grid gap-6 lg:grid-cols-[1.35fr_0.65fr]">
                        <div class="space-y-5">
                            <div class="flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-cyan-100/80">
                                <span class="rounded-full border border-white/15 px-3 py-1">@FormatContentKind(ModalTitleDetail.ContentKind)</span>
                                <span class="rounded-full border border-white/15 px-3 py-1">@ModalTitleDetail.PlayerCountDisplay</span>
                                <span class="rounded-full border border-white/15 px-3 py-1">@ModalTitleDetail.AgeDisplay</span>
                                @foreach (var tag in BrowseCatalogProjectionService.ParseGenreTags(ModalTitleDetail.GenreDisplay))
                                {
                                    <span class="rounded-full border border-white/15 px-3 py-1">@tag</span>
                                }
                            </div>
                            <p class="text-base leading-8 text-slate-200">@ModalTitleDetail.ShortDescription</p>
                            @if (!string.IsNullOrWhiteSpace(ModalTitleDetail.Description))
                            {
                                <p class="text-sm leading-7 text-slate-300">@ModalTitleDetail.Description</p>
                            }
                        </div>
                        <div class="space-y-4">
                            <div class="rounded-[1.5rem] border border-white/10 bg-black/15 p-5">
                                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Studio</div>
                                <div class="mt-2 text-lg font-semibold text-white">@GetStudioDisplayName(ModalTitleDetail.StudioSlug)</div>
                            </div>
                            <div class="rounded-[1.5rem] border border-white/10 bg-black/15 p-5">
                                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Release</div>
                                <div class="mt-2 text-sm text-slate-300">@(ModalTitleDetail.CurrentRelease?.Version ?? "Not published")</div>
                            </div>
                            <div class="flex flex-col gap-3">
                                <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@($"/browse/{ModalTitleDetail.StudioSlug}/{ModalTitleDetail.Slug}")">
                                    Details
                                </a>
                                @if (!string.IsNullOrWhiteSpace(ModalTitleDetail.Acquisition?.Url ?? ModalTitleDetail.AcquisitionUrl))
                                {
                                    <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@(ModalTitleDetail.Acquisition?.Url ?? ModalTitleDetail.AcquisitionUrl)" target="_blank" rel="noreferrer">
                                        @(ModalTitleDetail.Acquisition?.Label ?? "Get title")
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private string SearchInput { get; set; } = string.Empty;
    private string ContentKindInput { get; set; } = "all";
    private string SortInput { get; set; } = "title-asc";
    private string ResultsPerPageInput { get; set; } = "10";
    private IReadOnlyList<CatalogTitleSummary> AllTitles { get; set; } = [];
    private IReadOnlyList<CatalogTitleSummary> FilteredTitles { get; set; } = [];
    private IReadOnlyList<CatalogTitleSummary> PagedTitles { get; set; } = [];
    private IReadOnlyList<StudioSummary> Studios { get; set; } = [];
    private IReadOnlyDictionary<string, string> StudioDisplayNameBySlug { get; set; } = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyDictionary<string, string?> StudioDescriptionBySlug { get; set; } = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<BrowseStudioEntry> VisibleStudioEntries { get; set; } = [];
    private IReadOnlyList<string> AvailableGenreTags { get; set; } = [];
    private HashSet<string> SelectedGenres { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> SelectedStudios { get; } = new(StringComparer.OrdinalIgnoreCase);
    private int CurrentPageNumber { get; set; } = 1;
    private CatalogTitleSummary? ModalTitleSummary { get; set; }
    private CatalogTitle? ModalTitleDetail { get; set; }
    private string? TitleModalError { get; set; }
    private bool IsTitleModalLoading { get; set; }
    private Dictionary<string, CatalogTitle> TitleDetailCache { get; } = new(StringComparer.OrdinalIgnoreCase);
    private int ResultsPerPage => NormalizeResultsPerPage(ResultsPerPageInput);
    private int TotalPages => ResultsPerPage <= 0 ? 1 : Math.Max(1, (int)Math.Ceiling(FilteredTitles.Count / (double)ResultsPerPage));
    private bool HasPreviousPage => CurrentPageNumber > 1;
    private bool HasNextPage => CurrentPageNumber < TotalPages;
    private bool IsTitleModalOpen => ModalTitleSummary is not null;

    protected override async Task OnInitializedAsync()
    {
        ErrorMessage = null;
        IsLoading = true;
        InitializeInteractiveInputsFromCurrentUri();

        try
        {
            AllTitles = await LoadAllPublicTitlesAsync();
            Studios = (await ApiClient.GetPublicStudiosAsync()).Studios;
            StudioDisplayNameBySlug = Studios.GroupBy(candidate => candidate.Slug, StringComparer.OrdinalIgnoreCase).ToDictionary(group => group.Key, group => group.First().DisplayName, StringComparer.OrdinalIgnoreCase);
            StudioDescriptionBySlug = Studios.GroupBy(candidate => candidate.Slug, StringComparer.OrdinalIgnoreCase).ToDictionary(group => group.Key, group => group.First().Description, StringComparer.OrdinalIgnoreCase);
            ApplyBrowseProjection(resetPage: true);
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            AllTitles = [];
            FilteredTitles = [];
            PagedTitles = [];
            Studios = [];
            VisibleStudioEntries = [];
            AvailableGenreTags = [];
            StudioDisplayNameBySlug = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            StudioDescriptionBySlug = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task<IReadOnlyList<CatalogTitleSummary>> LoadAllPublicTitlesAsync()
    {
        var titles = new List<CatalogTitleSummary>();
        var pageNumber = 1;
        while (true)
        {
            var response = await ApiClient.GetCatalogTitlesAsync(new CatalogBrowseRequest(StudioSlug: null, ContentKind: null, Genre: null, Sort: "title", PageNumber: pageNumber, PageSize: 48));
            titles.AddRange(response.Titles.Where(candidate => string.Equals(candidate.Visibility, "listed", StringComparison.OrdinalIgnoreCase) && (string.Equals(candidate.LifecycleStatus, "testing", StringComparison.OrdinalIgnoreCase) || string.Equals(candidate.LifecycleStatus, "published", StringComparison.OrdinalIgnoreCase))));
            if (response.Paging.TotalPages <= pageNumber || response.Titles.Count == 0)
            {
                break;
            }
            pageNumber++;
        }
        return titles;
    }

    private void InitializeInteractiveInputsFromCurrentUri()
    {
        var query = QueryHelpers.ParseQuery(new Uri(NavigationManager.Uri).Query);
        SearchInput = query.TryGetValue("q", out var searchQuery) ? searchQuery.ToString() : string.Empty;
        ContentKindInput = BrowseCatalogProjectionService.NormalizeContentKind(query.TryGetValue("contentKind", out var contentKind) ? contentKind.ToString() : null);
        SortInput = BrowseCatalogProjectionService.NormalizeSort(query.TryGetValue("sort", out var sort) ? sort.ToString() : null);
        SelectedGenres.Clear();
        foreach (var genre in ParseCsv(query.TryGetValue("genres", out var genres) ? genres.ToString() : null))
        {
            SelectedGenres.Add(genre);
        }
        SelectedStudios.Clear();
        foreach (var studio in ParseCsv(query.TryGetValue("studios", out var studios) ? studios.ToString() : null))
        {
            SelectedStudios.Add(studio);
        }
    }

    private void ApplyBrowseProjection(bool resetPage)
    {
        var projection = BrowseCatalogProjectionService.Project(AllTitles, StudioDisplayNameBySlug, StudioDescriptionBySlug, new BrowseCatalogFilterState(string.IsNullOrWhiteSpace(SearchInput) ? null : SearchInput.Trim(), ContentKindInput, SortInput, SelectedGenres.ToArray(), SelectedStudios.ToArray()));
        FilteredTitles = projection.FilteredTitles;
        VisibleStudioEntries = projection.VisibleStudios;
        AvailableGenreTags = projection.AvailableGenres;
        CurrentPageNumber = resetPage ? 1 : Math.Clamp(CurrentPageNumber, 1, TotalPages);
        ApplyPaging();
    }

    private void ApplyPaging()
    {
        if (FilteredTitles.Count == 0)
        {
            PagedTitles = [];
            CurrentPageNumber = 1;
            return;
        }
        if (ResultsPerPage <= 0)
        {
            CurrentPageNumber = 1;
            PagedTitles = FilteredTitles;
            return;
        }
        CurrentPageNumber = Math.Clamp(CurrentPageNumber, 1, TotalPages);
        var skip = (CurrentPageNumber - 1) * ResultsPerPage;
        PagedTitles = FilteredTitles.Skip(skip).Take(ResultsPerPage).ToArray();
    }

    private void HandleSearchInput(ChangeEventArgs eventArgs)
    {
        SearchInput = eventArgs.Value?.ToString() ?? string.Empty;
        ApplyBrowseProjection(resetPage: true);
    }

    private void HandleContentKindChanged(ChangeEventArgs eventArgs)
    {
        ContentKindInput = BrowseCatalogProjectionService.NormalizeContentKind(eventArgs.Value?.ToString());
        ApplyBrowseProjection(resetPage: true);
    }

    private void HandleSortChanged(ChangeEventArgs eventArgs)
    {
        SortInput = BrowseCatalogProjectionService.NormalizeSort(eventArgs.Value?.ToString());
        ApplyBrowseProjection(resetPage: true);
    }

    private void HandleResultsPerPageChanged(ChangeEventArgs eventArgs)
    {
        ResultsPerPageInput = NormalizeResultsPerPageInput(eventArgs.Value?.ToString());
        ApplyBrowseProjection(resetPage: true);
    }

    private void ResetFilters()
    {
        SearchInput = string.Empty;
        ContentKindInput = "all";
        SortInput = "title-asc";
        ResultsPerPageInput = "10";
        SelectedGenres.Clear();
        SelectedStudios.Clear();
        ApplyBrowseProjection(resetPage: true);
    }

    private void ToggleStudioFilter(string studioSlug)
    {
        if (!SelectedStudios.Add(studioSlug))
        {
            SelectedStudios.Remove(studioSlug);
        }
        ApplyBrowseProjection(resetPage: true);
    }

    private void ToggleGenreFilter(string genreTag)
    {
        if (!SelectedGenres.Add(genreTag))
        {
            SelectedGenres.Remove(genreTag);
        }
        ApplyBrowseProjection(resetPage: true);
    }

    private void ShowPreviousPage()
    {
        if (!HasPreviousPage)
        {
            return;
        }
        CurrentPageNumber--;
        ApplyPaging();
    }

    private void ShowNextPage()
    {
        if (!HasNextPage)
        {
            return;
        }
        CurrentPageNumber++;
        ApplyPaging();
    }

    private async Task OpenTitleModalAsync(CatalogTitleSummary title)
    {
        ModalTitleSummary = title;
        ModalTitleDetail = null;
        TitleModalError = null;
        IsTitleModalLoading = true;
        var cacheKey = BuildTitleCacheKey(title.StudioSlug, title.Slug);
        if (TitleDetailCache.TryGetValue(cacheKey, out var cachedTitle))
        {
            ModalTitleDetail = cachedTitle;
            IsTitleModalLoading = false;
            return;
        }
        try
        {
            ModalTitleDetail = await ApiClient.GetCatalogTitleAsync(title.StudioSlug, title.Slug);
            if (ModalTitleDetail is not null)
            {
                TitleDetailCache[cacheKey] = ModalTitleDetail;
            }
        }
        catch (Exception exception)
        {
            TitleModalError = exception.Message;
        }
        finally
        {
            IsTitleModalLoading = false;
        }
    }

    private void CloseTitleModal()
    {
        ModalTitleSummary = null;
        ModalTitleDetail = null;
        TitleModalError = null;
        IsTitleModalLoading = false;
    }

    private string GetStudioDisplayName(string studioSlug) => StudioDisplayNameBySlug.TryGetValue(studioSlug, out var displayName) ? displayName : studioSlug;

    private static IReadOnlyList<string> ParseCsv(string? input) => string.IsNullOrWhiteSpace(input) ? [] : input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Where(candidate => !string.IsNullOrWhiteSpace(candidate)).Distinct(StringComparer.OrdinalIgnoreCase).ToArray();
    private static string FormatContentKind(string? contentKind) => string.Equals(contentKind, "app", StringComparison.OrdinalIgnoreCase) ? "App" : "Game";
    private static string BuildTitleCacheKey(string studioSlug, string titleSlug) => $"{studioSlug}/{titleSlug}";
    private static string NormalizeResultsPerPageInput(string? value) => string.Equals(value, "all", StringComparison.OrdinalIgnoreCase) ? "all" : NormalizeResultsPerPage(value).ToString();
    private static int NormalizeResultsPerPage(string? value) => (value ?? "10").Trim().ToLowerInvariant() switch { "25" => 25, "50" => 50, "all" => 0, _ => 10 };

    private static string GetCardStyle(CatalogTitleSummary? title) => string.IsNullOrWhiteSpace(title?.CardImageUrl) ? $"background-image:{GetFallbackGradient(title?.GenreDisplay)};" : $"background-image:linear-gradient(180deg, rgba(7,9,14,0.02), rgba(7,9,14,0.30)), url('{title.CardImageUrl}');";

    private static string GetModalHeroStyle(CatalogTitle? title)
    {
        var heroUrl = title?.MediaAssets.FirstOrDefault(asset => string.Equals(asset.MediaRole, "hero", StringComparison.OrdinalIgnoreCase))?.SourceUrl ?? title?.CardImageUrl;
        return string.IsNullOrWhiteSpace(heroUrl) ? $"background-image:{GetFallbackGradient(title?.GenreDisplay)};" : $"background-image:linear-gradient(135deg, rgba(4,19,29,0.16), rgba(4,19,29,0.58)), url('{heroUrl}');";
    }

    private static string GetFallbackGradient(string? genreDisplay)
    {
        var primaryGenre = BrowseCatalogProjectionService.ParseGenreTags(genreDisplay).FirstOrDefault();
        return primaryGenre switch
        {
            "Shooter" => "linear-gradient(135deg, #f8fafc, #7dd3fc, #1d4ed8)",
            "Adventure" => "linear-gradient(135deg, #fde68a, #fb7185, #7c3aed)",
            "Puzzle" => "linear-gradient(135deg, #d8f3dc, #60a5fa, #1e293b)",
            _ => "linear-gradient(135deg, #fef3c7, #f97316, #334155)"
        };
    }
}
