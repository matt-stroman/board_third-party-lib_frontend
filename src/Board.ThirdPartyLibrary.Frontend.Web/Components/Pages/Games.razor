@page "/games"

@inject IBoardLibraryApiClient ApiClient
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Games</PageTitle>

<section class="space-y-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="space-y-3">
            <h1 class="app-page-title">Games</h1>
            <p class="max-w-3xl text-base leading-8 text-slate-300">
                Browse the live public catalog with a Board-inspired hero spotlight, paging metadata, and low-hit query controls backed by the current API contract.
            </p>
            <AuthorizeView>
                <Authorized>
                    <div class="flex flex-wrap gap-3">
                        <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/player/games">Open my games</a>
                        <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/player/wishlist">Open wishlist</a>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
        @if (Catalog is not null)
        {
            <div class="app-panel flex flex-wrap gap-3 p-4 text-sm">
                <span class="app-chip">Kind: @EffectiveContentKindLabel</span>
                <span class="app-chip">Genre: @(string.IsNullOrWhiteSpace(Genre) ? "All" : Genre)</span>
                <span class="app-chip">Sort: @EffectiveSortLabel</span>
                <span class="app-chip">Page @Catalog.Paging.PageNumber of @(Math.Max(Catalog.Paging.TotalPages, 1))</span>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Library unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (Catalog is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-48 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-56 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (SpotlightTitle is null)
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">No titles match the current browse settings</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">
                Try clearing the genre filter or switching sort mode. The public catalog currently returns @Catalog.Paging.TotalCount matched titles.
            </p>
        </section>
    }
    else
    {
        <section class="app-panel grid gap-6 overflow-hidden p-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
            <div class="space-y-5">
                <div class="flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100/75">
                    <span class="app-chip">@SpotlightTitle.PlayerCountDisplay</span>
                    <span class="app-chip">@SpotlightTitle.GenreDisplay</span>
                    <span class="app-chip">@SpotlightTitle.AgeDisplay</span>
                </div>
                <div>
                    <div class="text-sm uppercase tracking-[0.28em] text-cyan-100/70">Spotlighted title</div>
                    <h2 class="mt-2 font-['Aptos_Display','Trebuchet_MS',sans-serif] text-5xl font-black uppercase tracking-[0.08em] text-white">@SpotlightTitle.DisplayName</h2>
                </div>
                <p class="max-w-xl text-base leading-8 text-slate-300">
                    @SpotlightTitle.ShortDescription
                </p>
                <div class="flex flex-col gap-3 sm:flex-row">
                    <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@($"/games/{SpotlightTitle.OrganizationSlug}/{SpotlightTitle.Slug}")">Open details</a>
                    @if (!string.IsNullOrWhiteSpace(SpotlightTitle.AcquisitionUrl))
                    {
                        <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@SpotlightTitle.AcquisitionUrl" target="_blank" rel="noreferrer">View acquisition</a>
                    }
                </div>
            </div>
            <div class="min-h-[320px] rounded-[1.75rem] bg-cover bg-center shadow-[inset_0_1px_0_rgba(255,255,255,0.6)] @SpotlightFallbackGradient" style="@SpotlightBackgroundStyle"></div>
        </section>

        <section class="space-y-4">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h2 class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold uppercase tracking-[0.08em] text-white">Title rail</h2>
                    <div class="mt-1 text-sm text-slate-400">
                        @Catalog.Paging.TotalCount matched titles. Page size is fixed to @Catalog.Paging.PageSize for the current MVP rail.
                    </div>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a class="app-chip" href="@BuildLibraryHref(sort: "genre")">Sort by genre</a>
                    <a class="app-chip" href="@BuildLibraryHref(sort: "title")">Sort by title</a>
                    <a class="app-chip" href="@BuildLibraryHref(genre: "Arcade Shooter")">Arcade Shooter</a>
                    <a class="app-chip" href="@BuildLibraryHref(clearGenre: true)">Clear genre</a>
                </div>
            </div>
            <div class="app-card-rail">
                @foreach (var title in Catalog.Titles)
                {
                    <a class="app-panel min-h-52 p-4 transition hover:-translate-y-1 hover:border-cyan-300/35" href="@($"/games/{title.OrganizationSlug}/{title.Slug}")">
                        <div class="h-28 rounded-[1.25rem] bg-cover bg-center @GetCardFallbackGradient(title)" style="@GetCardStyle(title)"></div>
                        <div class="mt-4 text-xs uppercase tracking-[0.22em] text-cyan-100/75">@title.GenreDisplay</div>
                        <div class="mt-2 font-semibold text-white">@title.DisplayName</div>
                        <div class="mt-2 text-sm text-slate-300">@title.PlayerCountDisplay</div>
                    </a>
                }
            </div>

            <div class="flex items-center justify-between">
                <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/35 @(Catalog.Paging.HasPreviousPage ? string.Empty : "pointer-events-none opacity-40")" href="@BuildLibraryHref(pageNumber: Math.Max(1, Catalog.Paging.PageNumber - 1))">Previous</a>
                <div class="text-sm text-slate-400">Showing page @Catalog.Paging.PageNumber of @(Math.Max(Catalog.Paging.TotalPages, 1))</div>
                <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/35 @(Catalog.Paging.HasNextPage ? string.Empty : "pointer-events-none opacity-40")" href="@BuildLibraryHref(pageNumber: Catalog.Paging.PageNumber + 1)">Next</a>
            </div>
        </section>
    }
</section>

@code {
    private const int PageSize = 12;

    [SupplyParameterFromQuery]
    public string? Genre { get; set; }

    [SupplyParameterFromQuery]
    public string? ContentKind { get; set; }

    [SupplyParameterFromQuery]
    public string? Sort { get; set; }

    [SupplyParameterFromQuery]
    public int? PageNumber { get; set; }

    private CatalogTitleListResponse? Catalog { get; set; }

    private CatalogTitleSummary? SpotlightTitle => Catalog?.Titles.FirstOrDefault();

    private string? ErrorMessage { get; set; }

    private string EffectiveContentKind => string.IsNullOrWhiteSpace(ContentKind) ? "game" : ContentKind.Trim().ToLowerInvariant();

    private string EffectiveContentKindLabel => string.Equals(EffectiveContentKind, "app", StringComparison.Ordinal) ? "Apps" : "Games";

    private string EffectiveSort => string.Equals(Sort, "title", StringComparison.OrdinalIgnoreCase) ? "title" : "genre";

    private string EffectiveSortLabel => string.Equals(EffectiveSort, "title", StringComparison.Ordinal) ? "Title" : "Genre";

    private string SpotlightBackgroundStyle => string.IsNullOrWhiteSpace(SpotlightTitle?.CardImageUrl)
        ? string.Empty
        : $"background-image:linear-gradient(135deg, rgba(4,19,29,0.18), rgba(4,19,29,0.48)), url('{SpotlightTitle.CardImageUrl}');";

    private string SpotlightFallbackGradient => GetCardFallbackGradient(SpotlightTitle);

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;

        try
        {
            Catalog = await ApiClient.GetCatalogTitlesAsync(
                new CatalogBrowseRequest(
                    OrganizationSlug: null,
                    ContentKind: EffectiveContentKind,
                    Genre: string.IsNullOrWhiteSpace(Genre) ? null : Genre.Trim(),
                    Sort: EffectiveSort,
                    PageNumber: PageNumber is > 0 ? PageNumber.Value : 1,
                    PageSize: PageSize));
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            Catalog = null;
        }
    }

    private string BuildLibraryHref(string? genre = null, string? sort = null, int? pageNumber = null, bool clearGenre = false)
    {
        var query = new Dictionary<string, string?>(StringComparer.Ordinal)
        {
            ["contentKind"] = EffectiveContentKind,
            ["sort"] = sort ?? EffectiveSort,
            ["pageNumber"] = (pageNumber ?? 1).ToString()
        };

        var effectiveGenre = clearGenre ? null : genre ?? Genre;
        if (!string.IsNullOrWhiteSpace(effectiveGenre))
        {
            query["genre"] = effectiveGenre;
        }

        return QueryHelpers.AddQueryString("/games", query);
    }

    private static string GetCardStyle(CatalogTitleSummary? title) =>
        string.IsNullOrWhiteSpace(title?.CardImageUrl)
            ? string.Empty
            : $"background-image:linear-gradient(135deg, rgba(4,19,29,0.1), rgba(4,19,29,0.4)), url('{title.CardImageUrl}');";

    private static string GetCardFallbackGradient(CatalogTitleSummary? title) =>
        title?.GenreDisplay switch
        {
            "Arcade Shooter" => "bg-[linear-gradient(135deg,_#f8fafc,_#7dd3fc,_#1d4ed8)]",
            "Adventure" => "bg-[linear-gradient(135deg,_#fde68a,_#fb7185,_#7c3aed)]",
            "Puzzle" => "bg-[linear-gradient(135deg,_#d8f3dc,_#60a5fa,_#1e293b)]",
            _ => "bg-[linear-gradient(135deg,_#fef3c7,_#f97316,_#334155)]"
        };
}
