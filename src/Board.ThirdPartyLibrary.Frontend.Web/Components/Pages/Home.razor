@page "/"

<PageTitle>Board Enthusiasts</PageTitle>

<section class="grid gap-8">
    <div class="space-y-6">
        <div>
            <h1 class="font-display text-5xl font-black uppercase leading-[0.93] tracking-[0.03em] text-white sm:text-6xl">
                Discover new games for Board
            </h1>
            <p class="text-lg leading-8 text-[#ece3d5]">
                Browse games created by the Board community.
            </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
            <AuthorizeView>
                <Authorized>
                    <a class="inline-flex items-center justify-center rounded-full bg-cyan-300 px-6 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 transition hover:bg-cyan-200" href="/player">Open play area</a>
                    <a class="inline-flex items-center justify-center rounded-full border border-white/15 px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100 transition hover:border-cyan-300/50 hover:text-cyan-100" href="/browse">Browse</a>
                </Authorized>
                <NotAuthorized>
                    <a class="inline-flex items-center justify-center rounded-full bg-cyan-300 px-6 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 transition hover:bg-cyan-200" href="/browse">Browse</a>
                    <a class="inline-flex items-center justify-center rounded-full border border-white/15 px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100 transition hover:border-cyan-300/50 hover:text-cyan-100" href="/auth/signin?returnUrl=%2Fplayer" data-enhance-nav="false">Sign In</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</section>

<section class="mt-10 grid gap-6 lg:grid-cols-3">
    <a class="app-panel p-6 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/browse">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">Public</div>
        <h2 class="mt-3 font-display text-2xl font-bold text-white">Browse</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">Find new games by genre, player count, and developer.</p>
    </a>
    <a class="app-panel p-6 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/player">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">Players</div>
        <h2 class="mt-3 font-display text-2xl font-bold text-white">Play</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">Keep your library and wishlist in one place.</p>
    </a>
    <a class="app-panel p-6 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/develop">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">Developers</div>
        <h2 class="mt-3 font-display text-2xl font-bold text-white">Developer access</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">Set up your studio and manage titles in the developer console.</p>
    </a>
</section>
