@page "/"

<PageTitle>Board Third Party Library</PageTitle>

<section class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
    <div class="space-y-6">
        <div class="inline-flex items-center rounded-full border border-cyan-200/20 bg-white/8 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-100/80">
            Browser MVP for the current Wave 5 vertical slice
        </div>
        <div class="space-y-4">
            <h1 class="max-w-3xl font-['Aptos_Display','Trebuchet_MS',sans-serif] text-5xl font-black uppercase leading-[0.95] tracking-[0.06em] text-white sm:text-6xl">
                Discover Board games built beyond first party.
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-slate-300">
                Browse third party releases, explore developer organizations, and give developers a clean place to manage titles, media, releases, and external acquisition links.
            </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
            <a class="inline-flex items-center justify-center rounded-full bg-cyan-300 px-6 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 transition hover:bg-cyan-200" href="/library">Browse library</a>
            <a class="inline-flex items-center justify-center rounded-full border border-white/15 px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100 transition hover:border-cyan-300/50 hover:text-cyan-100" href="/develop">Open developer console</a>
        </div>
    </div>

    <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-[linear-gradient(140deg,_rgba(240,248,255,0.94),_rgba(224,250,255,0.82)_38%,_rgba(255,209,102,0.36)_100%)] p-6 text-slate-950 shadow-[0_30px_80px_rgba(3,8,18,0.42)]">
        <div class="absolute inset-y-0 right-0 w-2/3 bg-[radial-gradient(circle_at_top,_rgba(255,0,128,0.24),_transparent_34%),radial-gradient(circle_at_bottom,_rgba(0,168,232,0.22),_transparent_42%)]"></div>
        <div class="relative space-y-5">
            <div class="inline-flex rounded-full bg-slate-950/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-slate-700">
                Featured rail direction
            </div>
            <div class="space-y-2">
                <div class="text-xs font-bold uppercase tracking-[0.24em] text-slate-700/80">1-4 players • Arcade • Ages 10+</div>
                <div class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-4xl font-black uppercase tracking-[0.08em]">Star Blasters</div>
                <p class="max-w-md text-sm leading-7 text-slate-700">
                    The first public browse surface should keep the dramatic Board-like hero and card rail on larger screens, then collapse gracefully on mobile.
                </p>
            </div>
            <div class="grid gap-3 sm:grid-cols-4">
                <div class="rounded-[1.3rem] border border-white/50 bg-[linear-gradient(160deg,_#0f172a,_#1d4ed8)] p-4 text-white shadow-lg">
                    <div class="text-xs uppercase tracking-[0.24em] text-cyan-100/80">Action</div>
                    <div class="mt-10 font-semibold">Play now</div>
                </div>
                <div class="rounded-[1.3rem] bg-[linear-gradient(160deg,_#f8fafc,_#dbeafe)] p-4 text-slate-800 shadow-lg">
                    <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Rail</div>
                    <div class="mt-10 font-semibold">Card 01</div>
                </div>
                <div class="rounded-[1.3rem] bg-[linear-gradient(160deg,_#fef3c7,_#f97316)] p-4 text-slate-900 shadow-lg">
                    <div class="text-xs uppercase tracking-[0.24em] text-slate-700">Rail</div>
                    <div class="mt-10 font-semibold">Card 02</div>
                </div>
                <div class="rounded-[1.3rem] bg-[linear-gradient(160deg,_#f5d0fe,_#7c3aed)] p-4 text-white shadow-lg">
                    <div class="text-xs uppercase tracking-[0.24em] text-fuchsia-100/80">Rail</div>
                    <div class="mt-10 font-semibold">Card 03</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mt-10 grid gap-6 lg:grid-cols-3">
    <a class="app-panel p-6 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/library">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">Players</div>
        <h2 class="mt-3 font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold text-white">Library browse</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">Board-inspired hero spotlight, title rail, mobile-first collapse, and direct organization/title routes.</p>
    </a>
    <a class="app-panel p-6 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/develop">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">Developers</div>
        <h2 class="mt-3 font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold text-white">Workspace shell</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">Organization switcher, title workspaces, media slots, release management, and acquisition setup.</p>
    </a>
    <a class="app-panel p-6 transition hover:-translate-y-0.5 hover:border-cyan-300/35" href="/account">
        <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">Identity</div>
        <h2 class="mt-3 font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold text-white">Account area</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">Current-user summary, Board profile linkage, and server-mediated sign-in and sign-out entry points.</p>
    </a>
</section>
