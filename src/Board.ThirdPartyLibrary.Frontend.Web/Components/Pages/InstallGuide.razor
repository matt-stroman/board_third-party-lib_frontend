@page "/install-guide"

<PageTitle>Install Guide</PageTitle>

<section class="space-y-8">
    <div class="space-y-3">
        <h1 class="app-page-title">Install Guide</h1>
        <p class="max-w-3xl text-base leading-8 text-slate-300">
            Follow these steps to install independent games on Board.
        </p>
    </div>

    <section class="grid gap-6 lg:grid-cols-3">
        <section class="app-panel p-6">
            <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">1. Get the files</div>
            <h2 class="mt-3 font-display text-2xl font-bold text-white">Download game files</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">
                Get the APK or install package from the developer or publisher.
            </p>
        </section>
        <section class="app-panel p-6">
            <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">2. Connect your device</div>
            <h2 class="mt-3 font-display text-2xl font-bold text-white">Prepare Board and your computer</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">
                Connect Board and your computer, then enable any required device settings.
            </p>
        </section>
        <section class="app-panel p-6">
            <div class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100/75">3. Finish the install</div>
            <h2 class="mt-3 font-display text-2xl font-bold text-white">Verify and launch</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">
                Confirm installation completed successfully, then launch on Board.
            </p>
        </section>
    </section>
</section>
