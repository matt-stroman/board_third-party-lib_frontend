@page "/moderate"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Moderation Console</PageTitle>

<section class="app-workspace-shell space-y-6">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Moderation unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CurrentUser is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-40 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!IsModerator)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Moderation access unavailable</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                This area is available only to users with the moderator role.
            </p>
        </section>
    }
    else
    {
        <section class="w-full space-y-4">
            <div>
                <h1 class="app-page-title">Moderate</h1>
                <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                    Manage moderation tools.
                </p>
            </div>

            <section class="app-panel w-full p-4">
                <div class="flex flex-wrap gap-2">
                    <button class="rounded-full bg-cyan-300 px-4 py-2 text-sm font-semibold uppercase tracking-[0.14em] text-slate-950" type="button">Developers</button>
                </div>
            </section>

            <section class="app-workspace-grid">
                <aside class="app-panel p-4">
                    <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">Workflow</div>
                    <nav class="mt-3 space-y-2">
                        <button class="w-full rounded-[0.9rem] border border-cyan-300/45 bg-cyan-300/15 px-3 py-2 text-left text-sm text-cyan-50" type="button">Verified Developer Access</button>
                    </nav>
                </aside>

                <section class="app-panel app-workspace-main p-6">
                    <h2 class="text-2xl font-semibold text-white">Verified Developer Role</h2>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                        Grant or remove the <code class="rounded bg-black/30 px-2 py-1 text-cyan-100">verified_developer</code> role for a developer account.
                    </p>

                    @if (!string.IsNullOrWhiteSpace(StatusMessage))
                    {
                        <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
                    }

                    <div class="mt-6 grid gap-4 sm:grid-cols-2">
                        <label class="text-sm text-slate-300 sm:col-span-2">Developer ID
                            <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                   @bind="DeveloperSubject"
                                   placeholder="user-id" />
                        </label>
                    </div>

                    <div class="mt-6 flex flex-wrap gap-3">
                        <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60"
                                type="button"
                                @onclick="GrantVerifiedDeveloperAsync"
                                disabled="@IsMutating">
                            @(IsMutating ? "Updating..." : "Grant Verified Developer")
                        </button>
                        <button class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60"
                                type="button"
                                @onclick="RevokeVerifiedDeveloperAsync"
                                disabled="@IsMutating">
                            @(IsMutating ? "Updating..." : "Remove Verified Developer")
                        </button>
                    </div>
                </section>
            </section>
        </section>
    }
</section>

@code {
    private CurrentUserResponse? CurrentUser { get; set; }

    private bool IsMutating { get; set; }

    private string? DeveloperSubject { get; set; }

    private string? ErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    private bool IsModerator => CurrentUser.HasRole("moderator");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }

    private async Task GrantVerifiedDeveloperAsync() => await MutateVerifiedDeveloperAsync(grant: true);

    private async Task RevokeVerifiedDeveloperAsync() => await MutateVerifiedDeveloperAsync(grant: false);

    private async Task MutateVerifiedDeveloperAsync(bool grant)
    {
        if (IsMutating)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(DeveloperSubject))
        {
            ErrorMessage = "Developer ID is required.";
            StatusMessage = null;
            return;
        }

        ErrorMessage = null;
        StatusMessage = null;
        IsMutating = true;

        try
        {
            var response = grant
                ? await ApiClient.GrantVerifiedDeveloperRoleAsync(DeveloperSubject.Trim())
                : await ApiClient.RevokeVerifiedDeveloperRoleAsync(DeveloperSubject.Trim());

            var state = response.VerifiedDeveloperRoleState;
            var action = state.VerifiedDeveloper ? "granted" : "removed";
            var already = state.AlreadyInRequestedState ? " (already in requested state)" : string.Empty;
            StatusMessage = $"Verified developer role {action} for {state.DeveloperSubject}{already}.";
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsMutating = false;
        }
    }
}
