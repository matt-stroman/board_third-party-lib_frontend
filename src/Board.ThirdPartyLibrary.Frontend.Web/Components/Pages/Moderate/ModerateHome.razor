@page "/moderate"
@attribute [Authorize]
@using System.Net
@using Microsoft.AspNetCore.WebUtilities
@inject IBoardLibraryApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Moderation Console</PageTitle>

<section class="app-workspace-shell space-y-6">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Moderation unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CurrentUser is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-40 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!IsModerator)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Moderation access unavailable</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                This area is only available to moderation team members.
            </p>
        </section>
    }
    else
    {
        <section class="app-workspace-content">
            <div>
                <h1 class="app-page-title">Moderate</h1>
                <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                    Review developer verification and reported titles.
                </p>
            </div>

            <section class="app-panel w-full p-4">
                <div class="flex flex-wrap gap-2">
                    <button class="@GetWorkflowButtonClass("developers-verify", true)" type="button" @onclick='() => SelectWorkflowAsync("developers-verify")'>Developers</button>
                    <button class="@GetWorkflowButtonClass("reports-review", true)" type="button" @onclick='() => SelectWorkflowAsync("reports-review")'>Reported Titles</button>
                </div>
            </section>

            <section class="app-workspace-grid">
                <aside class="app-panel p-4">
                    <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">Workflow</div>
                    <nav class="mt-3 space-y-2">
                        <button class="@GetWorkflowButtonClass("developers-verify", false)" type="button" @onclick='() => SelectWorkflowAsync("developers-verify")'>Verify Developers</button>
                        <button class="@GetWorkflowButtonClass("reports-review", false)" type="button" @onclick='() => SelectWorkflowAsync("reports-review")'>Reported Titles</button>
                    </nav>
                </aside>

                <section class="app-panel app-workspace-main p-6">
                    @if (ActiveWorkflow == "developers-verify")
                    {
                    <h2 class="text-2xl font-semibold text-white">Verify Developers</h2>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                        Find a developer account and set whether the account is verified.
                    </p>

                    @if (!string.IsNullOrWhiteSpace(StatusMessage))
                    {
                        <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(WorkflowErrorMessage))
                    {
                        <div class="mt-4 rounded-[1rem] border border-rose-300/35 bg-rose-400/10 px-4 py-3 text-sm text-rose-100">@WorkflowErrorMessage</div>
                    }

                    <div class="mt-6 space-y-4">
                        <label class="block text-sm text-slate-300">
                            Search developers
                            <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                   @bind="DeveloperFilterQuery"
                                   @bind:event="oninput"
                                   placeholder="Search by username, display name, or email" />
                        </label>

                        <label class="block text-sm text-slate-300">
                            Developer
                            <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-3 py-3 text-slate-100"
                                    @onchange="OnDeveloperSelectionChanged"
                                    disabled="@IsLoadingDevelopers">
                                <option value="">Select a developer...</option>
                                @foreach (var developer in GetFilteredDevelopers())
                                {
                                    var identifier = BuildDeveloperIdentifier(developer);
                                    <option value="@identifier" selected="@(identifier == SelectedDeveloperIdentifier)">
                                        @FormatDeveloperOption(developer)
                                    </option>
                                }
                            </select>
                        </label>

                        @if (IsLoadingDevelopers)
                        {
                            <p class="text-sm text-slate-300">Loading developer list...</p>
                        }
                        else if (!Developers.Any())
                        {
                            <p class="text-sm text-slate-300">No users are available yet.</p>
                        }
                        else if (!GetFilteredDevelopers().Any())
                        {
                            <p class="text-sm text-slate-300">No users match that search.</p>
                        }
                    </div>

                    <div class="mt-6 rounded-[1rem] border border-white/10 bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Selected account</div>
                        @if (SelectedDeveloper is null)
                        {
                            <p class="mt-2 text-sm text-slate-300">Select a developer to manage verification.</p>
                        }
                        else
                        {
                            <p class="mt-2 text-lg font-semibold text-white">@FormatDeveloperHeading(SelectedDeveloper)</p>
                            @if (!string.IsNullOrWhiteSpace(SelectedDeveloper.Email))
                            {
                                <p class="mt-1 text-sm text-slate-300">@SelectedDeveloper.Email</p>
                            }
                            <p class="mt-4 text-sm text-slate-200">
                                Verification status:
                                <span class="font-semibold text-white">@(SelectedVerificationState ? "Verified" : "Not verified")</span>
                            </p>
                        }
                    </div>

                    <div class="mt-6 flex flex-wrap items-center gap-3">
                        <label class="inline-flex items-center gap-3 rounded-full border border-white/15 px-4 py-2 text-sm text-slate-100">
                            <span class="font-semibold uppercase tracking-[0.14em]">Verified</span>
                            <input class="h-5 w-5 accent-cyan-300"
                                   type="checkbox"
                                   checked="@SelectedVerificationState"
                                   @onchange="OnVerificationToggleChanged"
                                   disabled="@(!CanMutateVerification)" />
                        </label>
                        @if (IsLoadingVerificationState)
                        {
                            <span class="text-sm text-slate-300">Checking current status...</span>
                        }
                        else if (IsMutating)
                        {
                            <span class="text-sm text-slate-300">Updating verification...</span>
                        }
                    </div>
                    }
                    else
                    {
                        <h2 class="text-2xl font-semibold text-white">Reported Titles</h2>
                        <p class="mt-3 text-sm leading-7 text-slate-300">
                            Review reports, message the developer, and resolve moderation decisions.
                        </p>

                        @if (!string.IsNullOrWhiteSpace(ReportStatusMessage))
                        {
                            <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@ReportStatusMessage</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(ReportWorkflowErrorMessage))
                        {
                            <div class="mt-4 rounded-[1rem] border border-rose-300/35 bg-rose-400/10 px-4 py-3 text-sm text-rose-100">@ReportWorkflowErrorMessage</div>
                        }

                        <div class="mt-6 grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
                            <div class="space-y-4">
                                <label class="block text-sm text-slate-300">
                                    Search reported titles
                                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                           @bind="TitleReportFilterQuery"
                                           @bind:event="oninput"
                                           placeholder="Search by title, studio, reporter, or reason" />
                                </label>

                                @if (IsLoadingTitleReports)
                                {
                                    <p class="text-sm text-slate-300">Loading reports...</p>
                                }
                                else if (!GetFilteredTitleReports().Any())
                                {
                                    <p class="text-sm text-slate-300">No reports match the current search.</p>
                                }
                                else
                                {
                                    <div class="space-y-3">
                                        @foreach (var report in GetFilteredTitleReports())
                                        {
                                            var isSelected = report.Id == SelectedTitleReportId;
                                            <button class="w-full rounded-[1.1rem] border px-4 py-4 text-left transition @(isSelected ? "border-cyan-300/45 bg-cyan-300/10 text-cyan-50" : "border-white/10 bg-black/15 text-slate-100 hover:border-cyan-300/35")"
                                                    type="button"
                                                    @onclick="() => SelectTitleReportAsync(report.Id)">
                                                <div class="flex flex-wrap items-center justify-between gap-3">
                                                    <div class="text-sm font-semibold text-white">@report.TitleDisplayName</div>
                                                    <div class="text-[0.65rem] uppercase tracking-[0.16em] text-cyan-100/75">@report.Status</div>
                                                </div>
                                                <div class="mt-2 text-xs uppercase tracking-[0.16em] text-slate-400">@report.StudioDisplayName</div>
                                                <p class="mt-3 text-sm leading-6 text-slate-300">@report.Reason</p>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="rounded-[1.25rem] border border-white/10 bg-black/15 p-5">
                                @if (SelectedTitleReportDetail is null)
                                {
                                    <div class="text-sm text-slate-300">Select a report to review its thread and moderation actions.</div>
                                }
                                else
                                {
                                    <div class="flex flex-wrap items-start justify-between gap-4">
                                        <div>
                                            <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">@SelectedTitleReportDetail.Report.Status</div>
                                            <h3 class="mt-2 text-2xl font-semibold text-white">@SelectedTitleReportDetail.Report.TitleDisplayName</h3>
                                            <div class="mt-2 text-sm text-slate-300">@SelectedTitleReportDetail.Report.StudioDisplayName</div>
                                        </div>
                                        <a class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100"
                                           href="@($"/browse/{SelectedTitleReportDetail.Report.StudioSlug}/{SelectedTitleReportDetail.Report.TitleSlug}")">
                                            Open public page
                                        </a>
                                    </div>

                                    <div class="mt-5 grid gap-4 md:grid-cols-2">
                                        <div class="rounded-[1rem] border border-white/10 bg-slate-950/40 p-4">
                                            <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Report reason</div>
                                            <p class="mt-2 text-sm leading-7 text-slate-300">@SelectedTitleReportDetail.Report.Reason</p>
                                        </div>
                                        <div class="rounded-[1rem] border border-white/10 bg-slate-950/40 p-4">
                                            <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Resolution note</div>
                                            <p class="mt-2 text-sm leading-7 text-slate-300">@(string.IsNullOrWhiteSpace(SelectedTitleReportDetail.ResolutionNote) ? "No resolution note yet." : SelectedTitleReportDetail.ResolutionNote)</p>
                                        </div>
                                    </div>

                                    <div class="mt-5">
                                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Thread</div>
                                        <div class="mt-3 space-y-3">
                                            @if (SelectedTitleReportDetail.Messages.Count == 0)
                                            {
                                                <div class="rounded-[1rem] border border-white/10 bg-slate-950/35 px-4 py-3 text-sm text-slate-300">No thread messages yet.</div>
                                            }
                                            else
                                            {
                                                @foreach (var message in SelectedTitleReportDetail.Messages.OrderBy(candidate => candidate.CreatedAt))
                                                {
                                                    <section class="rounded-[1rem] border border-white/10 bg-slate-950/35 px-4 py-3">
                                                        <div class="flex flex-wrap items-center justify-between gap-3">
                                                            <div class="text-sm font-semibold text-white">@FormatReportActorName(message.AuthorDisplayName, message.AuthorUserName, message.AuthorEmail, message.AuthorSubject)</div>
                                                            <div class="flex flex-wrap items-center gap-2 text-[0.65rem] uppercase tracking-[0.16em]">
                                                                <span class="text-cyan-100/70">@message.AuthorRole</span>
                                                                <span class="rounded-full border border-white/10 px-2 py-1 text-slate-300">@FormatReportAudience(message.Audience)</span>
                                                            </div>
                                                        </div>
                                                        <div class="mt-2 text-xs uppercase tracking-[0.16em] text-slate-500">@FormatTimestamp(message.CreatedAt)</div>
                                                        <p class="mt-3 text-sm leading-7 text-slate-300">@message.Message</p>
                                                    </section>
                                                }
                                            }
                                        </div>
                                    </div>

                                    @if (CanSendModeratorMessage)
                                    {
                                        <label class="mt-5 block text-sm text-slate-300">
                                            Message recipient
                                            <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                                    @bind="TitleReportRecipientRole">
                                                <option value="developer">Developer</option>
                                                <option value="player">Reporting player</option>
                                            </select>
                                        </label>

                                        <label class="mt-5 block text-sm text-slate-300">
                                            Moderator reply
                                            <textarea class="mt-2 min-h-28 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                                      @bind="TitleReportReplyDraft"
                                                      @bind:event="oninput"
                                                      placeholder="@GetModeratorReplyPlaceholder()"></textarea>
                                        </label>
                                    }

                                    <label class="mt-4 block text-sm text-slate-300">
                                        Resolution note
                                        <textarea class="mt-2 min-h-24 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                                  @bind="TitleReportResolutionNote"
                                                  @bind:event="oninput"
                                                  placeholder="Optional note for the final moderation decision."></textarea>
                                    </label>

                                    <div class="mt-6 flex flex-wrap gap-3">
                                        @if (CanSendModeratorMessage)
                                        {
                                            <button class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-slate-100 disabled:cursor-not-allowed disabled:opacity-60"
                                                    type="button"
                                                    @onclick="SendModeratorReportMessageAsync"
                                                    disabled="@(IsMutatingTitleReports || string.IsNullOrWhiteSpace(TitleReportReplyDraft))">
                                                @(IsMutatingTitleReports ? "Sending..." : "Send message")
                                            </button>
                                        }
                                        @if (CanResolveSelectedTitleReport)
                                        {
                                            <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60"
                                                    type="button"
                                                    @onclick="ValidateSelectedTitleReportAsync"
                                                    disabled="@IsMutatingTitleReports">
                                                Validate report
                                            </button>
                                            <button class="rounded-full border border-rose-300/40 px-5 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60"
                                                    type="button"
                                                    @onclick="InvalidateSelectedTitleReportAsync"
                                                    disabled="@IsMutatingTitleReports">
                                                Invalidate report
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </section>
            </section>
        </section>
    }
</section>

@code {
    private readonly List<ModerationDeveloperSummary> Developers = [];

    private CurrentUserResponse? CurrentUser { get; set; }

    private ModerationDeveloperSummary? SelectedDeveloper { get; set; }

    private string? SelectedDeveloperIdentifier { get; set; }

    private string DeveloperFilterQuery { get; set; } = string.Empty;
    private string ActiveWorkflow { get; set; } = "developers-verify";

    private bool SelectedVerificationState { get; set; }

    private bool IsLoadingDevelopers { get; set; }

    private bool IsLoadingVerificationState { get; set; }

    private bool IsMutating { get; set; }
    private readonly List<TitleReportSummary> TitleReports = [];
    private readonly Dictionary<Guid, TitleReportDetail> TitleReportDetails = [];
    private Guid? SelectedTitleReportId { get; set; }
    private bool IsLoadingTitleReports { get; set; }
    private bool IsMutatingTitleReports { get; set; }
    private string TitleReportFilterQuery { get; set; } = string.Empty;
    private string TitleReportReplyDraft { get; set; } = string.Empty;
    private string TitleReportRecipientRole { get; set; } = "developer";
    private string TitleReportResolutionNote { get; set; } = string.Empty;
    private bool HasAppliedInitialRouteState { get; set; }
    private string? RequestedWorkflow { get; set; }
    private Guid? RequestedTitleReportId { get; set; }
    private string? ReportWorkflowErrorMessage { get; set; }
    private string? ReportStatusMessage { get; set; }

    private string? ErrorMessage { get; set; }

    private string? WorkflowErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    private bool IsModerator => CurrentUser.HasRole("moderator");

    private bool CanMutateVerification =>
        SelectedDeveloper is not null &&
        !IsLoadingVerificationState &&
        !IsMutating;

    private TitleReportDetail? SelectedTitleReportDetail =>
        SelectedTitleReportId is not null && TitleReportDetails.TryGetValue(SelectedTitleReportId.Value, out var detail)
            ? detail
            : null;
    private bool CanResolveSelectedTitleReport =>
        SelectedTitleReportDetail is not null &&
        SelectedTitleReportDetail.Report.Status is not "validated" and not "invalidated";
    private bool CanSendModeratorMessage => CanResolveSelectedTitleReport;

    protected override async Task OnInitializedAsync()
    {
        CaptureRequestedRouteState();
        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            if (CurrentUser is not null && IsModerator)
            {
                await LoadDevelopersAsync();
                await LoadTitleReportsAsync();
                await ApplyRequestedRouteStateAsync();
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }

    private async Task LoadDevelopersAsync()
    {
        IsLoadingDevelopers = true;
        WorkflowErrorMessage = null;

        try
        {
            var response = await ApiClient.GetModerationDevelopersAsync();
            Developers.Clear();
            Developers.AddRange(
                response.Developers
                    .OrderBy(candidate => candidate.UserName ?? candidate.DisplayName ?? candidate.Email ?? candidate.DeveloperSubject, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(candidate => candidate.DeveloperSubject, StringComparer.Ordinal));
        }
        catch (Exception exception)
        {
            WorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsLoadingDevelopers = false;
        }
    }

    private async Task OnDeveloperSelectionChanged(ChangeEventArgs args)
    {
        var identifier = args.Value?.ToString();
        SelectedDeveloper = Developers.FirstOrDefault(candidate =>
            string.Equals(BuildDeveloperIdentifier(candidate), identifier, StringComparison.Ordinal));
        SelectedDeveloperIdentifier = SelectedDeveloper is null
            ? null
            : BuildDeveloperIdentifier(SelectedDeveloper);
        WorkflowErrorMessage = null;
        StatusMessage = null;

        if (SelectedDeveloper is null || string.IsNullOrWhiteSpace(SelectedDeveloperIdentifier))
        {
            SelectedVerificationState = false;
            return;
        }

        await LoadSelectedDeveloperVerificationAsync();
    }

    private async Task LoadSelectedDeveloperVerificationAsync()
    {
        if (SelectedDeveloper is null || string.IsNullOrWhiteSpace(SelectedDeveloperIdentifier))
        {
            return;
        }

        IsLoadingVerificationState = true;
        WorkflowErrorMessage = null;

        try
        {
            var response = await ApiClient.GetVerifiedDeveloperRoleStateAsync(SelectedDeveloperIdentifier);
            SelectedVerificationState = response.VerifiedDeveloperRoleState.VerifiedDeveloper;
        }
        catch (BoardLibraryApiException exception) when (exception.StatusCode == HttpStatusCode.NotFound)
        {
            SelectedVerificationState = false;
            WorkflowErrorMessage = "This account does not currently have developer access.";
        }
        catch (Exception exception)
        {
            WorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsLoadingVerificationState = false;
        }
    }

    private async Task OnVerificationToggleChanged(ChangeEventArgs args)
    {
        if (SelectedDeveloper is null || string.IsNullOrWhiteSpace(SelectedDeveloperIdentifier) || IsLoadingVerificationState || IsMutating)
        {
            return;
        }

        var requestedState = args.Value is bool requestedValue && requestedValue;
        var previousState = SelectedVerificationState;
        SelectedVerificationState = requestedState;
        WorkflowErrorMessage = null;
        StatusMessage = null;
        IsMutating = true;

        try
        {
            var response = requestedState
                ? await ApiClient.GrantVerifiedDeveloperRoleAsync(SelectedDeveloperIdentifier)
                : await ApiClient.RevokeVerifiedDeveloperRoleAsync(SelectedDeveloperIdentifier);

            var state = response.VerifiedDeveloperRoleState;
            SelectedVerificationState = state.VerifiedDeveloper;
            var statusLabel = state.VerifiedDeveloper ? "verified" : "not verified";
            StatusMessage = $"{FormatDeveloperHeading(SelectedDeveloper)} is now {statusLabel}.";
            if (state.AlreadyInRequestedState)
            {
                StatusMessage += " (No change was needed.)";
            }
        }
        catch (BoardLibraryApiException exception) when (exception.StatusCode == HttpStatusCode.NotFound)
        {
            SelectedVerificationState = previousState;
            WorkflowErrorMessage = "This account does not currently have developer access.";
        }
        catch (Exception exception)
        {
            SelectedVerificationState = previousState;
            WorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsMutating = false;
        }
    }

    private async Task SelectWorkflowAsync(string workflowKey)
    {
        ActiveWorkflow = workflowKey;
        if (workflowKey == "reports-review" && TitleReports.Count == 0)
        {
            await LoadTitleReportsAsync();
        }
    }

    private async Task LoadTitleReportsAsync()
    {
        IsLoadingTitleReports = true;
        ReportWorkflowErrorMessage = null;

        try
        {
            var response = await ApiClient.GetModerationTitleReportsAsync();
            TitleReports.Clear();
            TitleReports.AddRange(response.Reports.OrderByDescending(candidate => candidate.UpdatedAt));

            if (SelectedTitleReportId is null || TitleReports.All(candidate => candidate.Id != SelectedTitleReportId))
            {
                SelectedTitleReportId = TitleReports.FirstOrDefault()?.Id;
            }

            if (SelectedTitleReportId is not null)
            {
                await LoadSelectedTitleReportAsync(forceRefresh: true);
            }
        }
        catch (Exception exception)
        {
            ReportWorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsLoadingTitleReports = false;
        }
    }

    private IReadOnlyList<TitleReportSummary> GetFilteredTitleReports()
    {
        if (string.IsNullOrWhiteSpace(TitleReportFilterQuery))
        {
            return TitleReports;
        }

        var query = TitleReportFilterQuery.Trim();
        var threshold = FuzzySearchService.GetMinimumScoreThreshold(query);
        return TitleReports
            .Select(candidate => new
            {
                Report = candidate,
                Score = FuzzySearchService.BestScore(query, candidate.TitleDisplayName, candidate.StudioDisplayName, candidate.ReporterDisplayName, candidate.ReporterUserName, candidate.ReporterEmail, candidate.Reason)
            })
            .Where(entry =>
                entry.Score >= threshold ||
                ContainsIgnoreCase(entry.Report.TitleDisplayName, query) ||
                ContainsIgnoreCase(entry.Report.StudioDisplayName, query) ||
                ContainsIgnoreCase(entry.Report.Reason, query))
            .OrderByDescending(entry => entry.Report.UpdatedAt)
            .Select(entry => entry.Report)
            .ToArray();
    }

    private async Task SelectTitleReportAsync(Guid reportId)
    {
        SelectedTitleReportId = reportId;
        TitleReportReplyDraft = string.Empty;
        TitleReportRecipientRole = "developer";
        await LoadSelectedTitleReportAsync(forceRefresh: true);
    }

    private async Task LoadSelectedTitleReportAsync(bool forceRefresh)
    {
        if (SelectedTitleReportId is null)
        {
            return;
        }

        if (!forceRefresh && TitleReportDetails.ContainsKey(SelectedTitleReportId.Value))
        {
            return;
        }

        try
        {
            var detail = await ApiClient.GetModerationTitleReportAsync(SelectedTitleReportId.Value);
            if (detail is null)
            {
                return;
            }

            TitleReportDetails[detail.Report.Id] = detail;
            TitleReportRecipientRole = DetermineDefaultModeratorRecipientRole(detail.Report.Status);
            TitleReportResolutionNote = detail.ResolutionNote ?? string.Empty;
        }
        catch (Exception exception)
        {
            ReportWorkflowErrorMessage = exception.Message;
        }
    }

    private async Task SendModeratorReportMessageAsync()
    {
        if (SelectedTitleReportId is null || string.IsNullOrWhiteSpace(TitleReportReplyDraft) || IsMutatingTitleReports)
        {
            return;
        }

        IsMutatingTitleReports = true;
        ReportWorkflowErrorMessage = null;
        ReportStatusMessage = null;

        try
        {
            var response = await ApiClient.AddModerationTitleReportMessageAsync(
                SelectedTitleReportId.Value,
                new AddModerationTitleReportMessageRequest(TitleReportReplyDraft.Trim(), TitleReportRecipientRole));
            TitleReportDetails[response.Report.Report.Id] = response.Report;
            UpsertTitleReportSummary(response.Report.Report);
            TitleReportReplyDraft = string.Empty;
            TitleReportRecipientRole = DetermineDefaultModeratorRecipientRole(response.Report.Report.Status);
            TitleReportResolutionNote = response.Report.ResolutionNote ?? string.Empty;
            ReportStatusMessage = TitleReportRecipientRole == "player"
                ? "Moderator message sent to the reporting player."
                : "Moderator message sent to the developer.";
        }
        catch (Exception exception)
        {
            ReportWorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsMutatingTitleReports = false;
        }
    }

    private Task ValidateSelectedTitleReportAsync() => ResolveSelectedTitleReportAsync(validate: true);

    private Task InvalidateSelectedTitleReportAsync() => ResolveSelectedTitleReportAsync(validate: false);

    private async Task ResolveSelectedTitleReportAsync(bool validate)
    {
        if (SelectedTitleReportId is null || IsMutatingTitleReports)
        {
            return;
        }

        IsMutatingTitleReports = true;
        ReportWorkflowErrorMessage = null;
        ReportStatusMessage = null;

        try
        {
            var request = new ModerateTitleReportDecisionRequest(string.IsNullOrWhiteSpace(TitleReportResolutionNote) ? null : TitleReportResolutionNote.Trim());
            var response = validate
                ? await ApiClient.ValidateModerationTitleReportAsync(SelectedTitleReportId.Value, request)
                : await ApiClient.InvalidateModerationTitleReportAsync(SelectedTitleReportId.Value, request);

            TitleReportDetails[response.Report.Report.Id] = response.Report;
            UpsertTitleReportSummary(response.Report.Report);
            TitleReportResolutionNote = response.Report.ResolutionNote ?? string.Empty;
            ReportStatusMessage = validate ? "Report validated." : "Report invalidated.";
        }
        catch (Exception exception)
        {
            ReportWorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsMutatingTitleReports = false;
        }
    }

    private void UpsertTitleReportSummary(TitleReportSummary summary)
    {
        var existingIndex = TitleReports.FindIndex(candidate => candidate.Id == summary.Id);
        if (existingIndex >= 0)
        {
            TitleReports[existingIndex] = summary;
        }
        else
        {
            TitleReports.Add(summary);
        }

        TitleReports.Sort((left, right) => right.UpdatedAt.CompareTo(left.UpdatedAt));
    }

    private void CaptureRequestedRouteState()
    {
        var query = QueryHelpers.ParseQuery(new Uri(NavigationManager.Uri).Query);
        RequestedWorkflow = query.TryGetValue("workflow", out var workflowValue)
            ? workflowValue.ToString()
            : null;
        RequestedTitleReportId = query.TryGetValue("reportId", out var reportIdValue) && Guid.TryParse(reportIdValue.ToString(), out var reportId)
            ? reportId
            : null;
    }

    private async Task ApplyRequestedRouteStateAsync()
    {
        if (HasAppliedInitialRouteState)
        {
            return;
        }

        HasAppliedInitialRouteState = true;

        if (!string.IsNullOrWhiteSpace(RequestedWorkflow) &&
            (string.Equals(RequestedWorkflow, "developers-verify", StringComparison.Ordinal) ||
             string.Equals(RequestedWorkflow, "reports-review", StringComparison.Ordinal)))
        {
            ActiveWorkflow = RequestedWorkflow;
        }

        if (string.Equals(ActiveWorkflow, "reports-review", StringComparison.Ordinal) && TitleReports.Count == 0)
        {
            await LoadTitleReportsAsync();
        }

        if (RequestedTitleReportId is { } requestedTitleReportId && TitleReports.Any(candidate => candidate.Id == requestedTitleReportId))
        {
            SelectedTitleReportId = requestedTitleReportId;
            await LoadSelectedTitleReportAsync(forceRefresh: true);
        }
    }

    private IReadOnlyList<ModerationDeveloperSummary> GetFilteredDevelopers()
    {
        if (string.IsNullOrWhiteSpace(DeveloperFilterQuery))
        {
            return Developers
                .Take(80)
                .ToArray();
        }

        var query = DeveloperFilterQuery.Trim();
        var threshold = FuzzySearchService.GetMinimumScoreThreshold(query);
        return Developers
            .Select(candidate => new
            {
                Developer = candidate,
                Score = FuzzySearchService.BestScore(query, candidate.UserName, candidate.DisplayName, candidate.Email)
            })
            .Where(entry =>
                entry.Score >= threshold ||
                ContainsIgnoreCase(entry.Developer.UserName, query) ||
                ContainsIgnoreCase(entry.Developer.DisplayName, query) ||
                ContainsIgnoreCase(entry.Developer.Email, query))
            .OrderByDescending(entry => entry.Score)
            .ThenBy(entry => entry.Developer.UserName ?? entry.Developer.DisplayName ?? entry.Developer.Email ?? entry.Developer.DeveloperSubject, StringComparer.OrdinalIgnoreCase)
            .Take(80)
            .Select(entry => entry.Developer)
            .ToArray();
    }

    private static string BuildDeveloperIdentifier(ModerationDeveloperSummary developer) =>
        string.IsNullOrWhiteSpace(developer.UserName)
            ? developer.DeveloperSubject
            : developer.UserName;

    private static string FormatDeveloperOption(ModerationDeveloperSummary developer)
    {
        var userName = string.IsNullOrWhiteSpace(developer.UserName) ? developer.DeveloperSubject : developer.UserName;
        if (string.IsNullOrWhiteSpace(developer.DisplayName))
        {
            return userName;
        }

        return $"{userName} - {developer.DisplayName}";
    }

    private static string FormatDeveloperHeading(ModerationDeveloperSummary developer)
    {
        if (!string.IsNullOrWhiteSpace(developer.DisplayName) && !string.IsNullOrWhiteSpace(developer.UserName))
        {
            return $"{developer.DisplayName} ({developer.UserName})";
        }

        if (!string.IsNullOrWhiteSpace(developer.DisplayName))
        {
            return developer.DisplayName;
        }

        return string.IsNullOrWhiteSpace(developer.UserName)
            ? developer.DeveloperSubject
            : developer.UserName;
    }

    private static bool ContainsIgnoreCase(string? value, string query) =>
        value?.Contains(query, StringComparison.OrdinalIgnoreCase) == true;

    private static string FormatReportActorName(string? displayName, string? userName, string? email, string subject)
    {
        if (!string.IsNullOrWhiteSpace(displayName) && !string.IsNullOrWhiteSpace(userName))
        {
            return $"{displayName} ({userName})";
        }

        if (!string.IsNullOrWhiteSpace(displayName))
        {
            return displayName;
        }

        if (!string.IsNullOrWhiteSpace(userName))
        {
            return userName;
        }

        return !string.IsNullOrWhiteSpace(email) ? email : subject;
    }

    private static string FormatTimestamp(DateTime timestamp) =>
        timestamp.ToLocalTime().ToString("MMM d, yyyy h:mm tt");

    private string GetModeratorReplyPlaceholder() =>
        TitleReportRecipientRole == "player"
            ? "Ask the reporting player for more detail or share a moderation update."
            : "Ask the developer follow-up questions or explain the next step.";

    private static string DetermineDefaultModeratorRecipientRole(string status) =>
        status is "needs_player_response" or "player_responded"
            ? "player"
            : "developer";

    private static string FormatReportAudience(string audience) => audience switch
    {
        "all" => "all parties",
        "player" => "player only",
        "developer" => "developer only",
        _ => audience
    };

    private string GetWorkflowButtonClass(string workflowKey, bool compact) =>
        compact
            ? (ActiveWorkflow == workflowKey
                ? "rounded-full bg-cyan-300 px-4 py-2 text-sm font-semibold uppercase tracking-[0.14em] text-slate-950"
                : "rounded-full border border-white/15 px-4 py-2 text-sm font-semibold uppercase tracking-[0.14em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100")
            : (ActiveWorkflow == workflowKey
                ? "w-full rounded-[0.9rem] border border-cyan-300/45 bg-cyan-300/15 px-3 py-2 text-left text-sm text-cyan-50"
                : "w-full rounded-[0.9rem] border border-white/10 bg-black/15 px-3 py-2 text-left text-sm text-slate-200 transition hover:border-cyan-300/45 hover:text-cyan-100");
}
