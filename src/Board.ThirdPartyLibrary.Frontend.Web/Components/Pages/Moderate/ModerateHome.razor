@page "/moderate"
@attribute [Authorize]
@using System.Net
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Moderation Console</PageTitle>

<section class="app-workspace-shell space-y-6">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Moderation unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CurrentUser is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-52 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-40 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!IsModerator)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Moderation access unavailable</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                This area is only available to moderation team members.
            </p>
        </section>
    }
    else
    {
        <section class="app-workspace-content">
            <div>
                <h1 class="app-page-title">Moderate</h1>
                <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                    Review and update developer verification.
                </p>
            </div>

            <section class="app-panel w-full p-4">
                <div class="flex flex-wrap gap-2">
                    <button class="rounded-full bg-cyan-300 px-4 py-2 text-sm font-semibold uppercase tracking-[0.14em] text-slate-950" type="button">Developers</button>
                </div>
            </section>

            <section class="app-workspace-grid">
                <aside class="app-panel p-4">
                    <div class="text-xs uppercase tracking-[0.2em] text-cyan-100/70">Workflow</div>
                    <nav class="mt-3 space-y-2">
                        <button class="w-full rounded-[0.9rem] border border-cyan-300/45 bg-cyan-300/15 px-3 py-2 text-left text-sm text-cyan-50" type="button">Verify Developers</button>
                    </nav>
                </aside>

                <section class="app-panel app-workspace-main p-6">
                    <h2 class="text-2xl font-semibold text-white">Verify Developers</h2>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                        Find a developer account and set whether the account is verified.
                    </p>

                    @if (!string.IsNullOrWhiteSpace(StatusMessage))
                    {
                        <div class="mt-4 rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@StatusMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(WorkflowErrorMessage))
                    {
                        <div class="mt-4 rounded-[1rem] border border-rose-300/35 bg-rose-400/10 px-4 py-3 text-sm text-rose-100">@WorkflowErrorMessage</div>
                    }

                    <div class="mt-6 space-y-4">
                        <label class="block text-sm text-slate-300">
                            Search developers
                            <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                                   @bind="DeveloperFilterQuery"
                                   @bind:event="oninput"
                                   placeholder="Search by username, display name, or email" />
                        </label>

                        <label class="block text-sm text-slate-300">
                            Developer
                            <select class="mt-2 h-56 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-3 py-2 text-slate-100"
                                    @onchange="OnDeveloperSelectionChanged"
                                    disabled="@IsLoadingDevelopers">
                                <option value="">Select a developer...</option>
                                @foreach (var developer in GetFilteredDevelopers())
                                {
                                    var identifier = BuildDeveloperIdentifier(developer);
                                    <option value="@identifier" selected="@(identifier == SelectedDeveloperIdentifier)">
                                        @FormatDeveloperOption(developer)
                                    </option>
                                }
                            </select>
                        </label>

                        @if (IsLoadingDevelopers)
                        {
                            <p class="text-sm text-slate-300">Loading developer list...</p>
                        }
                        else if (!Developers.Any())
                        {
                            <p class="text-sm text-slate-300">No users are available yet.</p>
                        }
                        else if (!GetFilteredDevelopers().Any())
                        {
                            <p class="text-sm text-slate-300">No users match that search.</p>
                        }
                    </div>

                    <div class="mt-6 rounded-[1rem] border border-white/10 bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Selected account</div>
                        @if (SelectedDeveloper is null)
                        {
                            <p class="mt-2 text-sm text-slate-300">Select a developer to manage verification.</p>
                        }
                        else
                        {
                            <p class="mt-2 text-lg font-semibold text-white">@FormatDeveloperHeading(SelectedDeveloper)</p>
                            @if (!string.IsNullOrWhiteSpace(SelectedDeveloper.Email))
                            {
                                <p class="mt-1 text-sm text-slate-300">@SelectedDeveloper.Email</p>
                            }
                            <p class="mt-4 text-sm text-slate-200">
                                Verification status:
                                <span class="font-semibold text-white">@(SelectedVerificationState ? "Verified" : "Not verified")</span>
                            </p>
                        }
                    </div>

                    <div class="mt-6 flex flex-wrap items-center gap-3">
                        <label class="inline-flex items-center gap-3 rounded-full border border-white/15 px-4 py-2 text-sm text-slate-100">
                            <span class="font-semibold uppercase tracking-[0.14em]">Verified</span>
                            <input class="h-5 w-5 accent-cyan-300"
                                   type="checkbox"
                                   checked="@SelectedVerificationState"
                                   @onchange="OnVerificationToggleChanged"
                                   disabled="@(!CanMutateVerification)" />
                        </label>
                        @if (IsLoadingVerificationState)
                        {
                            <span class="text-sm text-slate-300">Checking current status...</span>
                        }
                        else if (IsMutating)
                        {
                            <span class="text-sm text-slate-300">Updating verification...</span>
                        }
                    </div>
                </section>
            </section>
        </section>
    }
</section>

@code {
    private readonly List<ModerationDeveloperSummary> Developers = [];

    private CurrentUserResponse? CurrentUser { get; set; }

    private ModerationDeveloperSummary? SelectedDeveloper { get; set; }

    private string? SelectedDeveloperIdentifier { get; set; }

    private string DeveloperFilterQuery { get; set; } = string.Empty;

    private bool SelectedVerificationState { get; set; }

    private bool IsLoadingDevelopers { get; set; }

    private bool IsLoadingVerificationState { get; set; }

    private bool IsMutating { get; set; }

    private string? ErrorMessage { get; set; }

    private string? WorkflowErrorMessage { get; set; }

    private string? StatusMessage { get; set; }

    private bool IsModerator => CurrentUser.HasRole("moderator");

    private bool CanMutateVerification =>
        SelectedDeveloper is not null &&
        !IsLoadingVerificationState &&
        !IsMutating;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            if (CurrentUser is not null && IsModerator)
            {
                await LoadDevelopersAsync();
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }

    private async Task LoadDevelopersAsync()
    {
        IsLoadingDevelopers = true;
        WorkflowErrorMessage = null;

        try
        {
            var response = await ApiClient.GetModerationDevelopersAsync();
            Developers.Clear();
            Developers.AddRange(
                response.Developers
                    .OrderBy(candidate => candidate.UserName ?? candidate.DisplayName ?? candidate.Email ?? candidate.DeveloperSubject, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(candidate => candidate.DeveloperSubject, StringComparer.Ordinal));
        }
        catch (Exception exception)
        {
            WorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsLoadingDevelopers = false;
        }
    }

    private async Task OnDeveloperSelectionChanged(ChangeEventArgs args)
    {
        var identifier = args.Value?.ToString();
        SelectedDeveloper = Developers.FirstOrDefault(candidate =>
            string.Equals(BuildDeveloperIdentifier(candidate), identifier, StringComparison.Ordinal));
        SelectedDeveloperIdentifier = SelectedDeveloper is null
            ? null
            : BuildDeveloperIdentifier(SelectedDeveloper);
        WorkflowErrorMessage = null;
        StatusMessage = null;

        if (SelectedDeveloper is null || string.IsNullOrWhiteSpace(SelectedDeveloperIdentifier))
        {
            SelectedVerificationState = false;
            return;
        }

        await LoadSelectedDeveloperVerificationAsync();
    }

    private async Task LoadSelectedDeveloperVerificationAsync()
    {
        if (SelectedDeveloper is null || string.IsNullOrWhiteSpace(SelectedDeveloperIdentifier))
        {
            return;
        }

        IsLoadingVerificationState = true;
        WorkflowErrorMessage = null;

        try
        {
            var response = await ApiClient.GetVerifiedDeveloperRoleStateAsync(SelectedDeveloperIdentifier);
            SelectedVerificationState = response.VerifiedDeveloperRoleState.VerifiedDeveloper;
        }
        catch (BoardLibraryApiException exception) when (exception.StatusCode == HttpStatusCode.NotFound)
        {
            SelectedVerificationState = false;
            WorkflowErrorMessage = "This account does not currently have developer access.";
        }
        catch (Exception exception)
        {
            WorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsLoadingVerificationState = false;
        }
    }

    private async Task OnVerificationToggleChanged(ChangeEventArgs args)
    {
        if (SelectedDeveloper is null || string.IsNullOrWhiteSpace(SelectedDeveloperIdentifier) || IsLoadingVerificationState || IsMutating)
        {
            return;
        }

        var requestedState = args.Value is bool requestedValue && requestedValue;
        var previousState = SelectedVerificationState;
        SelectedVerificationState = requestedState;
        WorkflowErrorMessage = null;
        StatusMessage = null;
        IsMutating = true;

        try
        {
            var response = requestedState
                ? await ApiClient.GrantVerifiedDeveloperRoleAsync(SelectedDeveloperIdentifier)
                : await ApiClient.RevokeVerifiedDeveloperRoleAsync(SelectedDeveloperIdentifier);

            var state = response.VerifiedDeveloperRoleState;
            SelectedVerificationState = state.VerifiedDeveloper;
            var statusLabel = state.VerifiedDeveloper ? "verified" : "not verified";
            StatusMessage = $"{FormatDeveloperHeading(SelectedDeveloper)} is now {statusLabel}.";
            if (state.AlreadyInRequestedState)
            {
                StatusMessage += " (No change was needed.)";
            }
        }
        catch (BoardLibraryApiException exception) when (exception.StatusCode == HttpStatusCode.NotFound)
        {
            SelectedVerificationState = previousState;
            WorkflowErrorMessage = "This account does not currently have developer access.";
        }
        catch (Exception exception)
        {
            SelectedVerificationState = previousState;
            WorkflowErrorMessage = exception.Message;
        }
        finally
        {
            IsMutating = false;
        }
    }

    private IReadOnlyList<ModerationDeveloperSummary> GetFilteredDevelopers()
    {
        if (string.IsNullOrWhiteSpace(DeveloperFilterQuery))
        {
            return Developers
                .Take(80)
                .ToArray();
        }

        var query = DeveloperFilterQuery.Trim();
        var threshold = FuzzySearchService.GetMinimumScoreThreshold(query);
        return Developers
            .Select(candidate => new
            {
                Developer = candidate,
                Score = FuzzySearchService.BestScore(query, candidate.UserName, candidate.DisplayName, candidate.Email)
            })
            .Where(entry =>
                entry.Score >= threshold ||
                ContainsIgnoreCase(entry.Developer.UserName, query) ||
                ContainsIgnoreCase(entry.Developer.DisplayName, query) ||
                ContainsIgnoreCase(entry.Developer.Email, query))
            .OrderByDescending(entry => entry.Score)
            .ThenBy(entry => entry.Developer.UserName ?? entry.Developer.DisplayName ?? entry.Developer.Email ?? entry.Developer.DeveloperSubject, StringComparer.OrdinalIgnoreCase)
            .Take(80)
            .Select(entry => entry.Developer)
            .ToArray();
    }

    private static string BuildDeveloperIdentifier(ModerationDeveloperSummary developer) =>
        string.IsNullOrWhiteSpace(developer.UserName)
            ? developer.DeveloperSubject
            : developer.UserName;

    private static string FormatDeveloperOption(ModerationDeveloperSummary developer)
    {
        var userName = string.IsNullOrWhiteSpace(developer.UserName) ? developer.DeveloperSubject : developer.UserName;
        if (string.IsNullOrWhiteSpace(developer.DisplayName))
        {
            return userName;
        }

        return $"{userName} - {developer.DisplayName}";
    }

    private static string FormatDeveloperHeading(ModerationDeveloperSummary developer)
    {
        if (!string.IsNullOrWhiteSpace(developer.DisplayName) && !string.IsNullOrWhiteSpace(developer.UserName))
        {
            return $"{developer.DisplayName} ({developer.UserName})";
        }

        if (!string.IsNullOrWhiteSpace(developer.DisplayName))
        {
            return developer.DisplayName;
        }

        return string.IsNullOrWhiteSpace(developer.UserName)
            ? developer.DeveloperSubject
            : developer.UserName;
    }

    private static bool ContainsIgnoreCase(string? value, string query) =>
        value?.Contains(query, StringComparison.OrdinalIgnoreCase) == true;
}
