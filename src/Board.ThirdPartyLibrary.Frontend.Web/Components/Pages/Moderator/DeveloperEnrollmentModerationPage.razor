@page "/moderation/developer-enrollment-requests"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@inject IBoardLibraryApiClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Developer Enrollment Queue</PageTitle>

<section class="space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <h1 class="mt-4 app-page-title">Developer Enrollment Queue</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                Pending requests stay in one queue. Moderators can approve immediately or keep the same request open while asking for more information.
            </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
            <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/account/notifications">Notifications</a>
            <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop">Back to develop</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Moderation unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CurrentUser is null || Requests is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-60 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-48 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else if (!CurrentUser.IsModerator())
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Moderator access required</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">This route is reserved for moderator and admin accounts reviewing developer registration requests.</p>
        </section>
    }
    else
    {
        <section class="grid gap-4 lg:grid-cols-3">
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Pending review</div>
                <div class="mt-3 text-4xl font-black text-white">@PendingCount</div>
            </section>
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Waiting on applicant</div>
                <div class="mt-3 text-4xl font-black text-white">@AwaitingApplicantCount</div>
            </section>
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Reviewed</div>
                <div class="mt-3 text-4xl font-black text-white">@ReviewedCount</div>
            </section>
        </section>

        <section class="app-panel p-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Queue filter</div>
                    <h2 class="mt-3 text-2xl font-semibold text-white">@SelectedFilter.Label</h2>
                </div>
                <div class="flex flex-wrap gap-3">
                    @foreach (var filter in Filters)
                    {
                        <a class="@BuildFilterCssClass(filter.Key)" href="@BuildFilterHref(filter.Key)">@($"{filter.Label} ({filter.Count})")</a>
                    }
                </div>
            </div>
            <p class="mt-4 text-sm leading-7 text-slate-300">@SelectedFilter.Description</p>
        </section>

        @if (VisibleRequests.Count == 0)
        {
            <section class="app-panel p-6">
                <h2 class="text-xl font-semibold text-white">No requests in this view</h2>
                <p class="mt-3 text-sm leading-7 text-slate-300">Change the filter to review a different part of the moderation queue.</p>
            </section>
        }
        else
        {
            <section class="space-y-4">
                @foreach (var request in VisibleRequests)
                {
                    <section class="app-panel p-6">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div class="max-w-3xl">
                            <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">@request.Status.Replace('_', ' ')</div>
                            <h2 class="mt-3 text-2xl font-semibold text-white">@(request.ApplicantDisplayName ?? request.ApplicantSubject)</h2>
                            <div class="mt-2 text-sm text-slate-300">@request.ApplicantEmail</div>
                            <div class="mt-4 grid gap-3 sm:grid-cols-3">
                                <div class="rounded-[1.25rem] bg-black/15 p-4">
                                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Requested</div>
                                    <div class="mt-2 text-base text-white">@request.RequestedAt.ToLocalTime().ToString("MMMM d, yyyy 'at' h:mm tt")</div>
                                </div>
                                <div class="rounded-[1.25rem] bg-black/15 p-4">
                                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Action required</div>
                                    <div class="mt-2 text-base text-white">@request.ActionRequiredBy</div>
                                </div>
                                <div class="rounded-[1.25rem] bg-black/15 p-4">
                                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Reviewer</div>
                                    <div class="mt-2 text-base text-white">@(request.ReviewerSubject ?? "Not final")</div>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col gap-3">
                            <button class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" type="button" @onclick="() => ToggleConversationAsync(request.RequestId)">
                                @(IsExpanded(request.RequestId) ? "Hide thread" : "Show thread")
                            </button>
                            @if (string.Equals(request.Status, "pending_review", StringComparison.OrdinalIgnoreCase))
                            {
                                <button class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => ApproveAsync(request.RequestId)" disabled="@IsBusy(request.RequestId)">
                                    @(IsBusy(request.RequestId) ? "Working..." : "Approve")
                                </button>
                            }
                        </div>
                    </div>

                    @if (string.Equals(request.Status, "pending_review", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="mt-6 rounded-[1.5rem] border border-white/10 bg-black/10 p-5">
                            <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Moderator comments</div>
                            <textarea class="mt-4 min-h-32 w-full rounded-[1.25rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-100" value="@GetCommentDraft(request.RequestId)" @oninput="args => SetCommentDraft(request.RequestId, args.Value?.ToString())" placeholder="Required for reject or request more information."></textarea>
                            <div class="mt-4 flex flex-wrap items-center gap-3">
                                <label class="app-file-button" for="@GetAttachmentInputId(request.RequestId)">Choose File...</label>
                                <InputFile id="@GetAttachmentInputId(request.RequestId)" class="sr-only" OnChange="@((InputFileChangeEventArgs args) => HandleAttachmentsAsync(request.RequestId, args))" multiple />
                                <span class="text-sm text-slate-300">@GetAttachmentSummary(request.RequestId)</span>
                            </div>
                            @if (AttachmentDrafts.TryGetValue(request.RequestId, out var attachments) && attachments.Count > 0)
                            {
                                <div class="mt-4 flex flex-wrap gap-2">
                                    @foreach (var attachment in attachments)
                                    {
                                        <div class="rounded-full border border-white/10 px-4 py-2 text-xs uppercase tracking-[0.18em] text-slate-200">@attachment.FileName</div>
                                    }
                                </div>
                            }
                            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                                <button class="rounded-full border border-cyan-300/50 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-cyan-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => RequestMoreInformationAsync(request.RequestId)" disabled="@IsBusy(request.RequestId)">
                                    Request more info
                                </button>
                                <button class="rounded-full border border-rose-300/40 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-rose-100 disabled:cursor-not-allowed disabled:opacity-60" type="button" @onclick="() => RejectAsync(request.RequestId)" disabled="@IsBusy(request.RequestId)">
                                    Reject
                                </button>
                            </div>
                        </div>
                    }

                    @if (IsExpanded(request.RequestId) && Conversations.TryGetValue(request.RequestId, out var conversation))
                    {
                        <div class="mt-6 space-y-3">
                            @foreach (var message in conversation.Conversation.Messages)
                            {
                                <section class="rounded-[1.5rem] border border-white/10 bg-black/15 p-5">
                                    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                                        <div class="text-sm font-semibold text-white">@((message.AuthorDisplayName ?? message.AuthorSubject) + " • " + message.AuthorRole)</div>
                                        <div class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">@message.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy 'at' h:mm tt")</div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(message.Body))
                                    {
                                        <p class="mt-3 text-sm leading-7 text-slate-300">@message.Body</p>
                                    }
                                    @if (message.Attachments.Count > 0)
                                    {
                                        <div class="mt-4 flex flex-wrap gap-2">
                                            @foreach (var attachment in message.Attachments)
                                            {
                                                <a class="rounded-full border border-white/10 px-4 py-2 text-xs uppercase tracking-[0.18em] text-slate-200" href="@($"/downloads/moderation/developer-enrollment/{request.RequestId:D}/attachments/{attachment.AttachmentId:D}")">@attachment.FileName (@FormatBytes(attachment.SizeBytes))</a>
                                            }
                                        </div>
                                    }
                                </section>
                            }
                        </div>
                    }
                    </section>
                }
            </section>
        }
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "filter")]
    public string? Filter { get; set; }

    private CurrentUserResponse? CurrentUser { get; set; }
    private List<DeveloperEnrollmentRequest>? Requests { get; set; }
    private Dictionary<Guid, string> CommentDrafts { get; } = [];
    private Dictionary<Guid, List<ApiUploadFile>> AttachmentDrafts { get; } = [];
    private Dictionary<Guid, DeveloperEnrollmentConversationResponse> Conversations { get; } = [];
    private HashSet<Guid> ExpandedRequestIds { get; } = [];
    private Guid? BusyRequestId { get; set; }
    private string? ErrorMessage { get; set; }
    private string SelectedFilterKey => NormalizeFilter(Filter);

    private int PendingCount => Requests?.Count(static request => string.Equals(request.Status, "pending_review", StringComparison.OrdinalIgnoreCase)) ?? 0;
    private int AwaitingApplicantCount => Requests?.Count(static request => string.Equals(request.Status, "awaiting_applicant_response", StringComparison.OrdinalIgnoreCase)) ?? 0;
    private int ReviewedCount => Requests?.Count(static request => string.Equals(request.Status, "approved", StringComparison.OrdinalIgnoreCase) || string.Equals(request.Status, "rejected", StringComparison.OrdinalIgnoreCase) || string.Equals(request.Status, "cancelled", StringComparison.OrdinalIgnoreCase)) ?? 0;
    private IReadOnlyList<QueueFilterOption> Filters =>
        [
            new("all", "All requests", "Review the complete history of developer-access requests, including active and completed items.", Requests?.Count ?? 0),
            new("pending-review", "Waiting on moderators", "These requests are currently in a moderator-owned review state and can be approved, rejected, or sent back for more information.", PendingCount),
            new("awaiting-applicant", "Waiting on applicants", "These requests are paused until the applicant replies with the additional information requested by a moderator.", AwaitingApplicantCount),
            new("reviewed", "Reviewed", "These requests are already approved, rejected, or cancelled and remain here for historical reference.", ReviewedCount)
        ];
    private QueueFilterOption SelectedFilter => Filters.First(filter => filter.Key == SelectedFilterKey);
    private IReadOnlyList<DeveloperEnrollmentRequest> VisibleRequests =>
        Requests is null
            ? []
            : Requests.Where(request => MatchesFilter(request, SelectedFilterKey)).ToArray();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private bool IsBusy(Guid requestId) => BusyRequestId == requestId;
    private bool IsExpanded(Guid requestId) => ExpandedRequestIds.Contains(requestId);

    private Task ApproveAsync(Guid requestId) => ReviewAsync(requestId, "approve");

    private Task RejectAsync(Guid requestId) => ReviewAsync(requestId, "reject");

    private Task RequestMoreInformationAsync(Guid requestId) => ReviewAsync(requestId, "request-more-information");

    private async Task ReviewAsync(Guid requestId, string action)
    {
        if (BusyRequestId is not null)
        {
            return;
        }

        ErrorMessage = null;
        BusyRequestId = requestId;
        try
        {
            var attachments = AttachmentDrafts.TryGetValue(requestId, out var currentAttachments) ? currentAttachments : [];
            _ = action switch
            {
                "approve" => await ApiClient.ApproveDeveloperEnrollmentRequestAsync(requestId),
                "reject" => await ApiClient.RejectDeveloperEnrollmentRequestAsync(requestId, GetCommentDraft(requestId), attachments),
                _ => await ApiClient.RequestMoreInformationForDeveloperEnrollmentAsync(requestId, GetCommentDraft(requestId), attachments)
            };

            CommentDrafts.Remove(requestId);
            AttachmentDrafts.Remove(requestId);
            await LoadRequestsAsync();
            if (IsExpanded(requestId))
            {
                Conversations[requestId] = await ApiClient.GetModeratedDeveloperEnrollmentConversationAsync(requestId);
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            BusyRequestId = null;
        }
    }

    private async Task ToggleConversationAsync(Guid requestId)
    {
        if (ExpandedRequestIds.Contains(requestId))
        {
            ExpandedRequestIds.Remove(requestId);
            return;
        }

        Conversations[requestId] = await ApiClient.GetModeratedDeveloperEnrollmentConversationAsync(requestId);
        ExpandedRequestIds.Add(requestId);
    }

    private async Task HandleAttachmentsAsync(Guid requestId, InputFileChangeEventArgs args)
    {
        var attachments = new List<ApiUploadFile>();
        foreach (var file in args.GetMultipleFiles())
        {
            await using var stream = file.OpenReadStream(25L * 1024L * 1024L);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            attachments.Add(new ApiUploadFile(file.Name, file.ContentType, memoryStream.ToArray()));
        }

        AttachmentDrafts[requestId] = attachments;
    }

    private string GetCommentDraft(Guid requestId) =>
        CommentDrafts.TryGetValue(requestId, out var value) ? value : string.Empty;

    private void SetCommentDraft(Guid requestId, string? value) =>
        CommentDrafts[requestId] = value ?? string.Empty;

    private async Task LoadAsync()
    {
        ErrorMessage = null;
        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            if (CurrentUser is null)
            {
                ErrorMessage = "The authenticated user profile could not be loaded from the backend.";
                return;
            }

            if (!CurrentUser.IsModerator())
            {
                Requests = [];
                return;
            }

            await LoadRequestsAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }

    private async Task LoadRequestsAsync() =>
        Requests = (await ApiClient.GetDeveloperEnrollmentRequestsAsync()).Requests.ToList();

    private string BuildFilterHref(string filterKey)
    {
        var relativePath = filterKey == "all"
            ? "/moderation/developer-enrollment-requests"
            : $"/moderation/developer-enrollment-requests?filter={Uri.EscapeDataString(filterKey)}";
        return NavigationManager.ToAbsoluteUri(relativePath).PathAndQuery;
    }

    private string BuildFilterCssClass(string filterKey) =>
        filterKey == SelectedFilterKey
            ? "rounded-full bg-cyan-300 px-4 py-2 text-sm font-bold uppercase tracking-[0.18em] text-slate-950"
            : "rounded-full border border-white/15 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100";

    private static string GetAttachmentInputId(Guid requestId) => $"moderation-attachments-{requestId:D}";

    private string GetAttachmentSummary(Guid requestId)
    {
        if (!AttachmentDrafts.TryGetValue(requestId, out var attachments) || attachments.Count == 0)
        {
            return "No file chosen";
        }

        return attachments.Count == 1
            ? attachments[0].FileName
            : $"{attachments.Count} files selected";
    }

    private static bool MatchesFilter(DeveloperEnrollmentRequest request, string filterKey) =>
        filterKey switch
        {
            "pending-review" => string.Equals(request.Status, "pending_review", StringComparison.OrdinalIgnoreCase),
            "awaiting-applicant" => string.Equals(request.Status, "awaiting_applicant_response", StringComparison.OrdinalIgnoreCase),
            "reviewed" => string.Equals(request.Status, "approved", StringComparison.OrdinalIgnoreCase) || string.Equals(request.Status, "rejected", StringComparison.OrdinalIgnoreCase) || string.Equals(request.Status, "cancelled", StringComparison.OrdinalIgnoreCase),
            _ => true
        };

    private static string NormalizeFilter(string? filter) =>
        filter switch
        {
            "pending-review" => "pending-review",
            "awaiting-applicant" => "awaiting-applicant",
            "reviewed" => "reviewed",
            _ => "all"
        };

    private static string FormatBytes(long value) =>
        value >= 1024 * 1024
            ? $"{value / 1024d / 1024d:0.#} MB"
            : $"{value / 1024d:0.#} KB";

    private sealed record QueueFilterOption(string Key, string Label, string Description, int Count);
}
