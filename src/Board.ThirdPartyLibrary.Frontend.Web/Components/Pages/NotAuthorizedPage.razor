@inject NavigationManager NavigationManager

<section class="mx-auto max-w-2xl app-panel p-8 text-center">
    <h1 class="app-page-title">Sign in to continue</h1>
    <p class="mt-4 text-base leading-8 text-slate-300">
        Sign in with your Board Enthusiasts account to open your library, wishlist, account tools, and developer console.
    </p>
    <div class="mt-6">
        <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@SignInHref" data-enhance-nav="false">Sign in</a>
    </div>
</section>

@code {
    private string SignInHref
    {
        get
        {
            var currentRelativeUri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            var returnUrl = string.IsNullOrWhiteSpace(currentRelativeUri)
                ? "/player"
                : currentRelativeUri.StartsWith('/') ? currentRelativeUri : $"/{currentRelativeUri}";

            return $"/auth/signin?returnUrl={Uri.EscapeDataString(returnUrl)}";
        }
    }
}
