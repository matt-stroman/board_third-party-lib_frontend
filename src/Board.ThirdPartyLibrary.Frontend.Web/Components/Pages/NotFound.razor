@page "/not-found"
@layout MainLayout

<PageTitle>Not Found</PageTitle>

<section class="mx-auto max-w-2xl rounded-[2rem] border border-white/10 bg-white/6 p-8 text-center shadow-[0_20px_60px_rgba(2,6,23,0.35)]">
    <div class="text-sm font-semibold uppercase tracking-[0.28em] text-cyan-100/75">404</div>
    <h1 class="mt-4 font-['Aptos_Display','Trebuchet_MS',sans-serif] text-4xl font-black uppercase tracking-[0.08em] text-white">Route Not Found</h1>
    <p class="mt-4 text-base leading-8 text-slate-300">
        The route does not exist in the current web UI scaffold. Return to the library or the developer console.
    </p>
    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/library">Open library</a>
        <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/develop">Open developer console</a>
    </div>
</section>
