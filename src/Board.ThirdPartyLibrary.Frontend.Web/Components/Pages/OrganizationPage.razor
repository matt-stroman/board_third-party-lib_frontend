@page "/organizations/{Slug}"

<PageTitle>Organization</PageTitle>

<section class="space-y-6">
    <div class="app-chip w-fit">Organization profile</div>
    <section class="app-panel p-6">
        <h1 class="app-page-title">Stellar Forge</h1>
        <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
            Public organization pages will highlight the developer identity and list visible catalog titles under the same shell as the library experience.
        </p>
    </section>
    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <a class="app-panel p-5 transition hover:-translate-y-1 hover:border-cyan-300/35" href="/library/stellar-forge/star-blasters">
            <div class="h-36 rounded-[1.4rem] bg-[linear-gradient(135deg,_#eff6ff,_#7dd3fc,_#2563eb)]"></div>
            <div class="mt-4 text-xs uppercase tracking-[0.22em] text-cyan-100/70">Arcade Shooter</div>
            <div class="mt-2 text-xl font-semibold text-white">Star Blasters</div>
            <div class="mt-2 text-sm text-slate-300">Family space battles in short rounds.</div>
        </a>
    </section>
</section>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
}
