@page "/organizations/{Slug}"
@using Microsoft.AspNetCore.WebUtilities
@inject IBoardLibraryApiClient ApiClient
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>Organization</PageTitle>

<section class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Organization unavailable</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-10 w-64 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-32 animate-pulse rounded-[1.4rem] bg-white/10"></div>
        </section>
    }
    else if (Organization is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Organization not found</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">This organization is not available.</p>
        </section>
    }
    else
    {
        <section class="app-panel p-6">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div class="space-y-3">
                    <h1 class="app-page-title">@Organization.DisplayName</h1>
                    @if (!string.IsNullOrWhiteSpace(Organization.Description))
                    {
                        <p class="max-w-3xl text-base leading-8 text-slate-300">@Organization.Description</p>
                    }
                    <div class="flex flex-wrap gap-2">
                        <span class="app-chip">@FilteredCount visible titles</span>
                        <span class="app-chip">Public catalog only</span>
                    </div>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/games">Back to games</a>
                    <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@BuildOrganizationHref(clearGenreFilters: true, acquisitionOnly: false, pageNumber: 1)">Reset filters</a>
                </div>
            </div>
        </section>

        <section class="app-panel p-5">
            <form class="grid gap-3 lg:grid-cols-[2fr_1fr_1fr_auto]" @onsubmit="HandleFilterFormSubmitAsync" @onsubmit:preventDefault="true">
                <label class="text-sm text-slate-300">
                    Search
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" value="@SearchInput" @oninput="HandleSearchInputAsync" placeholder="Title or description" />
                </label>
                <label class="text-sm text-slate-300">
                    Content kind
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="ContentKindInput">
                        <option value="game">Games</option>
                        <option value="app">Apps</option>
                    </select>
                </label>
                <label class="text-sm text-slate-300">
                    Sort
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" @bind="SortInput">
                        <option value="title-asc">Title (A-Z)</option>
                        <option value="title-desc">Title (Z-A)</option>
                        <option value="genre-asc">Genre</option>
                        <option value="players-asc">Players (low-high)</option>
                        <option value="players-desc">Players (high-low)</option>
                        <option value="age-asc">Age rating (low-high)</option>
                        <option value="age-desc">Age rating (high-low)</option>
                    </select>
                </label>
                <div class="flex items-end gap-2">
                    <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" type="submit">Apply</button>
                </div>
            </form>
            <div class="mt-4">
                <a class="inline-flex items-center rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-200 @(EffectiveAcquisitionOnly ? "border-cyan-300/45 bg-cyan-300/15 text-cyan-50" : string.Empty)" href="@BuildOrganizationHref(acquisitionOnly: !EffectiveAcquisitionOnly, pageNumber: 1)">
                    Requires acquisition link
                </a>
            </div>
        </section>

        <section class="app-panel p-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <h2 class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold uppercase tracking-[0.08em] text-white">Genres</h2>
                <a class="app-chip" href="@BuildOrganizationHref(clearGenreFilters: true, pageNumber: 1)">Clear genre filters</a>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
                @foreach (var genreTag in AvailableGenreTags)
                {
                    var selected = SelectedGenres.Contains(genreTag, StringComparer.OrdinalIgnoreCase);
                    <a class="rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] @(selected ? "border-cyan-300/45 bg-cyan-300/15 text-cyan-50" : "border-white/15 text-slate-100")" href="@BuildOrganizationHref(toggleGenre: genreTag, pageNumber: 1)">
                        @genreTag
                    </a>
                }
            </div>
        </section>

        @if (FilteredCount == 0)
        {
            <section class="app-panel p-6">
                <h2 class="text-xl font-semibold text-white">No titles match the current filters</h2>
                <p class="mt-3 text-sm leading-7 text-slate-300">Try clearing one or more filters.</p>
            </section>
        }
        else
        {
            <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                @foreach (var title in PagedTitles)
                {
                    <a class="app-panel p-5 transition hover:-translate-y-1 hover:border-cyan-300/35" href="@($"/games/{title.OrganizationSlug}/{title.Slug}")">
                        <div class="h-36 rounded-[1.4rem] bg-cover bg-center @GetCardFallbackGradient(title)" style="@GetCardStyle(title)"></div>
                        <div class="mt-4 flex flex-wrap gap-2">
                            @foreach (var genreTag in ParseGenreTags(title.GenreDisplay))
                            {
                                <span class="app-chip">@genreTag</span>
                            }
                        </div>
                        <div class="mt-3 text-xl font-semibold text-white">@title.DisplayName</div>
                        <div class="mt-2 text-sm text-slate-300">@title.ShortDescription</div>
                        <div class="mt-2 text-sm text-slate-300">@title.PlayerCountDisplay</div>
                    </a>
                }
            </section>

            <section class="flex items-center justify-between">
                <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/35 @(HasPreviousPage ? string.Empty : "pointer-events-none opacity-40")" href="@BuildOrganizationHref(pageNumber: CurrentPageNumber - 1)">Previous</a>
                <div class="text-sm text-slate-400">Page @CurrentPageNumber of @TotalPages</div>
                <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/35 @(HasNextPage ? string.Empty : "pointer-events-none opacity-40")" href="@BuildOrganizationHref(pageNumber: CurrentPageNumber + 1)">Next</a>
            </section>
        }
    }
</section>

@code {
    private const int SourcePageSize = 48;
    private const int BrowsePageSize = 12;

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "q")]
    public string? SearchQuery { get; set; }

    [SupplyParameterFromQuery(Name = "genres")]
    public string? GenresQuery { get; set; }

    [SupplyParameterFromQuery]
    public string? ContentKind { get; set; }

    [SupplyParameterFromQuery]
    public string? Sort { get; set; }

    [SupplyParameterFromQuery]
    public int? PageNumber { get; set; }

    [SupplyParameterFromQuery]
    public bool? AcquisitionOnly { get; set; }

    private bool IsLoading { get; set; }

    private string? ErrorMessage { get; set; }

    private string SearchInput { get; set; } = string.Empty;

    private string ContentKindInput { get; set; } = "game";

    private string SortInput { get; set; } = "title-asc";

    private CancellationTokenSource? SearchDebounceTokenSource { get; set; }

    private OrganizationSummary? Organization { get; set; }

    private IReadOnlyList<CatalogTitleSummary> AllTitles { get; set; } = [];

    private IReadOnlyList<CatalogTitleSummary> PagedTitles { get; set; } = [];

    private IReadOnlyList<string> AvailableGenreTags { get; set; } = [];

    private IReadOnlyList<string> SelectedGenres => ParseCsv(GenresQuery);

    private int EffectivePageNumber => PageNumber is > 0 ? PageNumber.Value : 1;

    private bool EffectiveAcquisitionOnly => AcquisitionOnly ?? false;

    private int CurrentPageNumber { get; set; } = 1;

    private string EffectiveContentKind =>
        string.Equals(ContentKind, "app", StringComparison.OrdinalIgnoreCase) ? "app" : "game";

    private string EffectiveSort => (Sort ?? "title-asc").Trim().ToLowerInvariant() switch
    {
        "title-desc" => "title-desc",
        "genre-asc" => "genre-asc",
        "players-asc" => "players-asc",
        "players-desc" => "players-desc",
        "age-asc" => "age-asc",
        "age-desc" => "age-desc",
        _ => "title-asc"
    };

    private int FilteredCount { get; set; }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCount / (double)BrowsePageSize));

    private bool HasPreviousPage => CurrentPageNumber > 1;

    private bool HasNextPage => CurrentPageNumber < TotalPages;

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;
        IsLoading = true;
        Organization = null;
        InitializeInteractiveInputsFromQuery();

        try
        {
            var normalizedSlug = Slug.Trim().ToLowerInvariant();
            Organization = await ApiClient.GetPublicOrganizationBySlugAsync(normalizedSlug);
            if (Organization is null)
            {
                AllTitles = [];
                PagedTitles = [];
                AvailableGenreTags = [];
                FilteredCount = 0;
                return;
            }

            AllTitles = await LoadAllPublicTitlesForOrganizationAsync(normalizedSlug, EffectiveContentKind);
            ApplyBrowseProjection();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            AllTitles = [];
            PagedTitles = [];
            AvailableGenreTags = [];
            FilteredCount = 0;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task<IReadOnlyList<CatalogTitleSummary>> LoadAllPublicTitlesForOrganizationAsync(string organizationSlug, string contentKind)
    {
        var titles = new List<CatalogTitleSummary>();
        var pageNumber = 1;

        while (true)
        {
            var response = await ApiClient.GetCatalogTitlesAsync(
                new CatalogBrowseRequest(
                    OrganizationSlug: organizationSlug,
                    ContentKind: contentKind,
                    Genre: null,
                    Sort: "title",
                    PageNumber: pageNumber,
                    PageSize: SourcePageSize));

            titles.AddRange(
                response.Titles.Where(candidate =>
                    string.Equals(candidate.Visibility, "listed", StringComparison.OrdinalIgnoreCase) &&
                    (string.Equals(candidate.LifecycleStatus, "testing", StringComparison.OrdinalIgnoreCase) ||
                     string.Equals(candidate.LifecycleStatus, "published", StringComparison.OrdinalIgnoreCase))));

            if (response.Paging.TotalPages <= pageNumber || response.Titles.Count == 0)
            {
                break;
            }

            pageNumber++;
        }

        return titles;
    }

    private void ApplyBrowseProjection()
    {
        var filteredBase = AllTitles.AsEnumerable();

        if (SelectedGenres.Count > 0)
        {
            filteredBase = filteredBase.Where(candidate =>
            {
                var tags = ParseGenreTags(candidate.GenreDisplay);
                return SelectedGenres.Any(selected => tags.Contains(selected, StringComparer.OrdinalIgnoreCase));
            });
        }

        if (EffectiveAcquisitionOnly)
        {
            filteredBase = filteredBase.Where(candidate => !string.IsNullOrWhiteSpace(candidate.AcquisitionUrl));
        }

        var sorted = ApplySort(filteredBase).ToArray();

        IEnumerable<CatalogTitleSummary> query = sorted;
        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            var normalizedSearch = SearchQuery.Trim();
            var threshold = FuzzySearchService.GetMinimumScoreThreshold(normalizedSearch);
            query = sorted
                .Select((title, index) => new
                {
                    Title = title,
                    Index = index,
                    Score = FuzzySearchService.BestScore(
                        normalizedSearch,
                        title.DisplayName,
                        title.ShortDescription,
                        title.GenreDisplay)
                })
                .Where(candidate => candidate.Score >= threshold)
                .OrderByDescending(candidate => candidate.Score)
                .ThenBy(candidate => candidate.Index)
                .Select(candidate => candidate.Title);
        }

        var filtered = query.ToArray();
        FilteredCount = filtered.Length;

        var safePageNumber = Math.Min(Math.Max(1, EffectivePageNumber), TotalPages);
        CurrentPageNumber = safePageNumber;
        var skip = (safePageNumber - 1) * BrowsePageSize;
        PagedTitles = filtered.Skip(skip).Take(BrowsePageSize).ToArray();

        AvailableGenreTags = filtered
            .SelectMany(candidate => ParseGenreTags(candidate.GenreDisplay))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(candidate => candidate, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private void InitializeInteractiveInputsFromQuery()
    {
        SearchInput = SearchQuery ?? string.Empty;
        ContentKindInput = EffectiveContentKind;
        SortInput = EffectiveSort;
    }

    private async Task HandleSearchInputAsync(ChangeEventArgs eventArgs)
    {
        SearchInput = eventArgs.Value?.ToString() ?? string.Empty;

        SearchDebounceTokenSource?.Cancel();
        SearchDebounceTokenSource?.Dispose();
        SearchDebounceTokenSource = new CancellationTokenSource();
        var cancellationToken = SearchDebounceTokenSource.Token;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(90), cancellationToken);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        SearchQuery = string.IsNullOrWhiteSpace(SearchInput) ? null : SearchInput.Trim();
        PageNumber = 1;
        CurrentPageNumber = 1;
        ApplyBrowseProjection();
        await InvokeAsync(StateHasChanged);
    }

    private Task HandleFilterFormSubmitAsync()
    {
        var targetUri = BuildOrganizationHref(
            contentKind: NormalizeContentKindInput(ContentKindInput),
            sort: NormalizeSortInput(SortInput),
            searchQuery: string.IsNullOrWhiteSpace(SearchInput) ? null : SearchInput.Trim(),
            pageNumber: 1);

        NavigationManager.NavigateTo(targetUri);
        return Task.CompletedTask;
    }

    private IEnumerable<CatalogTitleSummary> ApplySort(IEnumerable<CatalogTitleSummary> query) =>
        EffectiveSort switch
        {
            "title-desc" => query.OrderByDescending(candidate => candidate.DisplayName),
            "genre-asc" => query.OrderBy(candidate => candidate.GenreDisplay).ThenBy(candidate => candidate.DisplayName),
            "players-asc" => query.OrderBy(candidate => candidate.MinPlayers).ThenBy(candidate => candidate.MaxPlayers).ThenBy(candidate => candidate.DisplayName),
            "players-desc" => query.OrderByDescending(candidate => candidate.MaxPlayers).ThenByDescending(candidate => candidate.MinPlayers).ThenBy(candidate => candidate.DisplayName),
            "age-asc" => query.OrderBy(candidate => candidate.MinAgeYears).ThenBy(candidate => candidate.DisplayName),
            "age-desc" => query.OrderByDescending(candidate => candidate.MinAgeYears).ThenBy(candidate => candidate.DisplayName),
            _ => query.OrderBy(candidate => candidate.DisplayName)
        };

    private static string NormalizeContentKindInput(string? value) =>
        string.Equals(value, "app", StringComparison.OrdinalIgnoreCase) ? "app" : "game";

    private static string NormalizeSortInput(string? value) =>
        (value ?? "title-asc").Trim().ToLowerInvariant() switch
        {
            "title-desc" => "title-desc",
            "genre-asc" => "genre-asc",
            "players-asc" => "players-asc",
            "players-desc" => "players-desc",
            "age-asc" => "age-asc",
            "age-desc" => "age-desc",
            _ => "title-asc"
        };

    private string BuildOrganizationHref(
        int? pageNumber = null,
        bool? acquisitionOnly = null,
        string? toggleGenre = null,
        string? contentKind = null,
        string? sort = null,
        string? searchQuery = null,
        bool clearGenreFilters = false)
    {
        var genres = SelectedGenres.ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (clearGenreFilters)
        {
            genres.Clear();
        }
        else if (!string.IsNullOrWhiteSpace(toggleGenre))
        {
            if (!genres.Add(toggleGenre))
            {
                genres.Remove(toggleGenre);
            }
        }

        var effectivePage = Math.Max(1, pageNumber ?? CurrentPageNumber);
        var effectiveContentKind = NormalizeContentKindInput(contentKind ?? EffectiveContentKind);
        var effectiveSort = NormalizeSortInput(sort ?? EffectiveSort);
        var effectiveSearchQuery = searchQuery ?? SearchQuery;
        var query = new Dictionary<string, string?>(StringComparer.Ordinal)
        {
            ["q"] = string.IsNullOrWhiteSpace(effectiveSearchQuery) ? null : effectiveSearchQuery.Trim(),
            ["contentKind"] = effectiveContentKind,
            ["sort"] = effectiveSort,
            ["pageNumber"] = effectivePage == 1 ? null : effectivePage.ToString(),
            ["genres"] = genres.Count == 0 ? null : string.Join(',', genres.OrderBy(candidate => candidate, StringComparer.OrdinalIgnoreCase)),
            ["acquisitionOnly"] = acquisitionOnly ?? EffectiveAcquisitionOnly ? "true" : null
        };

        return QueryHelpers.AddQueryString($"/organizations/{Slug}", query);
    }

    private static IReadOnlyList<string> ParseCsv(string? input) =>
        string.IsNullOrWhiteSpace(input)
            ? []
            : input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(candidate => !string.IsNullOrWhiteSpace(candidate))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();

    private static IReadOnlyList<string> ParseGenreTags(string? genreDisplay) =>
        string.IsNullOrWhiteSpace(genreDisplay)
            ? []
            : genreDisplay.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(candidate => !string.IsNullOrWhiteSpace(candidate))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();

    private static string GetCardStyle(CatalogTitleSummary? title) =>
        string.IsNullOrWhiteSpace(title?.CardImageUrl)
            ? string.Empty
            : $"background-image:linear-gradient(135deg, rgba(4,19,29,0.1), rgba(4,19,29,0.4)), url('{title.CardImageUrl}');";

    private static string GetCardFallbackGradient(CatalogTitleSummary? title)
    {
        var primaryGenre = ParseGenreTags(title?.GenreDisplay).FirstOrDefault();
        return primaryGenre switch
        {
            "Shooter" => "bg-[linear-gradient(135deg,_#f8fafc,_#7dd3fc,_#1d4ed8)]",
            "Adventure" => "bg-[linear-gradient(135deg,_#fde68a,_#fb7185,_#7c3aed)]",
            "Puzzle" => "bg-[linear-gradient(135deg,_#d8f3dc,_#60a5fa,_#1e293b)]",
            _ => "bg-[linear-gradient(135deg,_#fef3c7,_#f97316,_#334155)]"
        };
    }

    public void Dispose()
    {
        SearchDebounceTokenSource?.Cancel();
        SearchDebounceTokenSource?.Dispose();
    }
}
