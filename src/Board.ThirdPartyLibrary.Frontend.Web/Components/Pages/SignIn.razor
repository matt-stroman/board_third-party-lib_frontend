@page "/signin"

<PageTitle>Sign In</PageTitle>

<section class="mx-auto max-w-2xl app-panel p-8 text-center">
    @if (string.Equals(Error, "identity-provider-unavailable", StringComparison.Ordinal))
    {
        <h1 class="mt-4 app-page-title">Sign in is unavailable right now</h1>
        <p class="mt-4 text-base leading-8 text-slate-300">
            The sign-in service is temporarily unavailable. Try again in a moment.
        </p>
        <div class="mt-6 flex justify-center gap-3">
            <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@RetryHref" data-enhance-nav="false">Try again</a>
            <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/browse">Back to browse</a>
        </div>
    }
    else if (string.Equals(Error, "identity-provider-auth-failed", StringComparison.Ordinal))
    {
        <h1 class="mt-4 app-page-title">Sign in could not start</h1>
        <p class="mt-4 text-base leading-8 text-slate-300">
            This sign-in request could not be completed. Try again.
        </p>
        <div class="mt-6 flex justify-center gap-3">
            <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@SignInHref" data-enhance-nav="false">Try again</a>
            <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/browse">Back to browse</a>
        </div>
    }
    else if (string.Equals(Error, "identity-provider-session-expired", StringComparison.Ordinal))
    {
        <h1 class="mt-4 app-page-title">Sign-in session expired</h1>
        <p class="mt-4 text-base leading-8 text-slate-300">
            Your previous sign-in attempt expired in this tab. Start a new sign-in.
        </p>
        <div class="mt-6 flex justify-center gap-3">
            <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@SignInHref" data-enhance-nav="false">Start new sign in</a>
            <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/browse">Back to browse</a>
        </div>
    }
    else
    {
        <h1 class="mt-4 app-page-title">Redirecting to sign in</h1>
        <p class="mt-4 text-base leading-8 text-slate-300">
            Continue to secure sign in and return to your play area when authentication completes.
        </p>
        <div class="mt-6 flex justify-center gap-3">
            <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@SignInHref" data-enhance-nav="false">Continue to sign in</a>
            <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/browse">Back to browse</a>
        </div>
    }
</section>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string SignInHref => $"/auth/signin?returnUrl={Uri.EscapeDataString(string.IsNullOrWhiteSpace(ReturnUrl) ? "/player" : ReturnUrl)}";
    private string RetryHref => $"/signin?returnUrl={Uri.EscapeDataString(string.IsNullOrWhiteSpace(ReturnUrl) ? "/player" : ReturnUrl)}";
}
