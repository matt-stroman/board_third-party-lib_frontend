@page "/signout"

<PageTitle>Sign Out</PageTitle>

<section class="mx-auto max-w-2xl app-panel p-8 text-center">
    <div class="app-chip mx-auto w-fit">Auth handoff</div>
    <h1 class="mt-4 app-page-title">Signing you out</h1>
    <p class="mt-4 text-base leading-8 text-slate-300">
        Continue to end the secure session and return to the public library.
    </p>
    <div class="mt-6 flex justify-center gap-3">
        <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/auth/signout?returnUrl=%2Flibrary">Continue to sign out</a>
        <a class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/library">Stay on library</a>
    </div>
</section>
