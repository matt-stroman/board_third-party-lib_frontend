@page "/studios/{Slug}"
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Studio</PageTitle>

<section class="space-y-8">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Studio unavailable</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (IsLoading)
    {
        <section class="app-panel p-6">
            <div class="h-10 w-64 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-32 animate-pulse rounded-[1.4rem] bg-white/10"></div>
        </section>
    }
    else if (Studio is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Studio not found</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">This studio is not available.</p>
        </section>
    }
    else
    {
        <section class="app-panel relative overflow-hidden p-0">
            <div class="min-h-[20rem] bg-cover bg-center" style="@GetStudioHeaderStyle()">
                <div class="h-full bg-[linear-gradient(120deg,rgba(8,10,18,0.88),rgba(8,10,18,0.52),rgba(8,10,18,0.82))] p-6 md:p-8">
                    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
                        <div class="max-w-4xl space-y-4">
                            <div class="flex flex-wrap items-center gap-3">
                                <a class="inline-flex h-12 min-w-[14rem] items-center justify-center whitespace-nowrap rounded-full border border-white/15 px-6 text-sm font-semibold uppercase tracking-[0.18em] leading-none text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" href="/browse">
                                    Back to browse
                                </a>
                            </div>
                            <h1 class="app-page-title">@Studio.DisplayName</h1>
                            @if (!string.IsNullOrWhiteSpace(Studio.Description))
                            {
                                <p class="max-w-3xl text-base leading-8 text-slate-200">@Studio.Description</p>
                            }
                            @if (GetKnownStudioLinks().Count > 0)
                            {
                                <div class="flex flex-wrap gap-3">
                                    @foreach (var link in GetKnownStudioLinks())
                                    {
                                        <a class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/15 bg-black/20 text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100"
                                           href="@link.Url"
                                           target="_blank"
                                           rel="noreferrer"
                                           title="@link.Label"
                                           aria-label="@link.Label">
                                            @((MarkupString)GetStudioLinkIconMarkup(link.Url))
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Studio.LogoUrl))
                        {
                            <div class="flex shrink-0 justify-end">
                                <img class="h-24 w-24 rounded-[1.5rem] border border-white/15 bg-black/15 object-cover shadow-[0_12px_32px_rgba(0,0,0,0.35)] md:h-32 md:w-32" src="@Studio.LogoUrl" alt="@($"{Studio.DisplayName} logo")" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section class="app-panel p-5">
            <div class="grid gap-3 xl:grid-cols-[2fr_0.85fr_0.85fr_auto]">
                <label class="text-sm text-slate-300">
                    Search
                    <input class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" value="@SearchInput" @oninput="HandleSearchInput" placeholder="Title, genre, description" />
                </label>
                <label class="text-sm text-slate-300">
                    Content kind
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" value="@ContentKindInput" @onchange="HandleContentKindChanged">
                        <option value="all">Games and apps</option>
                        <option value="game">Games only</option>
                        <option value="app">Apps only</option>
                    </select>
                </label>
                <label class="text-sm text-slate-300">
                    Sort
                    <select class="mt-2 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100" value="@SortInput" @onchange="HandleSortChanged">
                        <option value="title-asc">Title (A-Z)</option>
                        <option value="title-desc">Title (Z-A)</option>
                        <option value="genre-asc">Genre</option>
                        <option value="players-asc">Players (low-high)</option>
                        <option value="players-desc">Players (high-low)</option>
                        <option value="age-asc">Age rating (low-high)</option>
                        <option value="age-desc">Age rating (high-low)</option>
                    </select>
                </label>
                <div class="flex items-end">
                    <button class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" type="button" @onclick="ResetFilters">
                        Reset filters
                    </button>
                </div>
            </div>

            <div class="mt-5 space-y-3">
                <details class="rounded-[1.5rem] border border-white/10 bg-black/10 px-4 py-3 text-slate-200" open="@(SelectedGenres.Count > 0)">
                    <summary class="flex cursor-pointer list-none items-center gap-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-100/85">
                        <span>Genres</span>
                        <span class="h-px flex-1 bg-white/10"></span>
                        <span class="text-[0.65rem] tracking-[0.16em] text-slate-400">@AvailableGenreTags.Count available</span>
                    </summary>
                    <div class="mt-4 flex flex-wrap gap-2">
                        @foreach (var genreTag in AvailableGenreTags)
                        {
                            var selected = SelectedGenres.Contains(genreTag);
                            <button class="rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] transition @(selected ? "border-cyan-300/45 bg-cyan-300/15 text-cyan-50" : "border-white/15 text-slate-100 hover:border-cyan-300/45 hover:text-cyan-100")" type="button" aria-pressed="@selected" @onclick="() => ToggleGenreFilter(genreTag)">
                                @genreTag
                            </button>
                        }
                    </div>
                </details>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
                <div>
                    <h2 class="font-['Aptos_Display','Trebuchet_MS',sans-serif] text-2xl font-bold uppercase tracking-[0.08em] text-white">Search results</h2>
                    <div class="mt-1 text-sm text-slate-400">
                        Explore @Studio.DisplayName titles without leaving the catalog.
                    </div>
                </div>
                <div class="flex flex-wrap items-center gap-3 xl:justify-end">
                    <label class="text-sm text-slate-300">
                        Results per page
                        <select class="ml-3 rounded-full border border-white/15 bg-slate-950/70 px-4 py-2 text-sm text-slate-100" value="@ResultsPerPageInput" @onchange="HandleResultsPerPageChanged">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="all">All</option>
                        </select>
                    </label>
                    @if (FilteredTitles.Count > 0)
                    {
                        <div class="app-panel flex flex-wrap gap-3 p-4 text-sm">
                            <span>@FilteredTitles.Count titles</span>
                            <span class="text-slate-500">•</span>
                            <span>Page @CurrentPageNumber of @TotalPages</span>
                        </div>
                    }
                </div>
            </div>

            @if (FilteredTitles.Count == 0)
            {
                <section class="app-panel p-6">
                    <h3 class="text-xl font-semibold text-white">No titles match the current filters</h3>
                    <p class="mt-3 text-sm leading-7 text-slate-300">
                        Try clearing one or more filters to broaden the results.
                    </p>
                </section>
            }
            else
            {
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
                    @foreach (var title in PagedTitles)
                    {
                        <button class="app-panel group min-h-[26rem] overflow-hidden p-0 text-left transition hover:-translate-y-1 hover:border-cyan-300/35" type="button" @onclick="() => OpenTitleModalAsync(title)">
                            <div class="flex h-full flex-col justify-end bg-cover bg-center" style="@GetCardStyle(title)">
                                <div class="bg-[linear-gradient(180deg,rgba(7,9,14,0.12),rgba(7,9,14,0.95))] p-4">
                                    <div class="rounded-[1.25rem] border border-white/10 bg-slate-950/65 p-4 shadow-[0_10px_32px_rgba(8,8,12,0.34)] backdrop-blur-sm">
                                        <div class="flex flex-wrap gap-2 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-cyan-100/85">
                                            <span class="rounded-full border border-white/15 px-3 py-1">@FormatContentKind(title.ContentKind)</span>
                                            <span class="rounded-full border border-white/15 px-3 py-1">@title.PlayerCountDisplay</span>
                                            <span class="rounded-full border border-white/15 px-3 py-1">@title.AgeDisplay</span>
                                        </div>
                                        <div class="mt-4 text-2xl font-bold text-white">@title.DisplayName</div>
                                        <div class="mt-2 text-xs uppercase tracking-[0.22em] text-cyan-100/75">@Studio.DisplayName</div>
                                        <div class="mt-3 flex flex-wrap gap-2">
                                            @foreach (var tag in BrowseCatalogProjectionService.ParseGenreTags(title.GenreDisplay).Take(3))
                                            {
                                                <span class="rounded-full border border-white/10 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-slate-100">@tag</span>
                                            }
                                        </div>
                                        <p class="mt-4 text-sm leading-6 text-slate-200">
                                            @title.ShortDescription
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </button>
                    }
                </div>

                <div class="flex flex-wrap items-center justify-between gap-3">
                    <button class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 @(HasPreviousPage ? string.Empty : "pointer-events-none opacity-40")" type="button" @onclick="ShowPreviousPage" disabled="@(!HasPreviousPage)">
                        Previous
                    </button>
                    <div class="text-sm text-slate-400">Showing @PagedTitles.Count of @FilteredTitles.Count results</div>
                    <button class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100 @(HasNextPage ? string.Empty : "pointer-events-none opacity-40")" type="button" @onclick="ShowNextPage" disabled="@(!HasNextPage)">
                        Next
                    </button>
                </div>
            }
        </section>

        @if (GetOtherStudioLinks().Count > 0)
        {
            <section class="app-panel p-5">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Studio links</div>
                <div class="mt-4 flex flex-wrap gap-3">
                    @foreach (var link in GetOtherStudioLinks())
                    {
                        <a class="rounded-full border border-white/15 px-4 py-2 text-sm text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100"
                           href="@link.Url"
                           target="_blank"
                           rel="noreferrer">
                            @link.Label
                        </a>
                    }
                </div>
            </section>
        }
    }
</section>

@if (IsTitleModalOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/75 p-4 backdrop-blur-sm" @onclick="CloseTitleModal">
        <div class="app-panel max-h-[90vh] w-full max-w-5xl overflow-y-auto p-6 md:p-8" @onclick:stopPropagation="true">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Quick view</div>
                    <h2 class="mt-2 text-3xl font-black text-white">@(ModalTitleDetail?.DisplayName ?? ModalTitleSummary?.DisplayName)</h2>
                </div>
                <button class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" type="button" @onclick="CloseTitleModal">
                    Close
                </button>
            </div>

            @if (IsTitleModalLoading)
            {
                <div class="mt-6 h-72 animate-pulse rounded-[1.75rem] bg-white/10"></div>
            }
            else if (!string.IsNullOrWhiteSpace(TitleModalError))
            {
                <div class="mt-6 rounded-[1.5rem] border border-rose-400/25 bg-rose-500/10 p-5 text-sm leading-7 text-rose-100">
                    @TitleModalError
                </div>
            }
            else if (ModalTitleDetail is not null)
            {
                <div class="mt-6 space-y-6">
                    <div class="min-h-[20rem] rounded-[1.75rem] bg-cover bg-center" style="@GetModalHeroStyle(ModalTitleDetail)"></div>
                    <div class="grid gap-6 lg:grid-cols-[1.35fr_0.65fr]">
                        <div class="space-y-5">
                            <div class="flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-cyan-100/80">
                                <span class="rounded-full border border-white/15 px-3 py-1">@FormatContentKind(ModalTitleDetail.ContentKind)</span>
                                <span class="rounded-full border border-white/15 px-3 py-1">@ModalTitleDetail.PlayerCountDisplay</span>
                                <span class="rounded-full border border-white/15 px-3 py-1">@ModalTitleDetail.AgeDisplay</span>
                                @foreach (var tag in BrowseCatalogProjectionService.ParseGenreTags(ModalTitleDetail.GenreDisplay))
                                {
                                    <span class="rounded-full border border-white/15 px-3 py-1">@tag</span>
                                }
                            </div>
                            <p class="text-base leading-8 text-slate-200">@ModalTitleDetail.ShortDescription</p>
                            @if (!string.IsNullOrWhiteSpace(ModalTitleDetail.Description))
                            {
                                <p class="text-sm leading-7 text-slate-300">@ModalTitleDetail.Description</p>
                            }
                        </div>
                        <div class="space-y-4">
                            <div class="rounded-[1.5rem] border border-white/10 bg-black/15 p-5">
                                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Studio</div>
                                <div class="mt-2 text-lg font-semibold text-white">@(Studio?.DisplayName ?? ModalTitleDetail.StudioSlug)</div>
                            </div>
                            <div class="rounded-[1.5rem] border border-white/10 bg-black/15 p-5">
                                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Release</div>
                                <div class="mt-2 text-sm text-slate-300">@(ModalTitleDetail.CurrentRelease?.Version ?? "Not published")</div>
                            </div>
                            <div class="flex flex-col gap-3">
                                <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@($"/browse/{ModalTitleDetail.StudioSlug}/{ModalTitleDetail.Slug}")">
                                    Details
                                </a>
                                @if (!string.IsNullOrWhiteSpace(ModalTitleDetail.Acquisition?.Url ?? ModalTitleDetail.AcquisitionUrl))
                                {
                                    <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@(ModalTitleDetail.Acquisition?.Url ?? ModalTitleDetail.AcquisitionUrl)" target="_blank" rel="noreferrer">
                                        @(ModalTitleDetail.Acquisition?.Label ?? "Get title")
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private string SearchInput { get; set; } = string.Empty;
    private string ContentKindInput { get; set; } = "all";
    private string SortInput { get; set; } = "title-asc";
    private string ResultsPerPageInput { get; set; } = "10";
    private StudioSummary? Studio { get; set; }
    private IReadOnlyList<CatalogTitleSummary> AllTitles { get; set; } = [];
    private IReadOnlyList<CatalogTitleSummary> FilteredTitles { get; set; } = [];
    private IReadOnlyList<CatalogTitleSummary> PagedTitles { get; set; } = [];
    private IReadOnlyList<string> AvailableGenreTags { get; set; } = [];
    private IReadOnlyDictionary<string, string> StudioDisplayNameBySlug { get; set; } = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyDictionary<string, string?> StudioDescriptionBySlug { get; set; } = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> SelectedGenres { get; } = new(StringComparer.OrdinalIgnoreCase);
    private int CurrentPageNumber { get; set; } = 1;
    private CatalogTitleSummary? ModalTitleSummary { get; set; }
    private CatalogTitle? ModalTitleDetail { get; set; }
    private string? TitleModalError { get; set; }
    private bool IsTitleModalLoading { get; set; }
    private Dictionary<string, CatalogTitle> TitleDetailCache { get; } = new(StringComparer.OrdinalIgnoreCase);
    private int ResultsPerPage => NormalizeResultsPerPage(ResultsPerPageInput);
    private int TotalPages => ResultsPerPage <= 0 ? 1 : Math.Max(1, (int)Math.Ceiling(FilteredTitles.Count / (double)ResultsPerPage));
    private bool HasPreviousPage => CurrentPageNumber > 1;
    private bool HasNextPage => CurrentPageNumber < TotalPages;
    private bool IsTitleModalOpen => ModalTitleSummary is not null;

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;
        IsLoading = true;
        CloseTitleModal();

        try
        {
            var normalizedSlug = Slug.Trim().ToLowerInvariant();
            Studio = await ApiClient.GetPublicStudioBySlugAsync(normalizedSlug);
            if (Studio is null)
            {
                AllTitles = [];
                FilteredTitles = [];
                PagedTitles = [];
                AvailableGenreTags = [];
                StudioDisplayNameBySlug = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                StudioDescriptionBySlug = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
                return;
            }

            StudioDisplayNameBySlug = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
            {
                [Studio.Slug] = Studio.DisplayName
            };
            StudioDescriptionBySlug = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase)
            {
                [Studio.Slug] = Studio.Description
            };

            AllTitles = await LoadAllPublicTitlesForStudioAsync(normalizedSlug);
            ApplyBrowseProjection(resetPage: true);
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            Studio = null;
            AllTitles = [];
            FilteredTitles = [];
            PagedTitles = [];
            AvailableGenreTags = [];
            StudioDisplayNameBySlug = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            StudioDescriptionBySlug = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task<IReadOnlyList<CatalogTitleSummary>> LoadAllPublicTitlesForStudioAsync(string studioSlug)
    {
        var titles = new List<CatalogTitleSummary>();
        var pageNumber = 1;

        while (true)
        {
            var response = await ApiClient.GetCatalogTitlesAsync(
                new CatalogBrowseRequest(
                    StudioSlug: studioSlug,
                    ContentKind: null,
                    Genre: null,
                    Sort: "title",
                    PageNumber: pageNumber,
                    PageSize: 48));

            titles.AddRange(
                response.Titles.Where(candidate =>
                    string.Equals(candidate.Visibility, "listed", StringComparison.OrdinalIgnoreCase) &&
                    (string.Equals(candidate.LifecycleStatus, "testing", StringComparison.OrdinalIgnoreCase) ||
                     string.Equals(candidate.LifecycleStatus, "published", StringComparison.OrdinalIgnoreCase))));

            if (response.Paging.TotalPages <= pageNumber || response.Titles.Count == 0)
            {
                break;
            }

            pageNumber++;
        }

        return titles;
    }

    private string GetStudioHeaderStyle()
    {
        if (string.IsNullOrWhiteSpace(Studio?.BannerUrl))
        {
            return string.Empty;
        }

        return $"background-image:url('{Studio.BannerUrl}');";
    }

    private IReadOnlyList<StudioLink> GetKnownStudioLinks() =>
        Studio?.Links
            .Where(candidate => IsKnownStudioLink(candidate.Url))
            .OrderBy(candidate => candidate.Label, StringComparer.OrdinalIgnoreCase)
            .ToList()
        ?? [];

    private IReadOnlyList<StudioLink> GetOtherStudioLinks() =>
        Studio?.Links
            .Where(candidate => !IsKnownStudioLink(candidate.Url))
            .OrderBy(candidate => candidate.Label, StringComparer.OrdinalIgnoreCase)
            .ToList()
        ?? [];

    private static bool IsKnownStudioLink(string url) => TryGetStudioLinkIconKey(url) is not null;

    private static string? TryGetStudioLinkIconKey(string url)
    {
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            return null;
        }

        var host = uri.Host.ToLowerInvariant();
        if (host.Contains("linkedin.com", StringComparison.Ordinal))
        {
            return "linkedin";
        }
        if (host is "x.com" || host.EndsWith(".x.com", StringComparison.Ordinal) || host.Contains("twitter.com", StringComparison.Ordinal))
        {
            return "x";
        }
        if (host.Contains("discord.com", StringComparison.Ordinal) || host.Contains("discord.gg", StringComparison.Ordinal))
        {
            return "discord";
        }
        if (host.Contains("facebook.com", StringComparison.Ordinal))
        {
            return "facebook";
        }
        if (host.Contains("instagram.com", StringComparison.Ordinal))
        {
            return "instagram";
        }
        if (host.Contains("youtube.com", StringComparison.Ordinal) || host.Contains("youtu.be", StringComparison.Ordinal))
        {
            return "youtube";
        }
        if (host.Contains("github.com", StringComparison.Ordinal))
        {
            return "github";
        }

        return null;
    }

    private static string GetStudioLinkIconMarkup(string url) => TryGetStudioLinkIconKey(url) switch
    {
        "linkedin" => """<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M4.98 3.5a2.48 2.48 0 1 1 0 4.96 2.48 2.48 0 0 1 0-4.96ZM3 9h4v12H3Zm7 0h3.83v1.64h.05c.53-1.01 1.84-2.08 3.79-2.08C21.73 8.56 24 10.6 24 15v6h-4v-5.32c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21h-4Z"/></svg>""",
