    private void ApplyBrowseProjection(bool resetPage)
    {
        var projection = BrowseCatalogProjectionService.Project(
            AllTitles,
            StudioDisplayNameBySlug,
            StudioDescriptionBySlug,
            new BrowseCatalogFilterState(
                string.IsNullOrWhiteSpace(SearchInput) ? null : SearchInput.Trim(),
                ContentKindInput,
                SortInput,
                SelectedGenres.ToArray(),
                []));

        FilteredTitles = projection.FilteredTitles;
        AvailableGenreTags = projection.AvailableGenres;
        CurrentPageNumber = resetPage ? 1 : Math.Clamp(CurrentPageNumber, 1, TotalPages);
        ApplyPaging();
    }

    private void ApplyPaging()
    {
        if (FilteredTitles.Count == 0)
        {
            PagedTitles = [];
            CurrentPageNumber = 1;
            return;
        }

        if (ResultsPerPage <= 0)
        {
            CurrentPageNumber = 1;
            PagedTitles = FilteredTitles;
            return;
        }

        CurrentPageNumber = Math.Clamp(CurrentPageNumber, 1, TotalPages);
        var skip = (CurrentPageNumber - 1) * ResultsPerPage;
        PagedTitles = FilteredTitles.Skip(skip).Take(ResultsPerPage).ToArray();
    }

    private void HandleSearchInput(ChangeEventArgs eventArgs)
    {
        SearchInput = eventArgs.Value?.ToString() ?? string.Empty;
        ApplyBrowseProjection(resetPage: true);
    }

    private void HandleContentKindChanged(ChangeEventArgs eventArgs)
    {
        ContentKindInput = BrowseCatalogProjectionService.NormalizeContentKind(eventArgs.Value?.ToString());
        ApplyBrowseProjection(resetPage: true);
    }

    private void HandleSortChanged(ChangeEventArgs eventArgs)
    {
        SortInput = BrowseCatalogProjectionService.NormalizeSort(eventArgs.Value?.ToString());
        ApplyBrowseProjection(resetPage: true);
    }

    private void HandleResultsPerPageChanged(ChangeEventArgs eventArgs)
    {
        ResultsPerPageInput = NormalizeResultsPerPageInput(eventArgs.Value?.ToString());
        ApplyBrowseProjection(resetPage: true);
    }

    private void ResetFilters()
    {
        SearchInput = string.Empty;
        ContentKindInput = "all";
        SortInput = "title-asc";
        ResultsPerPageInput = "10";
        SelectedGenres.Clear();
        ApplyBrowseProjection(resetPage: true);
    }

    private void ToggleGenreFilter(string genreTag)
    {
        if (!SelectedGenres.Add(genreTag))
        {
            SelectedGenres.Remove(genreTag);
        }

        ApplyBrowseProjection(resetPage: true);
    }

    private void ShowPreviousPage()
    {
        if (!HasPreviousPage)
        {
            return;
        }

        CurrentPageNumber--;
        ApplyPaging();
    }

    private void ShowNextPage()
    {
        if (!HasNextPage)
        {
            return;
        }

        CurrentPageNumber++;
        ApplyPaging();
    }

    private async Task OpenTitleModalAsync(CatalogTitleSummary title)
    {
        ModalTitleSummary = title;
        ModalTitleDetail = null;
        TitleModalError = null;
        IsTitleModalLoading = true;

        var cacheKey = BuildTitleCacheKey(title.StudioSlug, title.Slug);
        if (TitleDetailCache.TryGetValue(cacheKey, out var cachedTitle))
        {
            ModalTitleDetail = cachedTitle;
            IsTitleModalLoading = false;
            return;
        }

        try
        {
            ModalTitleDetail = await ApiClient.GetCatalogTitleAsync(title.StudioSlug, title.Slug);
            if (ModalTitleDetail is not null)
            {
                TitleDetailCache[cacheKey] = ModalTitleDetail;
            }
        }
        catch (Exception exception)
        {
            TitleModalError = exception.Message;
        }
        finally
        {
            IsTitleModalLoading = false;
        }
    }

    private void CloseTitleModal()
    {
        ModalTitleSummary = null;
        ModalTitleDetail = null;
        TitleModalError = null;
        IsTitleModalLoading = false;
    }

    private static string FormatContentKind(string? contentKind) => string.Equals(contentKind, "app", StringComparison.OrdinalIgnoreCase) ? "App" : "Game";
    private static string BuildTitleCacheKey(string studioSlug, string titleSlug) => $"{studioSlug}/{titleSlug}";
    private static string NormalizeResultsPerPageInput(string? value) => string.Equals(value, "all", StringComparison.OrdinalIgnoreCase) ? "all" : NormalizeResultsPerPage(value).ToString();
    private static int NormalizeResultsPerPage(string? value) => (value ?? "10").Trim().ToLowerInvariant() switch { "25" => 25, "50" => 50, "all" => 0, _ => 10 };

    private static string GetCardStyle(CatalogTitleSummary? title) => string.IsNullOrWhiteSpace(title?.CardImageUrl) ? $"background-image:{GetFallbackGradient(title?.GenreDisplay)};" : $"background-image:linear-gradient(180deg, rgba(7,9,14,0.02), rgba(7,9,14,0.30)), url('{title.CardImageUrl}');";

    private static string GetModalHeroStyle(CatalogTitle? title)
    {
        var heroUrl = title?.MediaAssets.FirstOrDefault(asset => string.Equals(asset.MediaRole, "hero", StringComparison.OrdinalIgnoreCase))?.SourceUrl ?? title?.CardImageUrl;
        return string.IsNullOrWhiteSpace(heroUrl) ? $"background-image:{GetFallbackGradient(title?.GenreDisplay)};" : $"background-image:linear-gradient(135deg, rgba(4,19,29,0.16), rgba(4,19,29,0.58)), url('{heroUrl}');";
    }

    private static string GetFallbackGradient(string? genreDisplay)
    {
        var primaryGenre = BrowseCatalogProjectionService.ParseGenreTags(genreDisplay).FirstOrDefault();
        return primaryGenre switch
        {
            "Shooter" => "linear-gradient(135deg, #f8fafc, #7dd3fc, #1d4ed8)",
            "Adventure" => "linear-gradient(135deg, #fde68a, #fb7185, #7c3aed)",
            "Puzzle" => "linear-gradient(135deg, #d8f3dc, #60a5fa, #1e293b)",
            _ => "linear-gradient(135deg, #fef3c7, #f97316, #334155)"
        };
    }
