@page "/browse/{StudioSlug}/{TitleSlug}"
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Title Details</PageTitle>

<section class="space-y-8">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CatalogEntry is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">
                The requested title is not currently visible in the public catalog.
            </p>
        </section>
    }
    else
    {
        <section class="app-panel overflow-hidden p-6">
            <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
                <div class="space-y-5">
                    <div class="flex flex-wrap gap-2">
                        @foreach (var genreTag in ParseGenreTags(CatalogEntry.GenreDisplay))
                        {
                            <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100">@genreTag</span>
                        }
                        <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100">@CatalogEntry.PlayerCountDisplay</span>
                        <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100">@CatalogEntry.AgeDisplay</span>
                    </div>
                    <div>
                        <h1 class="app-page-title">@CatalogEntry.DisplayName</h1>
                        <p class="mt-4 max-w-2xl text-base leading-8 text-slate-300">
                            @CatalogEntry.Description
                        </p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(PlayerActionStatusMessage))
                    {
                        <div class="rounded-[1rem] border border-cyan-300/25 bg-cyan-300/10 px-4 py-3 text-sm text-cyan-50">@PlayerActionStatusMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(PlayerActionErrorMessage))
                    {
                        <div class="rounded-[1rem] border border-rose-300/35 bg-rose-500/10 px-4 py-3 text-sm text-rose-100">@PlayerActionErrorMessage</div>
                    }
                    @if (CatalogEntry.IsReported)
                    {
                        <div class="rounded-[1rem] border border-amber-200/35 bg-amber-300/10 px-4 py-3 text-sm leading-7 text-amber-50">
                            @GetReportedTitleBannerMessage(HasReported(CatalogEntry.Id))
                        </div>
                    }
                    <div class="flex flex-col gap-3 sm:flex-row">
                        <TitlePlayerActionButtons Visible="@ShowPlayerActions"
                                                  IsBusy="@IsTitleBusy(CatalogEntry.Id)"
                                                  IsWishlisted="@IsWishlisted(CatalogEntry.Id)"
                                                  IsOwned="@IsOwned(CatalogEntry.Id)"
                                                  IsReported="@HasReported(CatalogEntry.Id)"
                                                  CanReport="@CanReport(CatalogEntry.Id)"
                                                  OnToggleWishlist="() => ToggleWishlistAsync(CatalogEntry.Id, CatalogEntry.DisplayName)"
                                                  OnToggleOwned="() => ToggleOwnedAsync(CatalogEntry.Id, CatalogEntry.DisplayName)"
                                                  OnReport="() => OpenReportModal(CatalogEntry.Id, CatalogEntry.DisplayName)" />
                        @if (!string.IsNullOrWhiteSpace(CatalogEntry.Acquisition?.Url ?? CatalogEntry.AcquisitionUrl))
                        {
                            <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@(CatalogEntry.Acquisition?.Url ?? CatalogEntry.AcquisitionUrl)" target="_blank" rel="noreferrer">
                                @(CatalogEntry.Acquisition?.Label ?? "View acquisition")
                            </a>
                        }
                        <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@($"/studios/{CatalogEntry.StudioSlug}")">Open studio</a>
                    </div>
                </div>
                <div class="min-h-[320px] rounded-[1.75rem] bg-cover bg-center @HeroFallbackGradient" style="@HeroBackgroundStyle"></div>
            </div>
        </section>

        <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
            <div class="app-panel p-6">
                <h2 class="text-xl font-semibold text-white">About</h2>
                <p class="mt-4 text-base leading-8 text-slate-300">
                    @CatalogEntry.ShortDescription
                </p>
                <div class="mt-6 grid gap-3 text-sm text-slate-300 sm:grid-cols-2">
                    <div class="rounded-[1.25rem] bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Studio</div>
                        <div class="mt-2 text-white">@CatalogEntry.StudioSlug</div>
                    </div>
                    <div class="rounded-[1.25rem] bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Media assets</div>
                        <div class="mt-2 text-white">@CatalogEntry.MediaAssets.Count</div>
                    </div>
                </div>
            </div>
            <div class="app-panel p-6">
                <h2 class="text-xl font-semibold text-white">Current release</h2>
                <dl class="mt-4 grid gap-3 text-sm text-slate-300">
                    <div class="flex justify-between gap-4"><dt>Version</dt><dd>@(CatalogEntry.CurrentRelease?.Version ?? "Not published")</dd></div>
                    <div class="flex justify-between gap-4"><dt>Metadata revision</dt><dd>@(CatalogEntry.CurrentRelease?.MetadataRevisionNumber.ToString() ?? "-")</dd></div>
                    <div class="flex justify-between gap-4"><dt>Provider</dt><dd>@(CatalogEntry.Acquisition?.ProviderDisplayName ?? "External")</dd></div>
                </dl>
            </div>
        </section>
    }
</section>

@if (IsReportModalOpen)
{
    <div class="fixed inset-0 z-[60] flex items-center justify-center bg-slate-950/80 p-4 backdrop-blur-sm" @onclick="CloseReportModal">
        <div class="app-panel w-full max-w-2xl p-6" @onclick:stopPropagation="true">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Report title</div>
                    <h2 class="mt-2 text-2xl font-bold text-white">@ReportTargetTitleDisplayName</h2>
                </div>
                <button class="rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100 transition hover:border-cyan-300/60 hover:text-cyan-100" type="button" @onclick="CloseReportModal">
                    Close
                </button>
            </div>
            <p class="mt-4 text-sm leading-7 text-slate-300">
                Tell moderators what looks wrong so they can review it with the developer.
            </p>
            <label class="mt-5 block text-sm text-slate-300">
                Reason
                <textarea class="mt-2 min-h-36 w-full rounded-[1rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-slate-100"
                          value="@ReportReason"
                          @oninput="args => ReportReason = args.Value?.ToString() ?? string.Empty"
                          placeholder="Describe the issue with this title."></textarea>
            </label>
            @if (!string.IsNullOrWhiteSpace(ReportErrorMessage))
            {
                <div class="mt-4 rounded-[1rem] border border-rose-300/35 bg-rose-500/10 px-4 py-3 text-sm text-rose-100">@ReportErrorMessage</div>
            }
            <div class="mt-6 flex flex-wrap gap-3">
                <button class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.18em] text-slate-950 disabled:cursor-not-allowed disabled:opacity-60"
                        type="button"
                        @onclick="SubmitReportAsync"
                        disabled="@(IsSubmittingReport || string.IsNullOrWhiteSpace(ReportReason))">
                    @(IsSubmittingReport ? "Submitting..." : "Submit report")
                </button>
                <button class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" type="button" @onclick="CloseReportModal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string StudioSlug { get; set; } = string.Empty;

    [Parameter] public string TitleSlug { get; set; } = string.Empty;

    private CatalogTitle? CatalogEntry { get; set; }

    private string? ErrorMessage { get; set; }
    private CurrentUserResponse? CurrentUser { get; set; }
    private bool IsLoadingPlayerState { get; set; }
    private HashSet<Guid> OwnedTitleIds { get; } = [];
    private HashSet<Guid> WishlistedTitleIds { get; } = [];
    private HashSet<Guid> ReportedTitleIds { get; } = [];
    private HashSet<Guid> BusyTitleIds { get; } = [];
    private string? PlayerActionErrorMessage { get; set; }
    private string? PlayerActionStatusMessage { get; set; }
    private Guid? ReportTargetTitleId { get; set; }
    private string ReportTargetTitleDisplayName { get; set; } = string.Empty;
    private string ReportReason { get; set; } = string.Empty;
    private string? ReportErrorMessage { get; set; }
    private bool IsSubmittingReport { get; set; }

    private string HeroBackgroundStyle => string.IsNullOrWhiteSpace(HeroImageUrl)
        ? string.Empty
        : $"background-image:linear-gradient(135deg, rgba(4,19,29,0.18), rgba(4,19,29,0.48)), url('{HeroImageUrl}');";

    private string HeroFallbackGradient => GetFallbackGradient(CatalogEntry?.GenreDisplay);
    private bool ShowPlayerActions => CurrentUser.IsPlayer();
    private bool IsReportModalOpen => ReportTargetTitleId is not null;

    private string? HeroImageUrl =>
        CatalogEntry?.MediaAssets.FirstOrDefault(asset => string.Equals(asset.MediaRole, "hero", StringComparison.OrdinalIgnoreCase))?.SourceUrl
        ?? CatalogEntry?.CardImageUrl;

    private static IReadOnlyList<string> ParseGenreTags(string? genreDisplay) =>
        string.IsNullOrWhiteSpace(genreDisplay)
            ? []
            : genreDisplay.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(candidate => !string.IsNullOrWhiteSpace(candidate))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;

        try
        {
            CatalogEntry = await ApiClient.GetCatalogTitleAsync(StudioSlug, TitleSlug);
            await LoadPlayerStateAsync();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            CatalogEntry = null;
        }
    }

    private async Task LoadPlayerStateAsync()
    {
        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            if (!ShowPlayerActions)
            {
                return;
            }

            IsLoadingPlayerState = true;
            var libraryTask = ApiClient.GetPlayerLibraryAsync();
            var wishlistTask = ApiClient.GetPlayerWishlistAsync();
            var reportsTask = ApiClient.GetPlayerTitleReportsAsync();
            await Task.WhenAll(libraryTask, wishlistTask, reportsTask);

            OwnedTitleIds.Clear();
            foreach (var title in libraryTask.Result.Titles)
            {
                OwnedTitleIds.Add(title.Id);
            }

            WishlistedTitleIds.Clear();
            foreach (var title in wishlistTask.Result.Titles)
            {
                WishlistedTitleIds.Add(title.Id);
            }

            ReportedTitleIds.Clear();
            foreach (var report in reportsTask.Result.Reports)
            {
                ReportedTitleIds.Add(report.TitleId);
            }
        }
        catch
        {
            CurrentUser = null;
        }
        finally
        {
            IsLoadingPlayerState = false;
        }
    }

    private bool IsOwned(Guid titleId) => OwnedTitleIds.Contains(titleId);

    private bool IsWishlisted(Guid titleId) => WishlistedTitleIds.Contains(titleId);

    private bool HasReported(Guid titleId) => ReportedTitleIds.Contains(titleId);

    private bool CanReport(Guid titleId) => ShowPlayerActions && !HasReported(titleId);

    private bool IsTitleBusy(Guid titleId) => IsLoadingPlayerState || BusyTitleIds.Contains(titleId);

    private async Task ToggleWishlistAsync(Guid titleId, string titleDisplayName)
    {
        if (!ShowPlayerActions || !BusyTitleIds.Add(titleId))
        {
            return;
        }

        PlayerActionErrorMessage = null;
        PlayerActionStatusMessage = null;

        try
        {
            if (IsWishlisted(titleId))
            {
                await ApiClient.RemoveTitleFromPlayerWishlistAsync(titleId);
                WishlistedTitleIds.Remove(titleId);
                PlayerActionStatusMessage = $"{titleDisplayName} removed from wishlist.";
            }
            else
            {
                await ApiClient.AddTitleToPlayerWishlistAsync(titleId);
                WishlistedTitleIds.Add(titleId);
                PlayerActionStatusMessage = $"{titleDisplayName} added to wishlist.";
            }
        }
        catch (Exception exception)
        {
            PlayerActionErrorMessage = exception.Message;
        }
        finally
        {
            BusyTitleIds.Remove(titleId);
        }
    }

    private async Task ToggleOwnedAsync(Guid titleId, string titleDisplayName)
    {
        if (!ShowPlayerActions || !BusyTitleIds.Add(titleId))
        {
            return;
        }

        PlayerActionErrorMessage = null;
        PlayerActionStatusMessage = null;

        try
        {
            if (IsOwned(titleId))
            {
                await ApiClient.RemoveTitleFromPlayerLibraryAsync(titleId);
                OwnedTitleIds.Remove(titleId);
                PlayerActionStatusMessage = $"{titleDisplayName} removed from My Games.";
            }
            else
            {
                await ApiClient.AddTitleToPlayerLibraryAsync(titleId);
                OwnedTitleIds.Add(titleId);
                PlayerActionStatusMessage = $"{titleDisplayName} added to My Games.";
            }
        }
        catch (Exception exception)
        {
            PlayerActionErrorMessage = exception.Message;
        }
        finally
        {
            BusyTitleIds.Remove(titleId);
        }
    }

    private void OpenReportModal(Guid titleId, string titleDisplayName)
    {
        if (!ShowPlayerActions || HasReported(titleId))
        {
            return;
        }

        ReportTargetTitleId = titleId;
        ReportTargetTitleDisplayName = titleDisplayName;
        ReportReason = string.Empty;
        ReportErrorMessage = null;
    }

    private static string GetReportedTitleBannerMessage(bool reportedByCurrentUser) =>
        reportedByCurrentUser
            ? "This title has been reported and is under moderator review. You reported this title and will receive follow-up in your player notifications."
            : "This title has been reported and is currently under moderator review.";

    private void CloseReportModal()
    {
        ReportTargetTitleId = null;
        ReportTargetTitleDisplayName = string.Empty;
        ReportReason = string.Empty;
        ReportErrorMessage = null;
        IsSubmittingReport = false;
    }

    private async Task SubmitReportAsync()
    {
        if (ReportTargetTitleId is null || IsSubmittingReport)
        {
            return;
        }

        ReportErrorMessage = null;
        PlayerActionErrorMessage = null;
        PlayerActionStatusMessage = null;
        IsSubmittingReport = true;

        try
        {
            var response = await ApiClient.CreatePlayerTitleReportAsync(new CreatePlayerTitleReportRequest(ReportTargetTitleId.Value, ReportReason.Trim()));
            ReportedTitleIds.Add(response.Report.TitleId);
            PlayerActionStatusMessage = $"{ReportTargetTitleDisplayName} has been reported for moderator review.";
            CloseReportModal();
        }
        catch (Exception exception)
        {
            ReportErrorMessage = exception.Message;
            IsSubmittingReport = false;
        }
    }

    private static string GetFallbackGradient(string? genreDisplay) =>
        genreDisplay switch
        {
            "Arcade Shooter" => "bg-[linear-gradient(135deg,_#f8fafc,_#7dd3fc,_#1d4ed8)]",
            "Adventure" => "bg-[linear-gradient(135deg,_#fde68a,_#fb7185,_#7c3aed)]",
            "Puzzle" => "bg-[linear-gradient(135deg,_#d8f3dc,_#60a5fa,_#1e293b)]",
            _ => "bg-[linear-gradient(135deg,_#fef3c7,_#f97316,_#334155)]"
        };
}

