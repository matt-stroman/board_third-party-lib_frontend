@page "/browse/{StudioSlug}/{TitleSlug}"
@inject IBoardLibraryApiClient ApiClient

<PageTitle>Title Details</PageTitle>

<section class="space-y-8">
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title unavailable</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CatalogEntry is null)
    {
        <section class="app-panel p-6">
            <h1 class="app-page-title">Title not found</h1>
            <p class="mt-4 text-base leading-8 text-slate-300">
                The requested title is not currently visible in the public catalog.
            </p>
        </section>
    }
    else
    {
        <section class="app-panel overflow-hidden p-6">
            <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
                <div class="space-y-5">
                    <div class="flex flex-wrap gap-2">
                        @foreach (var genreTag in ParseGenreTags(CatalogEntry.GenreDisplay))
                        {
                            <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100">@genreTag</span>
                        }
                        <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100">@CatalogEntry.PlayerCountDisplay</span>
                        <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-100">@CatalogEntry.AgeDisplay</span>
                    </div>
                    <div>
                        <h1 class="app-page-title">@CatalogEntry.DisplayName</h1>
                        <p class="mt-4 max-w-2xl text-base leading-8 text-slate-300">
                            @CatalogEntry.Description
                        </p>
                    </div>
                    <div class="flex flex-col gap-3 sm:flex-row">
                        @if (!string.IsNullOrWhiteSpace(CatalogEntry.Acquisition?.Url ?? CatalogEntry.AcquisitionUrl))
                        {
                            <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="@(CatalogEntry.Acquisition?.Url ?? CatalogEntry.AcquisitionUrl)" target="_blank" rel="noreferrer">
                                @(CatalogEntry.Acquisition?.Label ?? "View acquisition")
                            </a>
                        }
                        <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="@($"/studios/{CatalogEntry.StudioSlug}")">Open studio</a>
                    </div>
                </div>
                <div class="min-h-[320px] rounded-[1.75rem] bg-cover bg-center @HeroFallbackGradient" style="@HeroBackgroundStyle"></div>
            </div>
        </section>

        <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
            <div class="app-panel p-6">
                <h2 class="text-xl font-semibold text-white">About</h2>
                <p class="mt-4 text-base leading-8 text-slate-300">
                    @CatalogEntry.ShortDescription
                </p>
                <div class="mt-6 grid gap-3 text-sm text-slate-300 sm:grid-cols-2">
                    <div class="rounded-[1.25rem] bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Studio</div>
                        <div class="mt-2 text-white">@CatalogEntry.StudioSlug</div>
                    </div>
                    <div class="rounded-[1.25rem] bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Media assets</div>
                        <div class="mt-2 text-white">@CatalogEntry.MediaAssets.Count</div>
                    </div>
                </div>
            </div>
            <div class="app-panel p-6">
                <h2 class="text-xl font-semibold text-white">Current release</h2>
                <dl class="mt-4 grid gap-3 text-sm text-slate-300">
                    <div class="flex justify-between gap-4"><dt>Version</dt><dd>@(CatalogEntry.CurrentRelease?.Version ?? "Not published")</dd></div>
                    <div class="flex justify-between gap-4"><dt>Metadata revision</dt><dd>@(CatalogEntry.CurrentRelease?.MetadataRevisionNumber.ToString() ?? "-")</dd></div>
                    <div class="flex justify-between gap-4"><dt>Provider</dt><dd>@(CatalogEntry.Acquisition?.ProviderDisplayName ?? "External")</dd></div>
                </dl>
            </div>
        </section>
    }
</section>

@code {
    [Parameter] public string StudioSlug { get; set; } = string.Empty;

    [Parameter] public string TitleSlug { get; set; } = string.Empty;

    private CatalogTitle? CatalogEntry { get; set; }

    private string? ErrorMessage { get; set; }

    private string HeroBackgroundStyle => string.IsNullOrWhiteSpace(HeroImageUrl)
        ? string.Empty
        : $"background-image:linear-gradient(135deg, rgba(4,19,29,0.18), rgba(4,19,29,0.48)), url('{HeroImageUrl}');";

    private string HeroFallbackGradient => GetFallbackGradient(CatalogEntry?.GenreDisplay);

    private string? HeroImageUrl =>
        CatalogEntry?.MediaAssets.FirstOrDefault(asset => string.Equals(asset.MediaRole, "hero", StringComparison.OrdinalIgnoreCase))?.SourceUrl
        ?? CatalogEntry?.CardImageUrl;

    private static IReadOnlyList<string> ParseGenreTags(string? genreDisplay) =>
        string.IsNullOrWhiteSpace(genreDisplay)
            ? []
            : genreDisplay.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(candidate => !string.IsNullOrWhiteSpace(candidate))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();

    protected override async Task OnParametersSetAsync()
    {
        ErrorMessage = null;

        try
        {
            CatalogEntry = await ApiClient.GetCatalogTitleAsync(StudioSlug, TitleSlug);
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            CatalogEntry = null;
        }
    }

    private static string GetFallbackGradient(string? genreDisplay) =>
        genreDisplay switch
        {
            "Arcade Shooter" => "bg-[linear-gradient(135deg,_#f8fafc,_#7dd3fc,_#1d4ed8)]",
            "Adventure" => "bg-[linear-gradient(135deg,_#fde68a,_#fb7185,_#7c3aed)]",
            "Puzzle" => "bg-[linear-gradient(135deg,_#d8f3dc,_#60a5fa,_#1e293b)]",
            _ => "bg-[linear-gradient(135deg,_#fef3c7,_#f97316,_#334155)]"
        };
}

