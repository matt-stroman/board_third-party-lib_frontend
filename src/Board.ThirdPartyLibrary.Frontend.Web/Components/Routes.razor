@rendermode InteractiveServer

<CascadingAuthenticationState>
    <LoggingErrorBoundary>
        <ChildContent>
            <Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
                <Found Context="routeData">
                    <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                        <NotAuthorized>
                            <NotAuthorizedPage />
                        </NotAuthorized>
                    </AuthorizeRouteView>
                    <FocusOnNavigate RouteData="routeData" Selector="h1" />
                </Found>
            </Router>
        </ChildContent>
        <ErrorContent Context="exception">
            <MainLayout>
                <section class="app-panel max-w-3xl p-6">
                    <h1 class="app-page-title">Application Error</h1>
                    <p class="mt-4 text-sm leading-7 text-slate-300">
                        A UI exception was caught. Reload the page to resume.
                    </p>
                    <p class="mt-3 text-xs text-rose-100/90">@exception.Message</p>
                    <div class="mt-6">
                        <a class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-950" href="/">Reload</a>
                    </div>
                </section>
            </MainLayout>
        </ErrorContent>
    </LoggingErrorBoundary>
</CascadingAuthenticationState>
