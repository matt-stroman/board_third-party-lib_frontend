@if (Visible)
{
    <div class="@ContainerClass">
        <button class="@GetButtonClass(IsWishlisted)"
                type="button"
                title="@(IsWishlisted ? "Remove from wishlist" : "Add to wishlist")"
                aria-label="@(IsWishlisted ? "Remove from wishlist" : "Add to wishlist")"
                @onclick="ToggleWishlistAsync"
                disabled="@IsBusy">
            <svg viewBox="0 0 24 24" class="h-4 w-4 @(IsWishlisted ? "fill-current stroke-[1.6]" : "fill-none stroke-2") stroke-current" aria-hidden="true">
                <path d="M12 21 4.7 13.8a4.9 4.9 0 0 1 6.9-6.9L12 7.3l.4-.4a4.9 4.9 0 0 1 6.9 6.9Z"></path>
            </svg>
        </button>
        <button class="@GetButtonClass(IsOwned)"
                type="button"
                title="@(IsOwned ? "Remove from my games" : "Add to my games")"
                aria-label="@(IsOwned ? "Remove from my games" : "Add to my games")"
                @onclick="ToggleOwnedAsync"
                disabled="@IsBusy">
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-2" aria-hidden="true">
                @if (IsOwned)
                {
                    <path d="m5 12 4.2 4.2L19 6.5"></path>
                }
                else
                {
                    <path d="M12 5v14"></path>
                    <path d="M5 12h14"></path>
                }
            </svg>
        </button>
        <button class="@GetButtonClass(IsReported)"
                type="button"
                title="@(CanReport ? "Report title" : "Report already submitted")"
                aria-label="@(CanReport ? "Report title" : "Report already submitted")"
                @onclick="ReportAsync"
                disabled="@(IsBusy || !CanReport)">
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-2" aria-hidden="true">
                <path d="M6 3v18"></path>
                <path d="M6 4h9l-1.5 3L15 10H6"></path>
            </svg>
        </button>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public bool IsWishlisted { get; set; }

    [Parameter]
    public bool IsOwned { get; set; }

    [Parameter]
    public bool IsReported { get; set; }

    [Parameter]
    public bool CanReport { get; set; } = true;

    [Parameter]
    public bool Compact { get; set; }

    [Parameter]
    public EventCallback OnToggleWishlist { get; set; }

    [Parameter]
    public EventCallback OnToggleOwned { get; set; }

    [Parameter]
    public EventCallback OnReport { get; set; }

    private string ContainerClass =>
        Compact
            ? "flex flex-wrap gap-2"
            : "flex flex-wrap gap-3";

    private string GetButtonClass(bool isActive)
    {
        var sizeClass = Compact ? "h-10 w-10" : "h-11 w-11";
        return $"{sizeClass} inline-flex items-center justify-center rounded-full border text-slate-100 transition disabled:cursor-not-allowed disabled:opacity-50 {(isActive ? "border-cyan-300/55 bg-cyan-300/15 text-cyan-50" : "border-white/15 bg-black/15 hover:border-cyan-300/55 hover:text-cyan-100")}";
    }

    private Task ToggleWishlistAsync() =>
        OnToggleWishlist.HasDelegate ? OnToggleWishlist.InvokeAsync() : Task.CompletedTask;

    private Task ToggleOwnedAsync() =>
        OnToggleOwned.HasDelegate ? OnToggleOwned.InvokeAsync() : Task.CompletedTask;

    private Task ReportAsync() =>
        OnReport.HasDelegate ? OnReport.InvokeAsync() : Task.CompletedTask;
}
